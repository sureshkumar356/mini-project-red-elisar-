    """VULNERABILITY 10: Hardcoded credentials (admin/admin123)."""\par 
    message = ""\par 
    msg_cls = ""\par 
    if request.method == "POST":\par 
        username = request.form.get("username", "")\par 
        password = request.form.get("password", "")\par 
\par 
        # Also SQL injectable version\par 
        try:\par 
            conn = sqlite3.connect(DB_PATH)\par 
            c    = conn.cursor()\par 
            # VULNERABLE: hardcoded + SQL injectable\par 
            sql = f"SELECT * FROM users WHERE username='\{username\}' AND password='\{password\}'"\par 
            c.execute(sql)\par 
            user = c.fetchone()\par 
            conn.close()\par 
            if user:\par 
                session["user"] = username\par 
                message = f"├в┼УтАж Logged in as: <b>\{username\}</b> (ID=\{user[0]\})"\par 
