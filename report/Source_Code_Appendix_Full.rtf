        "technique_id", "name", "description", "tactics",\par 
        "platforms", "data_sources", "is_subtechnique",\par 
        "stix_id", "url"\par 
    ]\par 
\par 
    def __init__(\par 
        self,\par 
        technique_id: str,\par 
        name: str,\par 
        description: str,\par 
        tactics: list[str],\par 
        platforms: list[str],\par 
        data_sources: list[str],\par 
        is_subtechnique: bool,\par 
        stix_id: str,\par 
        url: str\par 
    ):\par 
        self.technique_id = technique_id\par 
        self.name = name\par 
        self.description = description\par 
        self.tactics = tactics\par 
        self.platforms = platforms\par 
        self.data_sources = data_sources\par 
        self.is_subtechnique = is_subtechnique\par 
        self.stix_id = stix_id\par 
        self.url = url\par 
\par 
    def to_dict(self) -> dict:\par 
        return \{\par 
            "technique_id": self.technique_id,\par 
            "name": self.name,\par 
            "description": self.description,\par 
            "tactics": self.tactics,\par 
            "platforms": self.platforms,\par 
            "data_sources": self.data_sources,\par 
            "is_subtechnique": self.is_subtechnique,\par 
            "stix_id": self.stix_id,\par 
            "url": self.url,\par 
        \}\par 
\par 
    def to_embedding_text(self) -> str:\par 
        tactics_str = ", ".join(self.tactics) if self.tactics else "unknown"\par 
        desc = self.description[:config.MAX_DESCRIPTION_LENGTH]\par 
        return (\par 
            f"\{self.technique_id\}: \{self.name\} | "\par 
            f"Tactics: \{tactics_str\} | "\par 
            f"\{desc\}"\par 
        )\par 
\par 
    def __repr__(self) -> str:\par 
        return f"AttackTechnique(\{self.technique_id\}: \{self.name\})"\par 
\par 
\par 
def clean_description(raw_description: str) -> str:\par 
    if not raw_description:\par 
        return ""\par 
    text = raw_description\par 
    # Remove citation references\par 
    text = re.sub(r'\\(Citation:[^)]+\\)', '', text)\par 
    # Remove markdown links, keep text\par 
    text = re.sub(r'\\[([^\\]]+)\\]\\([^)]+\\)', r'\\1', text)\par 
    # Remove bold/italic markers\par 
    text = re.sub(r'\\*\{1,3\}([^*]+)\\*\{1,3\}', r'\\1', text)\par 
    # Remove code blocks\par 
    text = re.sub(r'```[^`]*```', '', text, flags=re.DOTALL)\par 
    text = re.sub(r'`([^`]+)`', r'\\1', text)\par 
    # Remove HTML tags\par 
    text = re.sub(r'<[^>]+>', '', text)\par 
    # Remove markdown headers\par 
    text = re.sub(r'^#\{1,6\}\\s+', '', text, flags=re.MULTILINE)\par 
    # Normalize whitespace\par 
    text = re.sub(r'\\n\{3,\}', '\\n\\n', text)\par 
    text = re.sub(r'[ \\t]+', ' ', text)\par 
    return text.strip()\par 
\par 
