def _enrich_chain(chain_steps: list, rag) -> list:\par 
    """Replace 'Unknown' technique names using available technique lookup sources."""\par 
    enriched = []\par 
    for step in chain_steps:\par 
        s = dict(step)\par 
        tid = str(s.get("technique_id") or "").strip().upper()\par 
        name = str(s.get("technique_name") or s.get("name") or "").strip()\par 
        if (not name or name.lower() == "unknown") and tid and rag:\par 
            try:\par 
                record = None\par 
                if hasattr(rag, "vector_store") and hasattr(rag.vector_store, "query_by_technique_id"):\par 
                    record = rag.vector_store.query_by_technique_id(tid)\par 
                elif hasattr(rag, "get_technique"):\par 
                    record = rag.get_technique(tid)\par 
                if record:\par 
                    s["technique_name"] = record.get("name") or record.get("technique_name") or tid\par 
                    if not s.get("tactic") and record.get("tactic"):\par 
                        s["tactic"] = record["tactic"]\par 
                else:\par 
                    s["technique_name"] = tid  # fallback: show ID itself\par 
            except Exception:\par 
                s["technique_name"] = tid\par 
        enriched.append(s)\par 
    return enriched\par 
