def _probe_xss(base: str, timeout_s: float) -> dict:\par 
    payloads = [\par 
        '<script>alert(1)</script>',\par 
        '"><script>alert(1)</script>',\par 
        "'><img src=x onerror=alert(1)>",\par 
    ]\par 
    endpoints_tested = []\par 
    evidence = []\par 
\par 
    xss_endpoints = [\par 
        ("/greet", "name"),\par 
        ("/search", "q"),\par 
        ("/", "q"),\par 
    ]\par 
\par 
    for path, param in xss_endpoints:\par 
        for payload in payloads:\par 
            url = f"\{base\}\{path\}?\{param\}=\{payload\}"\par 
            endpoints_tested.append(url)\par 
            try:\par 
                r = requests.get(url, timeout=timeout_s, allow_redirects=True)\par 
                if payload.lower() in r.text.lower() or "<script>" in r.text.lower():\par 
                    evidence.append(\{\par 
                        "url":        url,\par 
                        "status":     r.status_code,\par 
                        "payload":    payload,\par 
                        "confirmed":  True,\par 
                        "detail":     f"Payload reflected in response at \{path\}?\{param\}=",\par 
                    \})\par 
                    break\par 
            except Exception:\par 
                continue\par 
\par 
    found = len(evidence) > 0\par 
    return \{\par 
        "found":             found,\par 
        "endpoints_tested":  endpoints_tested[:6],\par 
        "evidence":          evidence,\par 
        "vuln_description":  "Reflected XSS: server returns user-supplied JavaScript unescaped, allowing session hijacking.",\par 
        "manual_test":       f"\{base\}/greet?name=<script>alert(document.cookie)</script>",\par 
        "recommendation":    "Escape all user input on output (use Jinja2 autoescaping). Add Content-Security-Policy header.",\par 
    \}\par 
\par 
