def detect_attack_type(scenario: str) -> str:\par 
    """Detect attack type from scenario text via keyword matching."""\par 
    s = scenario.lower()\par 
    scores = \{\}\par 
    for attack, keywords in ATTACK_KEYWORDS.items():\par 
        scores[attack] = sum(1 for kw in keywords if kw in s)\par 
    best = max(scores, key=scores.get)\par 
    return best if scores[best] > 0 else "generic"\par 
