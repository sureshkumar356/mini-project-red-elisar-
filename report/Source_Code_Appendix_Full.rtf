    def _calculate_overall_risk(self, stats: dict) -> str:\par 
        if stats["CRITICAL"] > 0:\par 
            return "CRITICAL"\par 
        elif stats["HIGH"] >= 2:\par 
            return "HIGH"\par 
        elif stats["HIGH"] >= 1 or stats["MEDIUM"] >= 3:\par 
