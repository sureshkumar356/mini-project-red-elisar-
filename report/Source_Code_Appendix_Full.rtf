@app.route("/api/validate", methods=["POST"])\par 
def api_validate():\par 
    """Option 3 ├втВмтАЭ Validate Scenario on Target URL."""\par 
    data = request.get_json(force=True) or \{\}\par 
    raw_scenario  = (data.get("scenario") or "").strip()\par 
    target_url_raw = (data.get("target_url") or "").strip()\par 
    request_id = str(data.get("request_id") or "").strip()\par 
\par 
    if not raw_scenario or not target_url_raw:\par 
        return jsonify(\{"error": "scenario and target_url are required"\}), 400\par 
\par 
    try:\par 
        scenario   = sanitize_scenario(raw_scenario)\par 
        target_url = run_module.normalize_url(target_url_raw)\par 
    except Exception as exc:\par 
        return jsonify(\{"error": str(exc)\}), 400\par 
\par 
    sq = StreamQueue()\par 
    cancel_event = _register_request(request_id)\par 
\par 
    def worker():\par 
        ctx = get_ctx()\par 
        handler = QueueHandler(sq)\par 
        handler.setFormatter(logging.Formatter(config.LOG_FORMAT))\par 
        root = logging.getLogger()\par 
        root.addHandler(handler)\par 
        try:\par 
            _check_cancel(cancel_event)\par 
            sq.put(f"[INFO] Validating scenario on: \{target_url\}")\par 
\par 
            sq.put("[STEP 1/4] Detecting attack type from scenario├втВм┬ж")\par 
            attack_type = detect_attack_type(scenario)\par 
            _check_cancel(cancel_event)\par 
            sq.put(f"[OK] Detected attack type: \{attack_type\}")\par 
\par 
            sq.put(f"[STEP 2/4] Probing target for \{attack_type\}├втВм┬ж")\par 
            probe = probe_target(\par 
                target_url,\par 
                attack_type,\par 
                timeout=float(getattr(config, "WEB_UI_PROBE_TIMEOUT_S", 5.0)),\par 
            )\par 
            _check_cancel(cancel_event)\par 
            status = "CONFIRMED" if probe.get("found") else "NOT CONFIRMED"\par 
            sq.put(f"[OK] Probe result: \{status\} | Severity: \{probe.get('severity', 'N/A')\}")\par 
\par 
            sq.put("[STEP 3/4] Loading RAG engine and mapping MITRE techniques├втВм┬ж")\par 
            ctx.ensure_rag(force_reindex=False)\par 
            _check_cancel(cancel_event)\par 
\par 
            evidence = probe.get("evidence", [])\par 
            vuln_items = []\par 
            for ev in evidence:\par 
                if not ev.get("confirmed"):\par 
                    continue\par 
                vuln_items.append(\{\par 
                    "type": f"Targeted Validation (\{attack_type\})",\par 
                    "detail": ev.get("detail", "Targeted evidence detected"),\par 
                    "severity": probe.get("severity", "MEDIUM"),\par 
                    "cwe_id": "CWE-20",\par 
                    "mitre_hint": "",\par 
                    "recommendation": probe.get("recommendation", "Review and patch issue."),\par 
                    "evidence": f"\{ev.get('url', target_url)\} | \{ev.get('payload', 'probe')\}",\par 
                    "confirmed_live": True,\par 
                \})\par 
            if not vuln_items:\par 
                vuln_items.append(\{\par 
                    "type": f"Targeted Validation (\{attack_type\})",\par 
                    "detail": "No automatic confirmation; manual verification recommended.",\par 
                    "severity": "LOW",\par 
                    "cwe_id": "CWE-200",\par 
                    "mitre_hint": "",\par 
                    "recommendation": probe.get("recommendation", "Perform manual validation."),\par 
                    "evidence": probe.get("manual_test", target_url),\par 
                    "confirmed_live": False,\par 
                \})\par 
\par 
            mapped = ctx.mapper.map_vulnerabilities(vuln_items)\par 
            _check_cancel(cancel_event)\par 
            chain  = ctx.mapper.build_attack_chain(mapped, target_url=target_url)\par 
            sq.put(f"[OK] MITRE mapping: \{len(chain)\} attack chain steps.")\par 
\par 
            sq.put("[STEP 4/4] Generating reports├втВм┬ж")\par 
            recon  = WebReconAgent(target_url).run()\par 
            counts = run_module._severity_counts(vuln_items)\par 
            risk   = run_module._overall_risk(counts)\par 
            report = ReportGenerator().generate(\par 
                target_url=target_url,\par 
                recon_data=recon,\par 
                scan_result=\{\par 
                    "target_url": target_url,\par 
                    "total_vulns": len(vuln_items),\par 
                    "severity_counts": counts,\par 
                    "overall_risk": risk,\par 
                    "vulnerabilities": vuln_items,\par 
                    "tech_stack": recon.get("tech_stack", \{\}),\par 
                \},\par 
                attack_chain=chain,\par 
                llm_analysis=(\par 
                    f"Scenario-driven validation for attack type '\{attack_type\}'. Status: \{status\}."\par 
                ),\par 
            )\par 
            _check_cancel(cancel_event)\par 
            txt_path = run_module._write_option_text_report(\par 
                option_slug="validation",\par 
                mode_name="Validate Scenario on Target URL",\par 
                scenario=scenario,\par 
                target_url=target_url,\par 
                vulnerabilities=vuln_items,\par 
                mapped=mapped,\par 
                mitre_db=ctx.mitre_db,\par 
                rag_engine=ctx.rag,\par 
            )\par 
            sq.put(f"[OK] Text report: \{txt_path.name\}")\par 
\par 
            result_payload = \{\par 
                "type": "result",\par 
                "scenario": scenario,\par 
                "target_url": target_url,\par 
                "attack_type": attack_type,\par 
                "probe_status": status,\par 
                "probe_severity": probe.get("severity", "N/A"),\par 
                "overall_risk": risk,\par 
                "severity_counts": counts,\par 
                "vulnerabilities": vuln_items,\par 
                "attack_chain": chain,\par 
                "reports": \{\par 
                    "txt": str(txt_path),\par 
                    "json": str(report.get("json_path", "")),\par 
                    "md": str(report.get("md_path", "")),\par 
                    "pdf": str(report.get("pdf_path", "")),\par 
                \},\par 
            \}\par 
            _attach_novelty(\par 
                result_payload,\par 
                chain_steps=chain,\par 
                vulnerabilities=vuln_items,\par 
                retrieval_results=[],\par 
            )\par 
            _store_latest("validate", result_payload)\par 
            sq.put("__RESULT__:" + json.dumps(result_payload, default=str))\par 
            sq.put("[DONE] Validation complete.")\par 
        except RequestCancelledError:\par 
            sq.put("[INFO] Request cancelled. Backend worker stopped.")\par 
        except Exception as exc:\par 
            sq.put(f"[ERROR] \{exc\}")\par 
        finally:\par 
            root.removeHandler(handler)\par 
            _cleanup_request(request_id)\par 
            sq.done()\par 
\par 
    threading.Thread(target=worker, daemon=True).start()\par 
\par 
    return Response(\par 
        stream_with_context(_stream_gen(sq)),\par 
        mimetype="text/event-stream",\par 
        headers=\{\par 
            "Cache-Control": "no-cache",\par 
            "X-Accel-Buffering": "no",\par 
            "Connection": "keep-alive",\par 
        \},\par 
    )\par 
