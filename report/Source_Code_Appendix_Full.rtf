def format_probe_result_markdown(result: dict) -> str:\par 
    """Format probe results as a Markdown section for injection into the report."""\par 
    found     = result.get("found", False)\par 
    atype     = result.get("attack_type", "unknown").replace("_", " ").title()\par 
    sev       = result.get("severity", "MEDIUM")\par 
    evidence  = result.get("evidence", [])\par 
    endpoints = result.get("endpoints_tested", [])\par 
    icons     = \{"CRITICAL": "[CRIT]", "HIGH": "[HIGH]", "MEDIUM": "[MED]", "LOW": "[LOW]"\}\par 
    icon      = icons.get(sev, "[UNK]")\par 
\par 
    lines = [\par 
        "## Live Vulnerability Verification",\par 
        "",\par 
        f"> **Attack Type Probed:** \{atype\}",\par 
        f"> **Target:** `\{result.get('target_url', 'N/A')\}`",\par 
        f"> **Status:** \{'[OK] VULNERABILITY CONFIRMED' if found else '[WARN] Not confirmed (may need manual check)'\}",\par 
        f"> **Severity:** \{icon\} \{sev\}",\par 
        "",\par 
    ]\par 
\par 
    if found:\par 
        lines += [\par 
            "### Confirmed Findings",\par 
            "",\par 
        ]\par 
        for i, ev in enumerate(evidence, 1):\par 
            if ev.get("confirmed"):\par 
                lines += [\par 
                    f"#### Finding \{i\}",\par 
                    f"- **URL Tested:** `\{ev.get('url', 'N/A')\}`",\par 
                    f"- **HTTP Status:** \{ev.get('status', 'N/A')\}",\par 
                    f"- **Payload/Method:** `\{ev.get('payload', 'N/A')\}`",\par 
                    f"- **Evidence:** \{ev.get('detail', 'N/A')\}",\par 
                    "",\par 
                ]\par 
    else:\par 
        lines += [\par 
            "### Probe Results",\par 
            "",\par 
            f"No automatic confirmation - the vulnerability may require manual testing.",\par 
            f"**Manual Test URL:** `\{result.get('manual_test', 'N/A')\}`",\par 
            "",\par 
        ]\par 
\par 
    lines += [\par 
        "### Endpoints Probed",\par 
        "",\par 
    ]\par 
    for ep in endpoints[:8]:\par 
        lines.append(f"- `\{ep\}`")\par 
\par 
    lines += [\par 
        "",\par 
        f"**Vulnerability Description:** \{result.get('vuln_description', 'N/A')\}",\par 
        "",\par 
        f"**Recommendation:** \{result.get('recommendation', 'N/A')\}",\par 
        "",\par 
        "---",\par 
        "",\par 
    ]\par 
    return "\\n".join(lines)\par 
