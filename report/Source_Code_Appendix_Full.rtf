\par 
class AttackChainGenerator:\par 
\par 
    def __init__(self, vector_store: FAISSVectorStore, model: str = None):\par 
        self.rag_engine = RAGEngine(vector_store, model=model)\par 
        self.vector_store = vector_store\par 
        self.generation_history: list[dict] = []\par 
\par 
    def generate(\par 
        self,\par 
        scenario: str,\par 
        target_environment: str = "Enterprise Windows Active Directory network",\par 
        chain_length: int = None,\par 
        top_k: int = None,\par 
        tactic_filter: Optional[str] = None,\par 
        platform_filter: Optional[str] = None,\par 
    ) -> dict:\par 
        result = self.rag_engine.generate_attack_chain(\par 
            scenario=scenario,\par 
            target_environment=target_environment,\par 
            chain_length=chain_length,\par 
            top_k=top_k,\par 
            tactic_filter=tactic_filter,\par 
            platform_filter=platform_filter,\par 
        )\par 
        result["analysis"] = self.analyze_chain(result)\par 
        self.generation_history.append(result)\par 
        return result\par 
\par 
    def generate_fast(\par 
        self,\par 
        scenario: str,\par 
        target_environment: str = "Enterprise Windows Active Directory network",\par 
        chain_length: int = None,\par 
        top_k: int = None,\par 
        tactic_filter: Optional[str] = None,\par 
        platform_filter: Optional[str] = None,\par 
    ) -> dict:\par 
        result = self.rag_engine.generate_attack_chain_fast(\par 
            scenario=scenario,\par 
            target_environment=target_environment,\par 
            chain_length=chain_length,\par 
            top_k=top_k,\par 
            tactic_filter=tactic_filter,\par 
            platform_filter=platform_filter,\par 
        )\par 
        result["analysis"] = self.analyze_chain(result)\par 
        self.generation_history.append(result)\par 
        return result\par 
\par 
    def generate_predefined(self, scenario_key: str) -> dict:\par 
        if scenario_key not in PREDEFINED_SCENARIOS:\par 
            available = ", ".join(PREDEFINED_SCENARIOS.keys())\par 
            raise KeyError(f"Unknown scenario '\{scenario_key\}'. Available: \{available\}")\par 
        params = dict(PREDEFINED_SCENARIOS[scenario_key])\par 
        # Respect the predefined scenario length; fall back to DEFAULT_CHAIN_LENGTH only when missing.\par 
        params["chain_length"] = int(params.get("chain_length") or config.DEFAULT_CHAIN_LENGTH)\par 
        logger.info(f"Generating predefined scenario: \{scenario_key\}")\par 
        return self.generate(**params)\par 
\par 
    def generate_batch(self, scenario_keys: Optional[list[str]] = None) -> list[dict]:\par 
        if scenario_keys is None:\par 
            scenario_keys = list(PREDEFINED_SCENARIOS.keys())\par 
        results = []\par 
        for i, key in enumerate(scenario_keys, 1):\par 
            logger.info(f"\\n\{'#'*60\}")\par 
            logger.info(f"BATCH \{i\}/\{len(scenario_keys)\}: \{key\}")\par 
            logger.info(f"\{'#'*60\}")\par 
            try:\par 
                result = self.generate_predefined(key)\par 
                result["scenario_key"] = key\par 
                results.append(result)\par 
            except Exception as e:\par 
                logger.error(f"Failed to generate \{key\}: \{e\}")\par 
                results.append(\{\par 
                    "scenario_key": key,\par 
                    "error": str(e),\par 
                    "timestamp": datetime.now(timezone.utc).isoformat(),\par 
                \})\par 
        return results\par 
\par 
    def analyze_chain(self, result: dict) -> dict:\par 
        chain = result.get("attack_chain", \{\}).get("attack_chain", [])\par 
        if not chain:\par 
            return \{"error": "No attack chain to analyze"\}\par 
\par 
        # Standard MITRE kill chain phases\par 
        mitre_tactics = [\par 
            "reconnaissance", "resource-development", "initial-access",\par 
            "execution", "persistence", "privilege-escalation",\par 
            "defense-evasion", "credential-access", "discovery",\par 
            "lateral-movement", "collection", "command-and-control",\par 
            "exfiltration", "impact",\par 
        ]\par 
\par 
        chain_tactics = [step.get("tactic", "").lower().replace(" ", "-") for step in chain]\par 
        covered_tactics = set(chain_tactics) & set(mitre_tactics)\par 
\par 
        technique_ids = [step.get("technique_id", "") for step in chain]\par 
        unique_techniques = set(technique_ids)\par 
\par 
        steps_with_detection = sum(\par 
            1 for step in chain if step.get("detection_considerations", "").strip()\par 
        )\par 
        hallucinated_steps = sum(\par 
            1 for step in chain if step.get("_hallucination_flag", False)\par 
        )\par 
\par 
        return \{\par 
            "total_steps": len(chain),\par 
            "unique_techniques": len(unique_techniques),\par 
            "technique_reuse": len(chain) - len(unique_techniques),\par 
            "tactical_coverage": \{\par 
                "covered": sorted(covered_tactics),\par 
                "total_mitre_tactics": len(mitre_tactics),\par 
                "coverage_ratio": len(covered_tactics) / len(mitre_tactics),\par 
            \},\par 
            "detection_coverage": \{\par 
                "steps_with_detection": steps_with_detection,\par 
                "coverage_ratio": steps_with_detection / len(chain) if chain else 0,\par 
            \},\par 
            "hallucination_metrics": \{\par 
                "hallucinated_steps": hallucinated_steps,\par 
                "total_steps": len(chain),\par 
                "faithfulness_score": result.get("faithfulness_score", 0),\par 
            \},\par 
            "latency_summary": \{\par 
                "total_pipeline_s": result.get("latency", \{\}).get("pipeline_total_s", 0),\par 
                "retrieval_ms": result.get("latency", \{\}).get("retrieval_time_s", 0) * 1000,\par 
                "generation_s": result.get("latency", \{\}).get("llm_latency_s", 0),\par 
                "tokens_per_second": result.get("latency", \{\}).get("tokens_per_second", 0),\par 
            \},\par 
        \}\par 
\par 
    def export_json(self, result: dict, output_path: Optional[Path] = None) -> Path:\par 
        config.ensure_directories()\par 
        if output_path is None:\par 
            timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")\par 
            output_path = config.OUTPUT_DIR / f"attack_chain_\{timestamp\}.json"\par 
        # Serialize, stripping non-JSON-serializable fields\par 
        clean_result = json.loads(json.dumps(result, default=str))\par 
        with open(output_path, 'w', encoding='utf-8') as f:\par 
            json.dump(clean_result, f, indent=2, ensure_ascii=False)\par 
        logger.info(f"Attack chain exported to: \{output_path\}")\par 
        return output_path\par 
