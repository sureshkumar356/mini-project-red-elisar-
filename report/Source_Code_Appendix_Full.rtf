    # ├втАЭтВм├втАЭтВм 9. Unauthenticated Admin Access ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм\par 
    def _check_unauth_admin(self):\par 
        admin_paths = ["/admin", "/admin/", "/admin/panel",\par 
                       "/administrator", "/management"]\par 
        for path in admin_paths:\par 
            try:\par 
                resp = self.session.get(\par 
                    f"\{self.target\}\{path\}",\par 
                    timeout=self.timeout,\par 
                    allow_redirects=True,\par 
                )\par 
                if resp.status_code == 200:\par 
                    body = resp.text.lower()\par 
                    # Confirm it's actually an admin panel, not a generic 200\par 
                    admin_keywords = ["admin", "panel", "management",\par 
                                      "system", "dashboard", "user"]\par 
                    if any(kw in body for kw in admin_keywords):\par 
                        self._add(\par 
                            vuln_type  = "Unauthenticated Admin Panel Access",\par 
                            detail     = (\par 
                                f"Admin path '\{path\}' returns HTTP 200 without any "\par 
                                f"authentication credentials"\par 
                            ),\par 
                            severity   = "CRITICAL",\par 
                            cwe        = "CWE-284",\par 
                            mitre      = "T1078",\par 
                            evidence   = (\par 
                                f"GET \{self.target\}\{path\} ├втАатАЩ HTTP 200 | "\par 
                                f"Admin keywords confirmed in live response body"\par 
                            ),\par 
                            check      = "_check_unauth_admin",\par 
                            confirmed  = True,\par 
