```python\par 
"""Passive web reconnaissance for the VulnShop demo.\par 
\par 
This module is intentionally lightweight:\par 
- Performs a single baseline GET to the target URL\par 
- Extracts basic tech hints from response headers\par 
- Probes a small set of common sensitive paths\par 
- Records missing security headers and information-leaking headers\par 
\par 
It is used by `vuln_checks.web_vuln_agent`.\par 
"""\par 
\par 
from __future__ import annotations\par 
\par 
import logging\par 
from dataclasses import dataclass\par 
from typing import Any\par 
from urllib.parse import urlparse, urljoin\par 
\par 
import requests\par 
\par 
logger = logging.getLogger("red_elisar.web_recon")\par 
\par 
\par 
_SECURITY_HEADERS: dict[str, str] = \{\par 
    "Content-Security-Policy": "Mitigates XSS by restricting allowed content sources",\par 
    "Strict-Transport-Security": "Forces HTTPS to reduce MITM risk",\par 
    "X-Frame-Options": "Mitigates clickjacking",\par 
    "X-Content-Type-Options": "Prevents MIME sniffing",\par 
    "Referrer-Policy": "Limits referrer leakage",\par 
    "Permissions-Policy": "Restricts browser features",\par 
\}\par 
\par 
_LEAKY_HEADERS = ["Server", "X-Powered-By", "X-App-Version"]\par 
\par 
_DEFAULT_SENSITIVE_PATHS = [\par 
    "/.env",\par 
    "/backup",\par 
    "/.git/config",\par 
    "/admin",\par 
    "/api/users",\par 
    "/phpinfo.php",\par 
    "/server-status",\par 
    "/.htaccess",\par 
    "/robots.txt",\par 
    "/debug",\par 
]\par 
\par 
\par 
@dataclass\par 
class WebReconAgent:\par 
    """Collects passive recon signals from a target web app."""\par 
\par 
    target_url: str\par 
    timeout_s: float = 8.0\par 
\par 
    def run(self) -> dict[str, Any]:\par 
        parsed = urlparse(self.target_url)\par 
        domain = parsed.netloc or parsed.path\par 
        base_url = self.target_url.rstrip("/")\par 
\par 
        out: dict[str, Any] = \{\par 
            "target_url": base_url,\par 
            "domain": domain,\par 
            "reachable": False,\par 
            "status_code": None,\par 
            "tech_stack": \{"server": "Unknown", "language": "Unknown", "versions": \{\}\},\par 
            "ssl": \{"enabled": parsed.scheme.lower() == "https", "valid": None, "error": None\},\par 
            "missing_security_headers": \{\},\par 
            "leaked_info_headers": \{\},\par 
            "exposed_paths": [],\par 
            "cors": \{"origin": None, "issues": []\},\par 
            "redirects": \{"open_redirect_likely": False, "details": []\},\par 
            "error": None,\par 
        \}\par 
\par 
        try:\par 
            resp = requests.get(base_url, timeout=self.timeout_s, allow_redirects=True)\par 
            out["reachable"] = True\par 
            out["status_code"] = resp.status_code\par 
\par 
            server = resp.headers.get("Server")\par 
            powered = resp.headers.get("X-Powered-By")\par 
            out["tech_stack"]["server"] = server or "Unknown"\par 
\par 
            language = "Unknown"\par 
            if powered:\par 
                language = powered\par 
            elif server and "werkzeug" in server.lower():\par 
                language = "Python/Flask"\par 
            out["tech_stack"]["language"] = language\par 
\par 
            versions: dict[str, str] = \{\}\par 
            if server:\par 
                versions["server"] = server\par 
            if powered:\par 
                versions["x_powered_by"] = powered\par 
            out["tech_stack"]["versions"] = versions\par 
\par 
            for header, desc in _SECURITY_HEADERS.items():\par 
                if header not in resp.headers:\par 
                    out["missing_security_headers"][header] = desc\par 
\par 
            for header in _LEAKY_HEADERS:\par 
                if header in resp.headers and str(resp.headers.get(header, "")).strip():\par 
                    out["leaked_info_headers"][header] = str(resp.headers.get(header, "")).strip()\par 
\par 
            # CORS quick check\par 
            acao = resp.headers.get("Access-Control-Allow-Origin")\par 
            if acao:\par 
                out["cors"]["origin"] = acao\par 
                if acao.strip() == "*":\par 
                    out["cors"]["issues"].append("Access-Control-Allow-Origin is wildcard (*)")\par 
\par 
            # Probe a small set of sensitive paths (passive-ish GET)\par 
            out["exposed_paths"] = self._probe_paths(base_url)\par 
\par 
        except Exception as e:  # noqa: BLE001\par 
            out["error"] = str(e)\par 
            logger.warning("Recon failed for %s: %s", base_url, e)\par 
\par 
        # SSL validity (best-effort)\par 
        if out["ssl"]["enabled"]:\par 
            try:\par 
                requests.get(base_url, timeout=self.timeout_s, verify=True)\par 
                out["ssl"]["valid"] = True\par 
            except Exception as e:  # noqa: BLE001\par 
                out["ssl"]["valid"] = False\par 
                out["ssl"]["error"] = str(e)\par 
        else:\par 
            out["ssl"]["valid"] = False\par 
\par 
        return out\par 
\par 
    def _probe_paths(self, base_url: str) -> list[dict[str, Any]]:\par 
        results: list[dict[str, Any]] = []\par 
        for path in _DEFAULT_SENSITIVE_PATHS:\par 
            url = urljoin(base_url + "/", path.lstrip("/"))\par 
            try:\par 
                resp = requests.get(url, timeout=self.timeout_s, allow_redirects=False)\par 
                preview = ""\par 
                try:\par 
                    preview = (resp.text or "")[:200]\par 
                except Exception:\par 
                    preview = ""\par 
\par 
                # record only interesting statuses to keep output small\par 
                if resp.status_code < 400:\par 
                    results.append(\par 
                        \{\par 
                            "path": path,\par 
                            "status_code": resp.status_code,\par 
                            "size_bytes": len(resp.content or b""),\par 
                            "content_preview": preview,\par 
                        \}\par 
                    )\par 
            except Exception:\par 
                continue\par 
        return results\par 
\par 
\par 
if __name__ == "__main__":\par 
    import argparse\par 
    import json\par 
\par 
    logging.basicConfig(level=logging.INFO, format="%(levelname)s | %(message)s")\par 
\par 
    ap = argparse.ArgumentParser(description="Passive web reconnaissance (Red ELISAR)")\par 
    ap.add_argument("url", help="Target URL, e.g. http://127.0.0.1:5000")\par 
    ap.add_argument("--timeout", type=float, default=8.0, help="HTTP timeout in seconds")\par 
    args = ap.parse_args()\par 
\par 
    data = WebReconAgent(args.url, timeout_s=args.timeout).run()\par 
    print(json.dumps(data, indent=2, ensure_ascii=False, default=str))\par 
