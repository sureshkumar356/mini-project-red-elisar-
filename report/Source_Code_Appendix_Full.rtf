def groq_chat_json(\par 
    messages: list[dict],\par 
    model: str = None,\par 
    max_tokens: int = None,\par 
    temperature: float = None,\par 
    top_p: float = None,\par 
    api_key: str = None,\par 
    timeout: int = None,\par 
    max_retries: int = None,\par 
) -> LLMResult:\par 
    """\par 
    Call the Groq OpenAI-compatible chat endpoint.\par 
\par 
    API key resolution order:\par 
        1. api_key argument\par 
        2. LLAMA3_API_KEY env var  (via config.LLAMA3_API_KEY)\par 
        3. GROQ_API_KEY env var    (legacy fallback)\par 
\par 
    Returns an LLMResult with .content, .usage, .latency_s.\par 
    """\par 
    _model       = model       or config.GROQ_MODEL\par 
    _max_tokens  = max_tokens  if max_tokens  is not None else config.LLM_MAX_TOKENS\par 
    _temperature = temperature if temperature is not None else config.LLM_TEMPERATURE\par 
    _top_p       = top_p       if top_p       is not None else config.LLM_TOP_P\par 
    _timeout     = timeout     if timeout     is not None else config.LLM_TIMEOUT\par 
    _max_retries = max_retries if max_retries is not None else config.LLM_MAX_RETRIES\par 
\par 
    _api_key = (\par 
        api_key\par 
        or config.LLAMA3_API_KEY\par 
        or os.getenv("GROQ_API_KEY", "")\par 
    ).strip()\par 
    if not _api_key:\par 
        raise RuntimeError(\par 
            "Groq API key not set. "\par 
            "Run: $env:LLAMA3_API_KEY = 'gsk_...'"\par 
        )\par 
\par 
    headers = \{\par 
        "Authorization": f"Bearer \{_api_key\}",\par 
        "Content-Type":  "application/json",\par 
    \}\par 
    payload = \{\par 
        "model":       _model,\par 
        "messages":    messages,\par 
        "max_tokens":  _max_tokens,\par 
        "temperature": _temperature,\par 
        "top_p":       _top_p,\par 
    \}\par 
\par 
    logger.debug("Groq request: model=%s tokens=%s temp=%s", _model, _max_tokens, _temperature)\par 
    t0 = time.perf_counter()\par 
\par 
    resp = _post_with_retry(\par 
        url           = GROQ_API_BASE,\par 
        headers       = headers,\par 
        payload       = payload,\par 
        max_retries   = _max_retries,\par 
        base_backoff  = config.LLM_RETRY_BASE_BACKOFF_S,\par 
        max_backoff   = config.LLM_RETRY_MAX_BACKOFF_S,\par 
        jitter        = config.LLM_RETRY_JITTER_S,\par 
        max_429_wait  = config.LLM_MAX_429_WAIT_S,\par 
        timeout       = _timeout,\par 
    )\par 
    latency = time.perf_counter() - t0\par 
\par 
    if not resp.ok:\par 
        raise RuntimeError(\par 
            f"Groq API error \{resp.status_code\}: \{resp.text[:400]\}"\par 
        )\par 
\par 
    data    = resp.json()\par 
    content = data["choices"][0]["message"]["content"]\par 
    usage   = data.get("usage") or \{\}\par 
\par 
    logger.debug(\par 
        "Groq response: %d chars in %.2fs | tokens=%s",\par 
        len(content), latency, usage.get("total_tokens"),\par 
    )\par 
    return LLMResult(content=content, usage=usage, latency_s=latency, model=_model, raw=data)\par 
\par 
