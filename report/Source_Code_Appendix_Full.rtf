    def _verify_reachable(self) -> bool:\par 
        try:\par 
            resp = self.session.get(self.target, timeout=self.timeout)\par 
            logger.info(f"Target reachable ├втВмтАЭ HTTP \{resp.status_code\}")\par 
            return True\par 
        except Exception as e:\par 
            logger.error(f"Target unreachable: \{e\}")\par 
            return False\par 
\par 
    # ├втАЭтВм├втАЭтВм 1. Security Header Audit ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм\par 
    def _check_security_headers(self):\par 
        try:\par 
            resp = self.session.get(self.target, timeout=self.timeout)\par 
            headers = resp.headers\par 
            for header, (severity, cwe, mitre) in REQUIRED_HEADERS.items():\par 
                if header not in headers:\par 
                    self._add(\par 
                        vuln_type  = "Missing Security Header",\par 
                        detail     = f"HTTP response is missing the '\{header\}' header",\par 
                        severity   = severity,\par 
                        cwe        = cwe,\par 
                        mitre      = mitre,\par 
                        evidence   = f"Header '\{header\}' absent in live response from \{self.target\}",\par 
                        check      = "_check_security_headers",\par 
                        confirmed  = True,\par 
                        recommendation = (\par 
                            f"Add '\{header\}' to all HTTP responses. "\par 
                            f"Example config depends on your web server / framework."\par 
                        ),\par 
                    )\par 
        except Exception as e:\par 
            logger.debug(f"Header check error: \{e\}")\par 
\par 
    # ├втАЭтВм├втАЭтВм 2. Server Banner Leakage ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм\par 
    def _check_server_banners(self):\par 
        try:\par 
            resp = self.session.get(self.target, timeout=self.timeout)\par 
            h = resp.headers\par 
            leaky = \{\par 
                "Server":       h.get("Server"),\par 
                "X-Powered-By": h.get("X-Powered-By"),\par 
                "X-App-Version":h.get("X-App-Version"),\par 
                "X-AspNet-Version": h.get("X-AspNet-Version"),\par 
            \}\par 
            for hname, hval in leaky.items():\par 
                if hval:\par 
                    self._add(\par 
                        vuln_type  = "Information Disclosure (Banner)",\par 
                        detail     = f"Header '\{hname\}' reveals technology: '\{hval\}'",\par 
                        severity   = "MEDIUM",\par 
                        cwe        = "CWE-200",\par 
                        mitre      = "T1592",\par 
                        evidence   = f"Live response header ├втАатАЩ \{hname\}: \{hval\}",\par 
                        check      = "_check_server_banners",\par 
                        confirmed  = True,\par 
                        recommendation = f"Remove or generalize the '\{hname\}' response header.",\par 
                    )\par 
        except Exception as e:\par 
            logger.debug(f"Banner check error: \{e\}")\par 
\par 
    # ├втАЭтВм├втАЭтВм 3. CORS Misconfiguration ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм\par 
    def _check_cors(self):\par 
        try:\par 
            resp = self.session.get(\par 
                self.target,\par 
                headers=\{"Origin": "https://evil-attacker.example.com"\},\par 
                timeout=self.timeout,\par 
            )\par 
            acao = resp.headers.get("Access-Control-Allow-Origin", "")\par 
            acac = resp.headers.get("Access-Control-Allow-Credentials", "")\par 
\par 
            if acao == "*":\par 
                self._add(\par 
                    vuln_type  = "CORS Wildcard Misconfiguration",\par 
                    detail     = "Server allows cross-origin requests from ANY domain (*)",\par 
                    severity   = "HIGH",\par 
                    cwe        = "CWE-942",\par 
                    mitre      = "T1557",\par 
                    evidence   = f"Live response: Access-Control-Allow-Origin: \{acao\}",\par 
                    check      = "_check_cors",\par 
                    confirmed  = True,\par 
                    recommendation = (\par 
                        "Replace '*' with specific trusted origins. "\par 
                        "Never combine wildcard CORS with cookies/credentials."\par 
                    ),\par 
                )\par 
            elif "evil-attacker.example.com" in acao:\par 
                severity = "CRITICAL" if acac.lower() == "true" else "HIGH"\par 
                self._add(\par 
                    vuln_type  = "CORS Origin Reflection",\par 
                    detail     = "Server reflects attacker Origin back ├втВмтАЭ CORS misconfigured",\par 
                    severity   = severity,\par 
                    cwe        = "CWE-942",\par 
                    mitre      = "T1557",\par 
                    evidence   = (f"Sent Origin: evil-attacker.example.com ├втАатАЩ "\par 
                                  f"Got ACAO: \{acao\}, ACAC: \{acac\}"),\par 
                    check      = "_check_cors",\par 
                    confirmed  = True,\par 
                    recommendation = (\par 
                        "Maintain and validate a strict allowlist of trusted origins. "\par 
                        "Reject requests from unknown origins."\par 
                    ),\par 
                )\par 
        except Exception as e:\par 
            logger.debug(f"CORS check error: \{e\}")\par 
\par 
    # ├втАЭтВм├втАЭтВм 4. Sensitive File Disclosure ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм\par 
    def _check_sensitive_paths(self):\par 
        for path, severity, cwe, mitre, desc in SENSITIVE_PATHS:\par 
            try:\par 
                url  = f"\{self.target\}\{path\}"\par 
                resp = self.session.get(url, timeout=self.timeout,\par 
                                        allow_redirects=False)\par 
                if resp.status_code == 200:\par 
                    preview = resp.text[:300].strip().replace("\\n", " ")\par 
                    self._add(\par 
                        vuln_type  = "Sensitive File / Path Disclosure",\par 
                        detail     = f"Path '\{path\}' returned HTTP 200 ├втВмтАЭ \{desc\}",\par 
                        severity   = severity,\par 
                        cwe        = cwe,\par 
                        mitre      = mitre,\par 
                        evidence   = f"GET \{url\} ├втАатАЩ 200 OK | Preview: \{preview[:120]\}...",\par 
                        check      = "_check_sensitive_paths",\par 
                        confirmed  = True,\par 
                        recommendation = (\par 
                            f"Remove or protect '\{path\}'. Ensure sensitive files are "\par 
                            f"outside the web root and access-controlled."\par 
                        ),\par 
                    )\par 
                elif resp.status_code in (301, 302):\par 
                    loc = resp.headers.get("Location", "")\par 
                    self._add(\par 
                        vuln_type  = "Sensitive Path Redirect",\par 
                        detail     = (f"Path '\{path\}' redirects (may be accessible): "\par 
                                      f"├втАатАЩ \{loc\}"),\par 
                        severity   = "LOW",\par 
                        cwe        = cwe,\par 
                        mitre      = mitre,\par 
                        evidence   = f"GET \{url\} ├втАатАЩ \{resp.status_code\} ├втАатАЩ Location: \{loc\}",\par 
                        check      = "_check_sensitive_paths",\par 
                        confirmed  = True,\par 
                        recommendation = f"Verify whether '\{path\}' is accessible after redirect.",\par 
                    )\par 
            except Exception:\par 
                continue\par 
\par 
    # ├втАЭтВм├втАЭтВм 5. SQL Injection ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм\par 
    def _check_sql_injection(self):\par 
        """\par 
        Probes GET parameters on known/discovered endpoints with SQLi payloads.\par 
        Detects: error-based, UNION-based, and data-exposure confirmation.\par 
        """\par 
        # Endpoints with known injectable parameters to probe\par 
        probe_targets = [\par 
            (f"\{self.target\}/search",  "q"),\par 
            (f"\{self.target\}/login",   None),  # POST ├втВмтАЭ handled separately\par 
        ]\par 
\par 
        sql_error_patterns = [\par 
            r"sqlite",\par 
            r"syntax error",\par 
            r"unrecognized token",\par 
            r"sql",\par 
            r"mysql",\par 
            r"postgre",\par 
            r"ORA-",\par 
            r"microsoft.*odbc",\par 
            r"query was:",\par 
            r"database error",\par 
        ]\par 
\par 
        for endpoint, param in probe_targets:\par 
            if param is None:\par 
                continue\par 
            for payload, payload_desc in SQLI_PAYLOADS:\par 
                try:\par 
                    params = \{param: payload\}\par 
                    resp   = self.session.get(endpoint, params=params,\par 
                                              timeout=self.timeout)\par 
                    body   = resp.text.lower()\par 
\par 
                    # Error-based detection\par 
                    for pattern in sql_error_patterns:\par 
                        if re.search(pattern, body, re.IGNORECASE):\par 
                            self._add(\par 
                                vuln_type  = "SQL Injection (Error-Based)",\par 
                                detail     = (\par 
                                    f"SQLi payload '\{payload\}' on \{endpoint\}?\{param\}=... "\par 
                                    f"triggered SQL error pattern '\{pattern\}' in live response"\par 
                                ),\par 
                                severity   = "CRITICAL",\par 
                                cwe        = "CWE-89",\par 
