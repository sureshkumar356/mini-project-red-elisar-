class MITREParser:\par 
\par 
    def __init__(self, stix_path: Optional[Path] = None):\par 
        self.stix_path = stix_path or config.MITRE_STIX_PATH\par 
        self.techniques: list[AttackTechnique] = []\par 
        self._raw_bundle = None\par 
\par 
    def parse(self) -> list[AttackTechnique]:\par 
        logger.info(f"Loading STIX bundle from: \{self.stix_path\}")\par 
\par 
        if not self.stix_path.exists():\par 
            raise FileNotFoundError(\par 
                f"MITRE ATT&CK STIX file not found: \{self.stix_path\}\\n"\par 
                f"Download from: https://github.com/mitre-attack/attack-stix-data/blob/master/enterprise-attack/enterprise-attack.json"\par 
            )\par 
\par 
        # Load JSON bundle\par 
        with open(self.stix_path, 'r', encoding='utf-8') as f:\par 
            self._raw_bundle = json.load(f)\par 
\par 
        self._validate_bundle()\par 
\par 
        # Extract attack-pattern objects\par 
        attack_patterns = [\par 
            obj for obj in self._raw_bundle.get("objects", [])\par 
            if obj.get("type") == "attack-pattern"\par 
        ]\par 
        logger.info(f"Found \{len(attack_patterns)\} attack-pattern objects")\par 
\par 
        valid_count = 0\par 
        skipped_deprecated = 0\par 
        skipped_revoked = 0\par 
\par 
        for obj in attack_patterns:\par 
            if obj.get("x_mitre_deprecated", False):\par 
                skipped_deprecated += 1\par 
                continue\par 
            if obj.get("revoked", False):\par 
                skipped_revoked += 1\par 
                continue\par 
            technique = self._extract_technique(obj)\par 
            if technique:\par 
                self.techniques.append(technique)\par 
                valid_count += 1\par 
\par 
        logger.info(\par 
            f"Extracted \{valid_count\} valid techniques "\par 
            f"(skipped \{skipped_deprecated\} deprecated, \{skipped_revoked\} revoked)"\par 
        )\par 
\par 
        # Free raw bundle memory\par 
        self._raw_bundle = None\par 
        if config.AGGRESSIVE_GC:\par 
            gc.collect()\par 
\par 
        return self.techniques\par 
\par 
    def _validate_bundle(self):\par 
        bundle_type = self._raw_bundle.get("type", "")\par 
        if bundle_type != "bundle":\par 
            raise ValueError(f"Expected STIX bundle type 'bundle', got '\{bundle_type\}'")\par 
        spec_version = self._raw_bundle.get("spec_version", "")\par 
        if spec_version and not spec_version.startswith("2."):\par 
            logger.warning(f"Expected STIX 2.x spec_version, got '\{spec_version\}'. Attempting anyway.")\par 
        objects = self._raw_bundle.get("objects", [])\par 
        if not objects:\par 
            raise ValueError("STIX bundle contains no objects")\par 
        logger.info(\par 
            f"STIX bundle validated: \{len(objects)\} total objects, "\par 
            f"ID: \{self._raw_bundle.get('id', 'unknown')\}"\par 
        )\par 
\par 
    def _extract_technique(self, obj: dict) -> Optional[AttackTechnique]:\par 
        try:\par 
            technique_id = ""\par 
            url = ""\par 
            # Extract ID from external references\par 
            for ref in obj.get("external_references", []):\par 
                if ref.get("source_name") == "mitre-attack":\par 
                    technique_id = ref.get("external_id", "")\par 
                    url = ref.get("url", "")\par 
                    break\par 
\par 
            if not technique_id:\par 
                logger.warning(f"No technique ID found for object: \{obj.get('id')\}")\par 
                return None\par 
\par 
            name = obj.get("name", "Unknown Technique")\par 
            description = clean_description(obj.get("description", ""))\par 
\par 
            # Extract tactics from kill chain phases\par 
            tactics = []\par 
            for phase in obj.get("kill_chain_phases", []):\par 
                if phase.get("kill_chain_name") == "mitre-attack":\par 
                    tactics.append(phase.get("phase_name", ""))\par 
\par 
            platforms = obj.get("x_mitre_platforms", [])\par 
            data_sources = obj.get("x_mitre_data_sources", [])\par 
            is_subtechnique = obj.get("x_mitre_is_subtechnique", False)\par 
            stix_id = obj.get("id", "")\par 
\par 
            return AttackTechnique(\par 
                technique_id=technique_id,\par 
                name=name,\par 
                description=description,\par 
                tactics=tactics,\par 
                platforms=platforms,\par 
                data_sources=data_sources,\par 
                is_subtechnique=is_subtechnique,\par 
                stix_id=stix_id,\par 
                url=url,\par 
            )\par 
        except Exception as e:\par 
            logger.error(f"Failed to extract technique from \{obj.get('id')\}: \{e\}")\par 
            return None\par 
\par 
    def get_tactics_summary(self) -> dict[str, int]:\par 
        tactic_counts: dict[str, int] = \{\}\par 
        for tech in self.techniques:\par 
            for tactic in tech.tactics:\par 
                tactic_counts[tactic] = tactic_counts.get(tactic, 0) + 1\par 
        return dict(sorted(tactic_counts.items(), key=lambda x: x[1], reverse=True))\par 
\par 
    def export_json(self, output_path: Optional[Path] = None) -> Path:\par 
        if output_path is None:\par 
            config.ensure_directories()\par 
            output_path = config.OUTPUT_DIR / "techniques.json"\par 
        data = \{\par 
            "total_techniques": len(self.techniques),\par 
            "tactics_summary": self.get_tactics_summary(),\par 
            "techniques": [t.to_dict() for t in self.techniques],\par 
        \}\par 
        with open(output_path, 'w', encoding='utf-8') as f:\par 
            json.dump(data, f, indent=2, ensure_ascii=False)\par 
        logger.info(f"Exported \{len(self.techniques)\} techniques to \{output_path\}")\par 
        return output_path\par 
