def _flow_rank(tactic: str) -> int:\par 
    t = str(tactic or "").strip().lower()\par 
    if t in ATTACK_FLOW_TACTICS:\par 
        return ATTACK_FLOW_TACTICS.index(t)\par 
    return 10_000\par 
\par 
