\par 
        # 2) Then add tactic coverage (from key tactics) using remaining candidates.\par 
        for key_tactic in getattr(config, "DIVERSITY_KEY_TACTICS", []):\par 
            kt = self._normalize_tactic(key_tactic)\par 
            if kt in covered_tactics:\par 
                continue\par 
            for t in deduped[top_n_similar:]:\par 
                tid = self._clean_ws(t.get("technique_id", ""))\par 
                if not tid or tid in selected_ids:\par 
                    continue\par 
                tt = _norm_tactics(t)\par 
                if kt in tt:\par 
                    selected.append(t)\par 
                    selected_ids.add(tid)\par 
                    covered_tactics |= tt\par 
                    break\par 
            if len(selected) >= desired_count:\par 
                return selected\par 
\par 
        # 3) Fill remaining slots by relevance.\par 
        for t in deduped:\par 
            if len(selected) >= desired_count:\par 
                break\par 
            tid = self._clean_ws(t.get("technique_id", ""))\par 
            if not tid or tid in selected_ids:\par 
                continue\par 
            selected.append(t)\par 
            selected_ids.add(tid)\par 
\par 
        return selected[:desired_count]\par 
\par 
    @staticmethod\par 
    def _tokenize(text: str) -> set[str]:\par 
        tokens = re.findall(r"[a-zA-Z0-9_-]\{2,\}", (text or "").lower())\par 
        stop = \{\par 
            "the",\par 
            "and",\par 
            "for",\par 
            "with",\par 
            "from",\par 
            "that",\par 
            "this",\par 
            "into",\par 
            "over",\par 
            "via",\par 
            "using",\par 
            "uses",\par 
            "used",\par 
            "attack",\par 
            "attacker",\par 
            "malware",\par 
        \}\par 
        return \{t for t in tokens if t not in stop\}\par 
\par 
    def _rerank_optional(self, query: str, techniques: list[dict]) -> list[dict]:\par 
        if not bool(getattr(config, "RAG_ENABLE_RERANK", False)):\par 
            return techniques\par 
\par 
        q = self._tokenize(query)\par 
        if not q:\par 
            return techniques\par 
\par 
        weight = float(getattr(config, "RAG_RERANK_WEIGHT", 0.25))\par 
        rescored = []\par 
        for t in techniques:\par 
            text = f"\{t.get('name','')\} \{t.get('description_preview','')\} \{t.get('document','')\}"\par 
            tt = self._tokenize(text)\par 
            overlap = len(q & tt) / max(1, len(q))\par 
            base = float(t.get("relevance_score", 0.0) or 0.0)\par 
            combined = (1.0 - weight) * base + weight * overlap\par 
            t2 = dict(t)\par 
            t2["_rerank_overlap"] = round(overlap, 4)\par 
            t2["_combined_score"] = round(combined, 4)\par 
            rescored.append(t2)\par 
\par 
        rescored.sort(key=lambda x: float(x.get("_combined_score", 0.0) or 0.0), reverse=True)\par 
        return rescored\par 
\par 
    def build_prompt(\par 
        self,\par 
        scenario: str,\par 
        target_environment: str,\par 
        retrieved_techniques: list[dict],\par 
        chain_length: int = None,\par 
    ) -> tuple[str, str]:\par 
        if chain_length is None:\par 
            chain_length = config.DEFAULT_CHAIN_LENGTH\par 
\par 
        # Enforce a small context budget (prompt stays small), but ALWAYS include\par 
        # up to 12 unique techniques in the prompt context.\par 
        max_ctx = int(getattr(config, "RAG_MAX_CONTEXT_TECHNIQUES", 12))\par 
        desired = min(max_ctx, 12)\par 
        retrieved_techniques = self._select_context_techniques(\par 
            scenario=scenario,\par 
            techniques=retrieved_techniques,\par 
            desired_count=desired,\par 
            chain_length=chain_length,\par 
        )\par 
\par 
        context = "\\n".join(f"- \{self._summarize_technique_for_prompt(t)\}" for t in retrieved_techniques)\par 
\par 
        system = SYSTEM_PROMPT\par 
        if int(chain_length or 1) <= 1:\par 
            user = USER_PROMPT_TEMPLATE_SINGLE.format(\par 
                scenario=scenario,\par 
                context=context,\par 
            )\par 
        else:\par 
            max_steps = min(chain_length, 14)\par 
            min_steps = max(8, max_steps - 2)\par 
            user = USER_PROMPT_TEMPLATE.format(\par 
                scenario=scenario,\par 
                context=context,\par 
                min_steps=min_steps,\par 
                max_steps=max_steps,\par 
            )\par 
\par 
        total_chars = len(system) + len(user)\par 
        logger.info(f"Prompt constructed: \{total_chars\} chars, \{len(retrieved_techniques)\} techniques in context")\par 
        return system, user\par 
