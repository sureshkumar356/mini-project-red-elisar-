def _attach_novelty(result_payload: dict, chain_steps: list, vulnerabilities: list | None = None, retrieval_results: list | None = None):\par 
    """Attach explainability and what-if simulation artifacts to API result payload."""\par 
    attributions = _build_step_attribution(chain_steps=chain_steps, retrieval_results=retrieval_results)\par 
    graph = _build_causal_attack_graph(chain_steps=chain_steps, vulnerabilities=vulnerabilities)\par 
    simulation = _simulate_defense_what_if(graph)\par 
    result_payload["attack_chain_attribution"] = attributions\par 
    result_payload["attack_graph"] = graph\par 
    result_payload["what_if_simulation"] = simulation\par 
