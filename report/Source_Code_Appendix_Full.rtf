    """VULNERABILITY 8: SQL Injection ├втВмтАЭ user input goes directly into SQL query."""\par 
    query   = request.args.get("q", "")\par 
    results = []\par 
    error   = None\par 
\par 
    if query:\par 
        try:\par 
            conn = sqlite3.connect(DB_PATH)\par 
            c    = conn.cursor()\par 
            # VULNERABLE: Direct string interpolation ├втВмтАЭ DO NOT DO THIS IN REAL CODE\par 
            sql = f"SELECT * FROM products WHERE name LIKE '%\{query\}%' OR description LIKE '%\{query\}%'"\par 
            c.execute(sql)\par 
            results = c.fetchall()\par 
            conn.close()\par 
        except Exception as e:\par 
            # VULNERABILITY 13: Expose error details including SQL query\par 
            error = f"Database error: \{str(e)\} | Query was: \{sql\}"\par 
\par 
    content = f"""\par 
