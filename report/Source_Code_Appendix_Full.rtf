    \}\par 
    probe_fn  = probers.get(attack_type, _probe_generic)\par 
    timeout_s = float(timeout) if timeout is not None else DEFAULT_TIMEOUT_S\par 
    result    = probe_fn(target_url, timeout_s)\par 
