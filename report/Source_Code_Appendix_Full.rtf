    def query_diverse(self, query_text: str, top_k: int = None) -> list[dict]:\par 
        if top_k is None:\par 
            top_k = config.RAG_TOP_K\par 
\par 
        # Wide retrieval for diversity\par 
        wide_results = self.query(query_text, top_k=config.DIVERSITY_TOP_K_WIDE)\par 
        if len(wide_results) <= top_k:\par 
            return wide_results\par 
\par 
        # Group techniques by tactic\par 
        tactic_groups: dict[str, list[dict]] = \{\}\par 
        for r in wide_results:\par 
            tactics = r.get("tactics", [])\par 
            if isinstance(tactics, str):\par 
                tactics = [t.strip() for t in tactics.split(",")]\par 
            for tactic in tactics:\par 
                tactic_lower = tactic.lower().strip()\par 
                if tactic_lower not in tactic_groups:\par 
                    tactic_groups[tactic_lower] = []\par 
                tactic_groups[tactic_lower].append(r)\par 
\par 
        # Pick best from each key kill chain tactic\par 
        selected = []\par 
        selected_ids = set()\par 
        for key_tactic in config.DIVERSITY_KEY_TACTICS:\par 
            if key_tactic in tactic_groups:\par 
                for candidate in tactic_groups[key_tactic]:\par 
                    if candidate["technique_id"] not in selected_ids:\par 
                        selected.append(candidate)\par 
                        selected_ids.add(candidate["technique_id"])\par 
                        break\par 
            if len(selected) >= top_k:\par 
                break\par 
\par 
        # Fill remaining slots with highest-scoring remaining techniques\par 
        for r in wide_results:\par 
            if len(selected) >= top_k:\par 
                break\par 
            if r["technique_id"] not in selected_ids:\par 
                selected.append(r)\par 
                selected_ids.add(r["technique_id"])\par 
\par 
        logger.info(\par 
            f"Diverse retrieval: \{len(selected)\} techniques from "\par 
            f"\{len(set(t for s in selected for t in (s.get('tactics', []) if isinstance(s.get('tactics'), list) else [s.get('tactics', '')])))\} tactics"\par 
        )\par 
        return selected[:top_k]\par 
