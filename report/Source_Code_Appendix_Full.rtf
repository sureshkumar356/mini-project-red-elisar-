    def _save_index(self):\par 
        config.ensure_directories()\par 
        self.index_dir.mkdir(parents=True, exist_ok=True)\par 
        # Save FAISS index\par 
        faiss.write_index(self._index, str(self._index_path))\par 
        # Save metadata sidecar\par 
        with open(self._metadata_path, "w", encoding="utf-8") as f:\par 
            json.dump(self._metadata, f, ensure_ascii=False)\par 
        # Save document texts\par 
        with open(self._chunks_path, "w", encoding="utf-8") as f:\par 
            json.dump(self._documents, f, ensure_ascii=False)\par 
        logger.info(f"Index persisted: \{self._index.ntotal\} vectors ├втАатАЩ \{self._index_path\}")\par 
\par 
    def _load_index(self):\par 
        logger.info(f"Loading FAISS index from \{self._index_path\}")\par 
        start = time.perf_counter()\par 
        self._index = faiss.read_index(str(self._index_path))\par 
        # Restore efSearch (not persisted by FAISS)\par 
        self._index.hnsw.efSearch = config.FAISS_HNSW_EF_SEARCH\par 
        with open(self._metadata_path, "r", encoding="utf-8") as f:\par 
            self._metadata = json.load(f)\par 
        if self._chunks_path.exists():\par 
            with open(self._chunks_path, "r", encoding="utf-8") as f:\par 
                self._documents = json.load(f)\par 
        else:\par 
            self._documents = [""] * len(self._metadata)\par 
        logger.info(f"FAISS index loaded: \{self._index.ntotal\} vectors in \{time.perf_counter() - start:.2f\}s")\par 
\par 
    def get_collection_stats(self) -> dict:\par 
        return \{\par 
            "total_documents": self.index.ntotal,\par 
            "total_metadata_entries": len(self._metadata),\par 
            "embedding_model": self.model_name,\par 
            "embedding_dimension": self.dimension,\par 
