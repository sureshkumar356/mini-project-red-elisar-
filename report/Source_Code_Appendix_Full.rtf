def _build_causal_attack_graph(chain_steps: list, vulnerabilities: list | None = None) -> dict:\par 
    """Convert linear chain into a lightweight causal graph with branch edges."""\par 
    vulnerabilities = vulnerabilities or []\par 
    nodes = []\par 
    edges = []\par 
    entry_nodes = []\par 
    objective_nodes = []\par 
\par 
    for i, step in enumerate(chain_steps, start=1):\par 
        sid = f"tech-\{i\}"\par 
        tactic = str(step.get("tactic") or step.get("phase") or "unknown")\par 
        prob = max(0.15, 0.72 - (0.03 * (i - 1)))\par 
        cost = 2 + i\par 
        nodes.append(\par 
            \{\par 
                "id": sid,\par 
                "type": "technique",\par 
                "label": str(step.get("technique_name") or step.get("name") or step.get("technique_id") or f"Step \{i\}"),\par 
                "technique_id": str(step.get("technique_id") or ""),\par 
                "tactic": tactic,\par 
                "base_probability": round(prob, 3),\par 
                "base_cost": cost,\par 
                "detectability": round(min(0.9, 0.25 + (0.05 * i)), 3),\par 
            \}\par 
        )\par 
\par 
        if i == 1:\par 
            entry_nodes.append(sid)\par 
        if i == len(chain_steps):\par 
            objective_nodes.append(sid)\par 
        if i > 1:\par 
            edges.append(\par 
                \{\par 
                    "source": f"tech-\{i-1\}",\par 
                    "target": sid,\par 
                    "relation": "enables",\par 
                    "weight": 1.0,\par 
                    "explanation": "Prior technique establishes conditions for next stage.",\par 
                \}\par 
            )\par 
\par 
        if i > 2 and (i % 2 == 0):\par 
            edges.append(\par 
                \{\par 
                    "source": f"tech-\{i-2\}",\par 
                    "target": sid,\par 
                    "relation": "alternative_path",\par 
                    "weight": 0.55,\par 
                    "explanation": "Alternative attacker path inferred from tactic-level continuity.",\par 
                \}\par 
            )\par 
\par 
    for vi, vuln in enumerate(vulnerabilities[:6], start=1):\par 
        vid = f"vuln-\{vi\}"\par 
        vlabel = str(vuln.get("type") or "Vulnerability")\par 
        sev = str(vuln.get("severity") or "MEDIUM").upper()\par 
        sev_weight = \{"CRITICAL": 0.85, "HIGH": 0.75, "MEDIUM": 0.6, "LOW": 0.45\}.get(sev, 0.5)\par 
        nodes.append(\par 
            \{\par 
                "id": vid,\par 
                "type": "condition",\par 
                "label": vlabel,\par 
                "tactic": "initial-access",\par 
                "base_probability": sev_weight,\par 
                "base_cost": 1,\par 
                "detectability": 0.35,\par 
            \}\par 
        )\par 
        if entry_nodes:\par 
            edges.append(\par 
                \{\par 
                    "source": vid,\par 
                    "target": entry_nodes[0],\par 
                    "relation": "requires",\par 
                    "weight": round(sev_weight, 2),\par 
                    "explanation": "Discovered weakness can enable initial attacker foothold.",\par 
                \}\par 
            )\par 
\par 
    return \{\par 
        "nodes": nodes,\par 
        "edges": edges,\par 
        "entry_nodes": entry_nodes,\par 
        "objective_nodes": objective_nodes,\par 
    \}\par 
\par 
