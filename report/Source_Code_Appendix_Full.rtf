def _write_scan_text_report(\par 
    target_url: str,\par 
    discovery: dict[str, Any],\par 
    vulnerabilities: list[dict[str, Any]],\par 
    mapped: list[dict[str, Any]],\par 
    mitre_db: MitreAttackDatabase | None,\par 
    rag_engine: RAGEngine | None,\par 
) -> Path:\par 
    config.ensure_directories()\par 
    ts = datetime.now(timezone.utc).strftime("%Y%m%d_%H%M%S")\par 
    scan_time = datetime.now(timezone.utc).strftime("%Y-%m-%d %H:%M")\par 
    out_path = config.OUTPUT_DIR / f"scan_report_\{ts\}.txt"\par 
\par 
    lines: list[str] = [\par 
        "===============================",\par 
        "RED AGENT SCAN REPORT",\par 
        "===============================",\par 
        "",\par 
        f"Target: \{target_url\}",\par 
        f"Scan Time: \{scan_time\}",\par 
        f"Discovered Routes: \{len(discovery.get('routes', []))\}",\par 
        f"Discovered Forms: \{len(discovery.get('forms', []))\}",\par 
        "",\par 
    ]\par 
\par 
    used_primary_ids: set[str] = set()\par 
    used_chain_ids: set[str] = set()\par 
\par 
    for i, vuln in enumerate(vulnerabilities, 1):\par 
        mapping = mapped[i - 1] if i - 1 < len(mapped) else \{\}\par 
        chain = _build_dynamic_chain_from_mapping(\par 
            vuln,\par 
            mapping,\par 
            mitre_db,\par 
            rag_engine=rag_engine,\par 
            top_k=25,\par 
            avoid_primary_ids=used_primary_ids,\par 
            avoid_chain_ids=used_chain_ids,\par 
        )\par 
        primary = next((s for s in chain if s.get("is_primary")), chain[0] if chain else \{\})\par 
        technique_id = str(primary.get("technique_id", "N/A"))\par 
        technique_name = str(primary.get("technique_name", "Unknown Technique"))\par 
        tactics = sorted(\{str(step.get("tactic", "unknown")) for step in chain\}) if chain else []\par 
        tools = _normalize_tools([tool for step in chain for tool in step.get("tools", [])], max_items=4)\par 
        if technique_id and technique_id != "N/A":\par 
            used_primary_ids.add(technique_id)\par 
        for step in chain:\par 
            sid = str(step.get("technique_id", "")).strip()\par 
            if sid:\par 
                used_chain_ids.add(sid)\par 
        affected_url = _infer_affected_url(vuln, target_url)\par 
        evidence_text = str(vuln.get("evidence", "N/A"))\par 
        recommendation = str(vuln.get("recommendation", ""))\par 
\par 
        lines.extend(\par 
            [\par 
                "--------------------------------",\par 
                f"[VULNERABILITY #\{i\}]",\par 
                f"Type: \{vuln.get('type', 'Unknown')\}",\par 
                f"Severity: \{vuln.get('severity', 'N/A')\}",\par 
                "",\par 
                "Affected URL:",\par 
                affected_url,\par 
                "",\par 
                "Evidence:",\par 
                f"- \{evidence_text\}",\par 
                "",\par 
                "--------------------------------",\par 
                "MITRE ATT&CK MAPPING",\par 
                f"Technique ID: \{technique_id\}",\par 
                f"Technique Name: \{technique_name\}",\par 
                f"Tactics: \{', '.join(tactics) if tactics else 'N/A'\}",\par 
                "Tools / Software:",\par 
            ]\par 
        )\par 
        for tool in tools:\par 
            lines.append(f"- \{tool.get('name', 'Unknown Tool')\}: \{tool.get('description', 'N/A')\}")\par 
        if not tools:\par 
            lines.append("- No tools found in MITRE dataset")\par 
        lines.extend(["", "--------------------------------", "ATTACK CHAIN:", ""])\par 
\par 
        for idx, step in enumerate(chain, 1):\par 
            lines.append(f"\{idx\}. \{str(step.get('tactic', 'unknown')).replace('-', ' ').title()\}:")\par 
            lines.append(\par 
                f"   Technique: \{step.get('technique_id', 'N/A')\} - \{step.get('technique_name', 'Unknown')\}"\par 
            )\par 
            step_tools = step.get("tools", [])\par 
            lines.append(\par 
                "   Tools: " + (", ".join(t.get("name", "Unknown Tool") for t in step_tools) if step_tools else "No tools found in MITRE dataset")\par 
            )\par 
            lines.append(f"   Description: \{step.get('description', 'N/A')\}")\par 
            lines.append("")\par 
\par 
        lines.extend(\par 
            [\par 
                "--------------------------------",\par 
                "RECOMMENDATION:",\par 
            ]\par 
        )\par 
        for rec in _split_recommendation_lines(recommendation):\par 
            lines.append(f"- \{rec\}")\par 
        lines.extend(["", "================================", ""])\par 
\par 
    out_path.write_text("\\n".join(lines), encoding="utf-8")\par 
    return out_path\par 
