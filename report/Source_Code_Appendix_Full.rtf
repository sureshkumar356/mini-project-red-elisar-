import json\par 
import logging\par 
import time\par 
import gc\par 
import numpy as np\par 
from pathlib import Path\par 
from typing import Optional\par 
\par 
import faiss\par 
from sentence_transformers import SentenceTransformer\par 
\par 
import config\par 
\par 
logger = logging.getLogger("red_elisar.faiss_store")\par 
\par 
\par 
class FAISSVectorStore:\par 
\par 
    def __init__(\par 
        self,\par 
        index_dir: Optional[Path] = None,\par 
        model_name: Optional[str] = None,\par 
    ):\par 
        self.index_dir = index_dir or config.FAISS_INDEX_DIR\par 
        self.model_name = model_name or config.EMBEDDING_MODEL_NAME\par 
        self.dimension = config.EMBEDDING_DIMENSION\par 
\par 
        # Persistence file paths\par 
        self._index_path    = self.index_dir / "hnsw_index.faiss"\par 
        self._metadata_path = self.index_dir / "metadata.json"\par 
        self._chunks_path   = self.index_dir / "chunks.json"\par 
\par 
        # Lazy-loaded components\par 
        self._model: Optional[SentenceTransformer] = None\par 
        self._index: Optional[faiss.Index] = None\par 
        self._metadata: list[dict] = []\par 
        self._documents: list[str] = []\par 
\par 
    @property\par 
    def model(self) -> SentenceTransformer:\par 
        if self._model is None:\par 
            logger.info(f"Loading embedding model: \{self.model_name\}")\par 
            start = time.perf_counter()\par 
            self._model = SentenceTransformer(self.model_name, device="cpu")\par 
            logger.info(f"Embedding model loaded in \{time.perf_counter() - start:.2f\}s")\par 
        return self._model\par 
\par 
    @property\par 
    def index(self) -> faiss.Index:\par 
        if self._index is None:\par 
            if self._index_path.exists():\par 
                self._load_index()\par 
            else:\par 
                self._create_index()\par 
        return self._index\par 
\par 
    def _create_index(self):\par 
        logger.info(\par 
            f"Creating FAISS HNSWFlat index: dim=\{self.dimension\}, "\par 
            f"M=\{config.FAISS_HNSW_M\}, efConstruction=\{config.FAISS_HNSW_EF_CONSTRUCTION\}"\par 
        )\par 
        self._index = faiss.IndexHNSWFlat(self.dimension, config.FAISS_HNSW_M)\par 
        self._index.hnsw.efConstruction = config.FAISS_HNSW_EF_CONSTRUCTION\par 
        self._index.hnsw.efSearch = config.FAISS_HNSW_EF_SEARCH\par 
        logger.info("FAISS HNSW index created")\par 
\par 
    def index_chunks(self, chunks: list[dict], force_reindex: bool = False) -> dict:\par 
        stats = \{\par 
            "total_chunks": len(chunks),\par 
            "indexed": 0,\par 
            "skipped": 0,\par 
            "embedding_time_s": 0.0,\par 
            "indexing_time_s": 0.0,\par 
            "total_time_s": 0.0,\par 
        \}\par 
        total_start = time.perf_counter()\par 
\par 
        # Skip if already indexed\par 
        if self._index_path.exists() and not force_reindex:\par 
            self._load_index()\par 
            if self._index.ntotal > 0:\par 
                logger.info(\par 
                    f"Index already contains \{self._index.ntotal\} vectors. "\par 
                    f"Skipping. Use force_reindex=True to rebuild."\par 
                )\par 
                stats["skipped"] = self._index.ntotal\par 
                stats["total_time_s"] = time.perf_counter() - total_start\par 
                return stats\par 
\par 
        # Rebuild from scratch\par 
        self._create_index()\par 
        self._metadata = []\par 
        self._documents = []\par 
\par 
        texts     = [c["text"] for c in chunks]\par 
        metadatas = [c["metadata"] for c in chunks]\par 
\par 
        # Generate embeddings in batches\par 
        logger.info(f"Generating embeddings for \{len(texts)\} chunks...")\par 
        embed_start = time.perf_counter()\par 
        all_embeddings = []\par 
        batch_size = config.EMBEDDING_BATCH_SIZE\par 
\par 
        for i in range(0, len(texts), batch_size):\par 
            batch = texts[i : i + batch_size]\par 
            batch_embeddings = self.model.encode(\par 
                batch,\par 
                show_progress_bar=False,\par 
                convert_to_numpy=True,\par 
                normalize_embeddings=True,  # L2-normalize for cosine similarity\par 
            )\par 
            all_embeddings.append(batch_embeddings)\par 
            logger.debug(\par 
                f"Embedded batch \{i // batch_size + 1\}/"\par 
                f"\{(len(texts) + batch_size - 1) // batch_size\}"\par 
            )\par 
\par 
        embeddings = np.vstack(all_embeddings).astype(np.float32)\par 
        stats["embedding_time_s"] = time.perf_counter() - embed_start\par 
        logger.info(f"Embeddings generated in \{stats['embedding_time_s']:.2f\}s")\par 
\par 
        # Add vectors to FAISS index\par 
        index_start = time.perf_counter()\par 
        self._index.add(embeddings)\par 
        stats["indexing_time_s"] = time.perf_counter() - index_start\par 
\par 
        self._metadata = metadatas\par 
        self._documents = texts\par 
        stats["indexed"] = len(texts)\par 
\par 
        self._save_index()\par 
        stats["total_time_s"] = time.perf_counter() - total_start\par 
        logger.info(\par 
            f"Indexed \{stats['indexed']\} chunks in \{stats['total_time_s']:.2f\}s "\par 
            f"(embed: \{stats['embedding_time_s']:.2f\}s, "\par 
            f"index: \{stats['indexing_time_s']:.2f\}s)"\par 
        )\par 
\par 
        # Free embedding memory\par 
        del embeddings, all_embeddings\par 
        if config.AGGRESSIVE_GC:\par 
            gc.collect()\par 
\par 
        return stats\par 
\par 
    def query(\par 
        self,\par 
        query_text: str,\par 
        top_k: int = None,\par 
        tactic_filter: Optional[str] = None,\par 
        platform_filter: Optional[str] = None,\par 
    ) -> list[dict]:\par 
        if top_k is None:\par 
            top_k = config.RAG_TOP_K\par 
\par 
        if self.index.ntotal == 0:\par 
            logger.warning("FAISS index is empty. Index chunks first.")\par 
            return []\par 
\par 
        start = time.perf_counter()\par 
\par 
        # Embed query (normalized for cosine similarity via L2)\par 
        query_embedding = self.model.encode(\par 
            [query_text],\par 
            convert_to_numpy=True,\par 
            normalize_embeddings=True,\par 
        ).astype(np.float32)\par 
\par 
        # Over-retrieve when filters are active\par 
        search_k = (\par 
            min(top_k * 3, self.index.ntotal)\par 
            if tactic_filter or platform_filter\par 
            else min(top_k, self.index.ntotal)\par 
        )\par 
        distances, indices = self.index.search(query_embedding, search_k)\par 
        elapsed = time.perf_counter() - start\par 
\par 
        results = []\par 
        for dist, idx in zip(distances[0], indices[0]):\par 
            if idx < 0 or idx >= len(self._metadata):\par 
                continue\par 
\par 
            # Convert L2 distance ├втАатАЩ cosine similarity (normalized vectors)\par 
            cosine_sim = 1.0 - (float(dist) / 2.0)\par 
            cosine_sim = max(0.0, min(1.0, cosine_sim))\par 
            metadata = self._metadata[idx]\par 
            document = self._documents[idx] if idx < len(self._documents) else ""\par 
\par 
            if tactic_filter:\par 
                if tactic_filter.lower() not in metadata.get("tactics", "").lower():\par 
                    continue\par 
            if platform_filter:\par 
                if platform_filter.lower() not in metadata.get("platforms", "").lower():\par 
                    continue\par 
\par 
            results.append(\{\par 
                "technique_id": metadata.get("technique_id", ""),\par 
                "name": metadata.get("name", ""),\par 
                "tactics": metadata.get("tactics", "").split(",") if isinstance(metadata.get("tactics"), str) else metadata.get("tactics", []),\par 
                "platforms": metadata.get("platforms", "").split(",") if isinstance(metadata.get("platforms"), str) else metadata.get("platforms", []),\par 
                "description_preview": metadata.get("description_preview", ""),\par 
                "distance": round(float(dist), 4),\par 
                "relevance_score": round(cosine_sim, 4),\par 
                "document": document,\par 
                "chunk_index": int(idx),\par 
                "stix_id": metadata.get("stix_id", ""),\par 
                "url": metadata.get("url", ""),\par 
