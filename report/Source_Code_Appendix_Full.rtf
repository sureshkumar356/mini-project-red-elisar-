@app.route("/api/scan", methods=["POST"])\par 
def api_scan():\par 
    """Option 1 ├втВмтАЭ Full Web Vulnerability Scan."""\par 
    data = request.get_json(force=True) or \{\}\par 
    target_url_raw = (data.get("target_url") or "").strip()\par 
    request_id = str(data.get("request_id") or "").strip()\par 
\par 
    if not target_url_raw:\par 
        return jsonify(\{"error": "target_url is required"\}), 400\par 
\par 
    try:\par 
        target_url = run_module.normalize_url(target_url_raw)\par 
    except ValueError as exc:\par 
        return jsonify(\{"error": str(exc)\}), 400\par 
\par 
    sq = StreamQueue()\par 
    cancel_event = _register_request(request_id)\par 
\par 
    def worker():\par 
        ctx = get_ctx()\par 
        # Attach queue handler to root logger\par 
        handler = QueueHandler(sq)\par 
        handler.setFormatter(logging.Formatter(config.LOG_FORMAT))\par 
        root = logging.getLogger()\par 
        root.addHandler(handler)\par 
        try:\par 
            _check_cancel(cancel_event)\par 
            sq.put(f"[INFO] Starting full web scan on: \{target_url\}")\par 
\par 
            # Step 1 ├втВмтАЬ Attack surface discovery\par 
            sq.put("[STEP 1/5] Discovering attack surface (crawl + common paths)├втВм┬ж")\par 
            discovery = run_module.discover_attack_surface(\par 
                target_url,\par 
                max_pages=int(getattr(config, "WEB_UI_DISCOVERY_MAX_PAGES", 18)),\par 
                timeout=float(getattr(config, "WEB_UI_DISCOVERY_TIMEOUT_S", 6.0)),\par 
            )\par 
            routes = discovery.get("routes", [])\par 
            _check_cancel(cancel_event)\par 
            sq.put(f"[OK] Found \{len(routes)\} routes, \{len(discovery.get('forms', []))\} forms.")\par 
\par 
            # Step 2 ├втВмтАЬ Web Recon\par 
            sq.put("[STEP 2/5] Running web recon├втВм┬ж")\par 
            recon_data = WebReconAgent(\par 
                target_url,\par 
                timeout_s=float(getattr(config, "WEB_UI_RECON_TIMEOUT_S", 6.0)),\par 
            ).run()\par 
            _check_cancel(cancel_event)\par 
            if not recon_data.get("reachable"):\par 
                sq.put(f"[ERROR] Target \{target_url\} is not reachable. Aborting.")\par 
                return\par 
\par 
            # Step 3 ├втВмтАЬ Passive + live vulnerability scan\par 
            sq.put("[STEP 3/5] Scanning for vulnerabilities (passive + live)├втВм┬ж")\par 
            passive_result = VulnerabilityScanner(recon_data).scan()\par 
            passive_vulns = passive_result.get("vulnerabilities", [])\par 
            _check_cancel(cancel_event)\par 
            sq.put(f"[OK] Passive scanner found \{len(passive_vulns)\} issue(s).")\par 
\par 
            live_vulns: list = []\par 
            try:\par 
                live_report = LiveVulnChecker(\par 
                    target_url,\par 
                    timeout=int(getattr(config, "WEB_UI_LIVE_TIMEOUT_S", 6.0)),\par 
                ).run_full_check()\par 
                _check_cancel(cancel_event)\par 
                live_vulns = [f for f in live_report.get("vulnerabilities", []) if f.get("confirmed_live")]\par 
                sq.put(f"[OK] Live checker confirmed \{len(live_vulns)\} issue(s).")\par 
            except Exception as exc:\par 
                sq.put(f"[WARN] Live check failed: \{exc\}")\par 
\par 
            form_vulns = run_module._probe_discovered_forms(\par 
                target_url,\par 
                discovery.get("forms", []),\par 
                timeout=float(getattr(config, "WEB_UI_FORM_TIMEOUT_S", 5.0)),\par 
            )\par 
            _check_cancel(cancel_event)\par 
            sq.put(f"[OK] Form probe found \{len(form_vulns)\} issue(s).")\par 
\par 
            merged_vulns = run_module._merge_vulnerabilities(passive_vulns, live_vulns, form_vulns)\par 
            counts = run_module._severity_counts(merged_vulns)\par 
            risk = run_module._overall_risk(counts)\par 
            sq.put(f"[OK] Merged total: \{len(merged_vulns)\} vulnerabilities. Overall risk: \{risk\}")\par 
\par 
            # Step 4 ├втВмтАЬ MITRE mapping + RAG\par 
            sq.put("[STEP 4/5] Loading FAISS index and mapping to MITRE ATT&CK├втВм┬ж")\par 
            ctx.ensure_rag(force_reindex=False)\par 
            _check_cancel(cancel_event)\par 
            mapped = ctx.mapper.map_vulnerabilities(merged_vulns)\par 
            chain = ctx.mapper.build_attack_chain(mapped, target_url=target_url)\par 
            sq.put(f"[OK] MITRE mapping complete. Attack chain has \{len(chain)\} steps.")\par 
\par 
            # Step 5 ├втВмтАЬ Report generation\par 
            sq.put("[STEP 5/5] Generating reports├втВм┬ж")\par 
            scan_result = \{\par 
                "target_url": target_url,\par 
                "scan_timestamp": datetime.now(timezone.utc).isoformat(),\par 
                "total_vulns": len(merged_vulns),\par 
                "severity_counts": counts,\par 
                "overall_risk": risk,\par 
                "vulnerabilities": merged_vulns,\par 
                "tech_stack": recon_data.get("tech_stack", \{\}),\par 
            \}\par 
            report = ReportGenerator().generate(\par 
                target_url=target_url,\par 
                recon_data=recon_data,\par 
                scan_result=scan_result,\par 
                attack_chain=chain,\par 
                llm_analysis="LLM analysis skipped in web UI mode.",\par 
            )\par 
            _check_cancel(cancel_event)\par 
            txt_path = run_module._write_scan_text_report(\par 
                target_url=target_url,\par 
                discovery=discovery,\par 
                vulnerabilities=merged_vulns,\par 
                mapped=mapped,\par 
                mitre_db=ctx.mitre_db,\par 
                rag_engine=ctx.rag,\par 
            )\par 
            sq.put(f"[OK] Text report saved: \{txt_path.name\}")\par 
            sq.put(f"[OK] JSON report: \{Path(report.get('json_path', '')).name\}")\par 
            sq.put(f"[OK] Markdown report: \{Path(report.get('md_path', '')).name\}")\par 
\par 
            # Emit structured result for the UI to parse\par 
            chain_with_vuln = []\par 
            for s in chain:\par 
                x = dict(s)\par 
                sv = x.get("source_vulnerability") or \{\}\par 
                x["vulnerability_name"] = str(sv.get("type") or "")\par 
                x["vulnerability_detail"] = str(sv.get("detail") or "")\par 
                x["vulnerability_severity"] = str(sv.get("severity") or "")\par 
                chain_with_vuln.append(x)\par 
\par 
            scenario_summary = (\par 
                f"Full scan for \{target_url\}. "\par 
                f"Total findings: \{len(merged_vulns)\}. "\par 
                f"Risk profile: \{risk\}. "\par 
                f"Primary findings include: \{', '.join([str(v.get('type') or 'Finding') for v in merged_vulns[:6]])\}."\par 
            )\par 
            result_payload = \{\par 
                "type": "result",\par 
                "target_url": target_url,\par 
                "overall_risk": risk,\par 
                "severity_counts": counts,\par 
                "total_vulns": len(merged_vulns),\par 
                "vulnerabilities": merged_vulns,\par 
                "attack_chain": chain_with_vuln,\par 
                "readable_scenario": _build_readable_scenario_text(\par 
                    scenario=scenario_summary,\par 
                    target_env=target_url,\par 
                    chain_steps=chain_with_vuln,\par 
                ),\par 
                "reports": \{\par 
                    "txt": str(txt_path),\par 
                    "json": str(report.get("json_path", "")),\par 
                    "md": str(report.get("md_path", "")),\par 
                    "pdf": str(report.get("pdf_path", "")),\par 
                \},\par 
            \}\par 
            _attach_novelty(\par 
                result_payload,\par 
                chain_steps=chain,\par 
                vulnerabilities=merged_vulns,\par 
                retrieval_results=[],\par 
            )\par 
            _store_latest("fullscan", result_payload)\par 
            sq.put("__RESULT__:" + json.dumps(result_payload, default=str))\par 
            sq.put("[DONE] Scan complete.")\par 
        except RequestCancelledError:\par 
            sq.put("[INFO] Request cancelled. Backend worker stopped.")\par 
        except Exception as exc:\par 
            sq.put(f"[ERROR] \{exc\}")\par 
        finally:\par 
            root.removeHandler(handler)\par 
            _cleanup_request(request_id)\par 
            sq.done()\par 
\par 
    threading.Thread(target=worker, daemon=True).start()\par 
\par 
