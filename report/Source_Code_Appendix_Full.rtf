\par 
def _register_request(request_id: str | None) -> threading.Event | None:\par 
    if not request_id:\par 
        return None\par 
    with _cancel_lock:\par 
        ev = _cancel_events.get(request_id)\par 
        if ev is None:\par 
            ev = threading.Event()\par 
            _cancel_events[request_id] = ev\par 
        return ev\par 
\par 
\par 
def _cleanup_request(request_id: str | None) -> None:\par 
    if not request_id:\par 
        return\par 
    with _cancel_lock:\par 
        _cancel_events.pop(request_id, None)\par 
\par 
\par 
def _check_cancel(cancel_event: threading.Event | None):\par 
    if cancel_event is not None and cancel_event.is_set():\par 
        raise RequestCancelledError("Request cancelled by user")\par 
\par 
\par 
def get_ctx() -> run_module.RuntimeContext:\par 
    global _runtime_ctx\par 
    with _ctx_lock:\par 
        if _runtime_ctx is None:\par 
            _runtime_ctx = run_module.RuntimeContext()\par 
        return _runtime_ctx\par 
