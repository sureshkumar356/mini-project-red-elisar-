import logging\par 
from typing import Optional\par 
from transformers import AutoTokenizer\par 
import config\par 
\par 
logger = logging.getLogger("red_elisar.chunking")\par 
\par 
_tokenizer: Optional[AutoTokenizer] = None\par 
\par 
\par 
def _get_tokenizer() -> AutoTokenizer:\par 
    global _tokenizer\par 
    if _tokenizer is None:\par 
        logger.info(f"Loading tokenizer for: \{config.CHUNK_TOKENIZER\}")\par 
        _tokenizer = AutoTokenizer.from_pretrained(\par 
            f"sentence-transformers/\{config.CHUNK_TOKENIZER\}"\par 
        )\par 
        logger.info("Tokenizer loaded")\par 
    return _tokenizer\par 
\par 
\par 
def chunk_text(\par 
    text: str,\par 
    metadata: dict,\par 
    chunk_size: int = None,\par 
    chunk_overlap: int = None,\par 
) -> list[dict]:\par 
    if chunk_size is None:\par 
        chunk_size = config.CHUNK_SIZE_TOKENS\par 
    if chunk_overlap is None:\par 
        chunk_overlap = config.CHUNK_OVERLAP_TOKENS\par 
\par 
    if not text or not text.strip():\par 
        return []\par 
\par 
    tokenizer = _get_tokenizer()\par 
    stride = chunk_size - chunk_overlap  # 512 - 128 = 384\par 
\par 
    # Tokenize full text\par 
    encoded = tokenizer.encode(text, add_special_tokens=False)\par 
    total_tokens = len(encoded)\par 
\par 
    # Single chunk if text fits\par 
    if total_tokens <= chunk_size:\par 
        chunk_meta = \{\par 
            **metadata,\par 
            "chunk_index": 0,\par 
            "total_chunks": 1,\par 
            "is_chunked": False,\par 
            "token_count": total_tokens,\par 
        \}\par 
        return [\{"text": text.strip(), "metadata": chunk_meta\}]\par 
\par 
    # Sliding window chunking\par 
    chunks = []\par 
    start = 0\par 
    chunk_index = 0\par 
\par 
    while start < total_tokens:\par 
        end = min(start + chunk_size, total_tokens)\par 
        chunk_token_ids = encoded[start:end]\par 
\par 
        chunk_text_str = tokenizer.decode(\par 
            chunk_token_ids,\par 
            skip_special_tokens=True,\par 
            clean_up_tokenization_spaces=True,\par 
        ).strip()\par 
\par 
        if chunk_text_str:\par 
            chunk_meta = \{\par 
                **metadata,\par 
                "chunk_index": chunk_index,\par 
                "total_chunks": -1,\par 
                "is_chunked": True,\par 
                "token_count": len(chunk_token_ids),\par 
            \}\par 
            chunks.append(\{"text": chunk_text_str, "metadata": chunk_meta\})\par 
            chunk_index += 1\par 
\par 
        start += stride\par 
\par 
        # Merge tiny trailing chunk into last chunk\par 
        if start < total_tokens and (total_tokens - start) < chunk_size // 4:\par 
            remaining_ids = encoded[start:total_tokens]\par 
            remaining_text = tokenizer.decode(\par 
                remaining_ids,\par 
                skip_special_tokens=True,\par 
                clean_up_tokenization_spaces=True,\par 
            ).strip()\par 
            if remaining_text and chunks:\par 
                last_chunk = chunks[-1]\par 
                last_chunk["text"] += " " + remaining_text\par 
                last_chunk["metadata"]["token_count"] += len(remaining_ids)\par 
            break\par 
\par 
    # Set total_chunks on all chunks\par 
    total_chunks = len(chunks)\par 
    for c in chunks:\par 
        c["metadata"]["total_chunks"] = total_chunks\par 
\par 
    return chunks\par 
\par 
\par 
def chunk_techniques(techniques: list) -> list[dict]:\par 
    all_chunks = []\par 
    stats = \{\par 
        "total_techniques": len(techniques),\par 
        "total_chunks": 0,\par 
        "single_chunk_techniques": 0,\par 
        "multi_chunk_techniques": 0,\par 
        "max_chunks_per_technique": 0,\par 
    \}\par 
\par 
    for tech in techniques:\par 
        text = tech.to_embedding_text()\par 
        metadata = \{\par 
            "technique_id": tech.technique_id,\par 
            "name": tech.name,\par 
            "tactics": ", ".join(tech.tactics) if tech.tactics else "",\par 
            "platforms": ", ".join(tech.platforms) if tech.platforms else "",\par 
            "is_subtechnique": tech.is_subtechnique,\par 
            "stix_id": tech.stix_id,\par 
            "url": tech.url,\par 
            "description_preview": tech.description[:200] if tech.description else "",\par 
        \}\par 
\par 
        chunks = chunk_text(text, metadata)\par 
        all_chunks.extend(chunks)\par 
\par 
        n_chunks = len(chunks)\par 
        if n_chunks == 1:\par 
            stats["single_chunk_techniques"] += 1\par 
        else:\par 
            stats["multi_chunk_techniques"] += 1\par 
        if n_chunks > stats["max_chunks_per_technique"]:\par 
            stats["max_chunks_per_technique"] = n_chunks\par 
\par 
    stats["total_chunks"] = len(all_chunks)\par 
\par 
    logger.info(\par 
        f"Chunking complete: \{stats['total_techniques']\} techniques ├втАатАЩ "\par 
        f"\{stats['total_chunks']\} chunks "\par 
        f"(\{stats['single_chunk_techniques']\} single, "\par 
        f"\{stats['multi_chunk_techniques']\} multi, "\par 
        f"max \{stats['max_chunks_per_technique']\} chunks/technique)"\par 
    )\par 
\par 
    return all_chunks\par 
\par 
\par 
def chunk_offensive_logs(logs: list[dict]) -> list[dict]:\par 
    all_chunks = []\par 
\par 
    for log in logs:\par 
        text = log.get("query", log.get("description", ""))\par 
        if not text:\par 
            continue\par 
\par 
        metadata = \{\par 
            "scenario_id": log.get("scenario_id", ""),\par 
            "scenario_type": log.get("scenario_type", "unknown"),\par 
            "expected_techniques": ", ".join(log.get("expected_techniques", [])),\par 
            "source": "offensive_log",\par 
        \}\par 
\par 
        chunks = chunk_text(text, metadata)\par 
        all_chunks.extend(chunks)\par 
\par 
    logger.info(f"Chunked \{len(logs)\} offensive logs ├втАатАЩ \{len(all_chunks)\} chunks")\par 
    return all_chunks\par 
\par 
