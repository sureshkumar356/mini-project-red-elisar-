    # ├втАЭтВм├втАЭтВм 7. Open Redirect ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм\par 
    def _check_open_redirect(self):\par 
        for param, evil_url in REDIRECT_PARAMS:\par 
            test_url = f"\{self.target\}/redirect"\par 
            try:\par 
                resp = self.session.get(\par 
                    test_url,\par 
                    params=\{param: evil_url\},\par 
                    timeout=self.timeout,\par 
                    allow_redirects=False,\par 
                )\par 
                if resp.status_code in (301, 302, 303, 307, 308):\par 
                    location = resp.headers.get("Location", "")\par 
                    # Confirm it actually redirects to the evil URL (or domain)\par 
                    if "evil-attacker" in location or location.startswith("http"):\par 
                        parsed_loc = urlparse(location)\par 
                        if parsed_loc.netloc and parsed_loc.netloc != urlparse(self.target).netloc:\par 
                            self._add(\par 
                                vuln_type  = "Open Redirect",\par 
                                detail     = (\par 
                                    f"Parameter '\{param\}' on /redirect causes unvalidated "\par 
                                    f"redirect to external domain: \{location\}"\par 
                                ),\par 
                                severity   = "MEDIUM",\par 
                                cwe        = "CWE-601",\par 
                                mitre      = "T1204",\par 
                                evidence   = (\par 
                                    f"GET /redirect?\{param\}=\{evil_url\} ├втАатАЩ "\par 
                                    f"HTTP \{resp.status_code\} Location: \{location\}"\par 
                                ),\par 
                                check      = "_check_open_redirect",\par 
                                confirmed  = True,\par 
                                recommendation = (\par 
                                    "Validate redirect destinations against a whitelist. "\par 
                                    "Never redirect to user-supplied external URLs."\par 
                                ),\par 
                            )\par 
                            break\par 
            except Exception:\par 
                continue\par 
