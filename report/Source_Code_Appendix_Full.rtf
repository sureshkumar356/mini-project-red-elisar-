def run_full_web_scan(ctx: RuntimeContext) -> None:\par 
    try:\par 
        target_url = normalize_url(input("Target URL: ").strip())\par 
    except ValueError:\par 
        return\par 
\par 
    with _silent_execution():\par 
        discovery = discover_attack_surface(target_url)\par 
        routes = discovery.get("routes", [])\par 
\par 
        # Fallback rule: if crawl yields nothing useful, scan the base URL directly.\par 
        if len(routes) <= 1:\par 
            routes = [target_url]\par 
\par 
        recon_data = WebReconAgent(target_url).run()\par 
        if not recon_data.get("reachable"):\par 
            return\par 
\par 
        passive = VulnerabilityScanner(recon_data).scan()\par 
        passive_vulns = passive.get("vulnerabilities", [])\par 
\par 
        live_vulns: list[dict[str, Any]] = []\par 
        try:\par 
