def _get_latest(mode: str | None = None) -> tuple[dict | None, dict]:\par 
    with _latest_lock:\par 
        if mode and mode in _latest_results:\par 
            return _latest_results.get(mode), dict(_latest_meta)\par 
        return _latest_results.get("last"), dict(_latest_meta)\par 
