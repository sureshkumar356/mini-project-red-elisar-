def _context_profile(vuln: dict[str, Any]) -> dict[str, Any]:\par 
    vtype = str(vuln.get("type", ""))\par 
    detail = str(vuln.get("detail", ""))\par 
    evidence = str(vuln.get("evidence", ""))\par 
    query = _vulnerability_rag_query(vuln)\par 
    strict_context_text = " ".join([vtype, detail, evidence]).strip()\par 
    context_text = " ".join([strict_context_text, query]).strip()\par 
\par 
    terms = _tokenize_text(context_text)\par 
    terms = \{t for t in terms if t not in GENERIC_CONTEXT_TOKENS and len(t) >= 3\}\par 
\par 
    lowered = context_text.lower()\par 
    allows_cloud = any(k in lowered for k in ["cloud", "aws", "azure", "gcp", "s3", "iam"])\par 
    allows_phishing = any(k in lowered for k in ["phish", "email", "inbox", "attachment"])\par 
    return \{\par 
        "context_text": context_text,\par 
        "strict_context_text": strict_context_text,\par 
        "focus_terms": terms,\par 
        "allows_cloud": allows_cloud,\par 
        "allows_phishing": allows_phishing,\par 
        "mitre_hint": str(vuln.get("mitre_hint", "")).strip(),\par 
        "expected_primary": _expected_primary_technique(vuln),\par 
    \}\par 
\par 
\par 
def _record_text(record: dict[str, Any]) -> str:\par 
    return " ".join(\par 
        [\par 
            str(record.get("technique_name", "")),\par 
            str(record.get("description", "")),\par 
            " ".join(record.get("tactics", []) or []),\par 
        ]\par 
    )\par 
\par 
\par 
def _is_contextually_relevant(\par 
    record: dict[str, Any],\par 
    context_text: str,\par 
    focus_terms: set[str],\par 
    allows_cloud: bool,\par 
    allows_phishing: bool,\par 
) -> bool:\par 
    text = _record_text(record)\par 
    low = text.lower()\par 
    overlap = _text_overlap_score(context_text, text)\par 
    relevance = float(record.get("relevance", 0.0))\par 
\par 
    if not allows_phishing and any(k in low for k in ["phish", "spearphish", "email attachment", "inbox"]):\par 
        return False\par 
    if not allows_cloud and any(k in low for k in ["aws", "azure", "gcp", "s3", "ec2", "iam", "kubernetes"]):\par 
        return False\par 
    if any(k in low for k in ["malware", "ransomware", "trojan", "rat", "nation-state", "apt"]):\par 
        return False\par 
\par 
    # Keep web/data/credential-centric results with clear contextual signal.\par 
    has_focus_term = bool(focus_terms & _tokenize_text(text))\par 
    has_relevant_tactic = any(t in (record.get("tactics", []) or []) for t in ATTACK_FLOW_TACTICS)\par 
\par 
    if not has_relevant_tactic:\par 
        return False\par 
    if overlap >= 0.02:\par 
        return True\par 
    if has_focus_term and relevance >= 0.14:\par 
        return True\par 
    return False\par 
\par 
\par 
def _primary_score(\par 
    record: dict[str, Any],\par 
    context_text: str,\par 
    focus_terms: set[str],\par 
    mitre_hint: str,\par 
    expected_primary: str,\par 
    avoid_primary_ids: set[str],\par 
) -> float:\par 
    tid = str(record.get("technique_id", "")).strip()\par 
    text = _record_text(record)\par 
    overlap = _text_overlap_score(context_text, text)\par 
    relevance = float(record.get("relevance", 0.0))\par 
    direct_term_hits = len(focus_terms & _tokenize_text(text))\par 
    directness = min(1.0, direct_term_hits / 5.0)\par 
\par 
    score = (0.5 * overlap) + (0.3 * relevance) + (0.2 * directness)\par 
    if mitre_hint and tid == mitre_hint:\par 
        score += 0.2\par 
    if expected_primary and tid == expected_primary:\par 
        score += 1.5\par 
    elif expected_primary and tid != expected_primary:\par 
        score -= 0.4\par 
    if tid in avoid_primary_ids:\par 
        score -= 0.08\par 
    return score\par 
\par 
\par 
def _downsample_chain_preserve_order(chain: list[dict[str, Any]], max_steps: int) -> list[dict[str, Any]]:\par 
    if len(chain) <= max_steps:\par 
        return chain\par 
    if max_steps <= 0:\par 
        return []\par 
    if max_steps == 1:\par 
        return [chain[0]]\par 
    idxs = \{\par 
        round(i * (len(chain) - 1) / (max_steps - 1))\par 
        for i in range(max_steps)\par 
    \}\par 
    selected = [chain[i] for i in sorted(idxs)]\par 
    return selected[:max_steps]\par 
\par 
\par 
def _build_dynamic_chain_from_mapping(\par 
    vuln: dict[str, Any],\par 
    mapping: dict[str, Any],\par 
    mitre_db: MitreAttackDatabase | None,\par 
    rag_engine: RAGEngine | None,\par 
    top_k: int = 20,\par 
    avoid_primary_ids: set[str] | None = None,\par 
    avoid_chain_ids: set[str] | None = None,\par 
) -> list[dict[str, Any]]:\par 
    avoid_primary_ids = avoid_primary_ids or set()\par 
    avoid_chain_ids = avoid_chain_ids or set()\par 
\par 
    techniques = mapping.get("mitre_techniques") or []\par 
    records = [_resolve_technique_record(t, vuln, mitre_db) for t in techniques]\par 
\par 
    profile = _context_profile(vuln)\par 
    query = str(profile.get("context_text", ""))\par 
    strict_context_text = str(profile.get("strict_context_text", query))\par 
    focus_terms = set(profile.get("focus_terms", set()))\par 
    allows_cloud = bool(profile.get("allows_cloud", False))\par 
    allows_phishing = bool(profile.get("allows_phishing", False))\par 
    mitre_hint = str(profile.get("mitre_hint", ""))\par 
    expected_primary = str(profile.get("expected_primary", ""))\par 
\par 
    if rag_engine is not None:\par 
        try:\par 
            broad = rag_engine.retrieve(query, top_k=top_k)\par 
            records.extend(_resolve_technique_record(t, vuln, mitre_db) for t in broad)\par 
        except Exception:\par 
            pass\par 
\par 
    # Deduplicate and keep highest relevance per technique.\par 
    dedup: dict[str, dict[str, Any]] = \{\}\par 
    for r in records:\par 
        tid = str(r.get("technique_id", "")).strip()\par 
        if not tid or tid == "N/A":\par 
            continue\par 
        prev = dedup.get(tid)\par 
        if prev is None or float(r.get("relevance", 0.0)) > float(prev.get("relevance", 0.0)):\par 
            dedup[tid] = r\par 
\par 
    records = list(dedup.values())\par 
\par 
    # Force tactic diversity by querying for missing lifecycle tactics.\par 
    tactic_order = ATTACK_FLOW_TACTICS\par 
    covered = \{t for r in records for t in r.get("tactics", [])\}\par 
    missing = [t for t in tactic_order if t not in covered]\par 
\par 
    if rag_engine is not None:\par 
        for tactic in missing:\par 
            try:\par 
                tactic_query = f"\{query\} techniques for tactic \{tactic.replace('-', ' ')\}"\par 
                extra = rag_engine.retrieve(tactic_query, top_k=8)\par 
                for t in extra:\par 
                    rec = _resolve_technique_record(t, vuln, mitre_db)\par 
                    tid = str(rec.get("technique_id", "")).strip()\par 
                    if not tid or tid == "N/A":\par 
                        continue\par 
                    prev = dedup.get(tid)\par 
                    if prev is None or float(rec.get("relevance", 0.0)) > float(prev.get("relevance", 0.0)):\par 
                        dedup[tid] = rec\par 
            except Exception:\par 
                continue\par 
\par 
    records = list(dedup.values())\par 
    if not records:\par 
        return []\par 
\par 
    if expected_primary and expected_primary not in \{str(r.get("technique_id", "")).strip() for r in records\} and mitre_db:\par 
        forced = mitre_db.get_technique(expected_primary)\par 
        if forced:\par 
            records.append(\par 
                \{\par 
                    "technique_id": forced.get("technique_id", expected_primary),\par 
                    "technique_name": forced.get("technique_name", "Unknown Technique"),\par 
                    "tactics": forced.get("tactics", []) or ["execution"],\par 
                    "tools": [],\par 
                    "relevance": 1.0,\par 
                    "description": forced.get("description", ""),\par 
                \}\par 
            )\par 
\par 
    context_text = query\par 
\par 
    # Context-aware filtering and ranking to reduce irrelevant noise.\par 
    filtered: list[dict[str, Any]] = []\par 
    for r in records:\par 
        if not _is_contextually_relevant(\par 
            r,\par 
            context_text=context_text,\par 
            focus_terms=focus_terms,\par 
            allows_cloud=allows_cloud,\par 
            allows_phishing=allows_phishing,\par 
        ):\par 
            continue\par 
\par 
        overlap = _text_overlap_score(\par 
            context_text,\par 
            f"\{r.get('technique_name', '')\} \{r.get('description', '')\} \{' '.join(r.get('tactics', []))\}",\par 
        )\par 
        relevance = float(r.get("relevance", 0.0))\par 
        score = (0.55 * relevance) + (0.45 * overlap)\par 
        if str(r.get("technique_id", "")) in avoid_chain_ids:\par 
            score -= 0.06\par 
        enriched = dict(r)\par 
        enriched["_score"] = score\par 
        filtered.append(enriched)\par 
\par 
    records = filtered\par 
    if not records:\par 
        return []\par 
\par 
    primary_candidates = sorted(\par 
        records,\par 
        key=lambda r: _primary_score(\par 
            r,\par 
            context_text=context_text,\par 
            focus_terms=focus_terms,\par 
            mitre_hint=mitre_hint,\par 
            expected_primary=expected_primary,\par 
            avoid_primary_ids=set(),\par 
        ),\par 
        reverse=True,\par 
    )\par 
    primary = primary_candidates[0]\par 
    if expected_primary:\par 
        for candidate in primary_candidates:\par 
            if str(candidate.get("technique_id", "")).strip() == expected_primary:\par 
                primary = candidate\par 
                break\par 
    elif avoid_primary_ids:\par 
        for candidate in primary_candidates:\par 
            tid = str(candidate.get("technique_id", "")).strip()\par 
            if tid and tid not in avoid_primary_ids:\par 
                primary = candidate\par 
                break\par 
    primary_id = str(primary.get("technique_id", "")).strip()\par 
    primary_tactics = primary.get("tactics", []) or []\par 
    primary_tactic = next((t for t in primary_tactics if t in ATTACK_FLOW_TACTICS), "execution")\par 
    primary_rank = _flow_rank(primary_tactic)\par 
\par 
    # Group by tactic and sort each tactic bucket by relevance.\par 
    tactic_groups: dict[str, list[dict[str, Any]]] = \{\}\par 
    for r in records:\par 
        tactics = r.get("tactics", []) or ["unknown"]\par 
        for tactic in tactics:\par 
            tactic_groups.setdefault(tactic, []).append(r)\par 
\par 
    for tactic in tactic_groups:\par 
        tactic_groups[tactic].sort(key=lambda x: -float(x.get("_score", x.get("relevance", 0.0))))\par 
\par 
    chain: list[dict[str, Any]] = []\par 
    used_techniques: set[str] = set()\par 
    used_tactics: set[str] = set()\par 
\par 
    # Follow requested lifecycle order first for logical progression.\par 
    ordered_tactics = [t for t in ATTACK_FLOW_TACTICS if t in tactic_groups]\par 
\par 
    for tactic in ordered_tactics:\par 
        rank = _flow_rank(tactic)\par 
        if rank < primary_rank - 1 or rank > primary_rank + 4:\par 
            continue\par 
        bucket = tactic_groups.get(tactic, [])\par 
        if not bucket:\par 
            continue\par 
        selected = None\par 
        if primary_id:\par 
            for candidate in bucket:\par 
                if str(candidate.get("technique_id", "")) == primary_id:\par 
                    selected = candidate\par 
                    break\par 
        if selected is None:\par 
            for candidate in bucket:\par 
                tid = str(candidate.get("technique_id", ""))\par 
                if tid and tid not in used_techniques:\par 
                    selected = candidate\par 
                    break\par 
        if selected is None:\par 
            continue\par 
        used_techniques.add(str(selected.get("technique_id", "")))\par 
        used_tactics.add(tactic)\par 
        step_tools = _select_context_tools(selected.get("tools", []), strict_context_text, max_tools=3)\par 
        if not step_tools:\par 
            step_tools = _fallback_web_tools(vuln, tactic)\par 
        chain.append(\par 
            \{\par 
                "step": len(chain) + 1,\par 
                "technique_id": selected.get("technique_id", "N/A"),\par 
                "technique_name": selected.get("technique_name", "Unknown Technique"),\par 
                "tactic": tactic,\par 
                "tools": step_tools,\par 
                "description": selected.get("description", "No description available."),\par 
                "is_primary": str(selected.get("technique_id", "")) == primary_id,\par 
            \}\par 
        )\par 
        if len(chain) >= 6:\par 
            break\par 
\par 
    # Add remaining non-duplicate techniques, prioritizing tactics not yet covered.\par 
    remaining = sorted(records, key=lambda x: -float(x.get("_score", x.get("relevance", 0.0))))\par 
    remaining_unique_tactics = []\par 
    remaining_repeat_tactics = []\par 
    for rec in remaining:\par 
        tid = str(rec.get("technique_id", ""))\par 
        if not tid or tid in used_techniques:\par 
            continue\par 
        tactic = (rec.get("tactics", ["unknown"]) or ["unknown"])[0]\par 
        if tactic not in ATTACK_FLOW_TACTICS:\par 
            continue\par 
        rank = _flow_rank(tactic)\par 
        if rank < primary_rank - 1 or rank > primary_rank + 4:\par 
            continue\par 
        if tactic in used_tactics:\par 
            remaining_repeat_tactics.append(rec)\par 
        else:\par 
            remaining_unique_tactics.append(rec)\par 
\par 
    for rec in remaining_unique_tactics:\par 
        if len(chain) >= 6:\par 
            break\par 
        tid = str(rec.get("technique_id", ""))\par 
        tactic = (rec.get("tactics", ["unknown"]) or ["unknown"])[0]\par 
        step_tools = _select_context_tools(rec.get("tools", []), strict_context_text, max_tools=3)\par 
        if not step_tools:\par 
            step_tools = _fallback_web_tools(vuln, tactic)\par 
        chain.append(\par 
            \{\par 
                "step": len(chain) + 1,\par 
                "technique_id": rec.get("technique_id", "N/A"),\par 
                "technique_name": rec.get("technique_name", "Unknown Technique"),\par 
                "tactic": tactic,\par 
                "tools": step_tools,\par 
                "description": rec.get("description", "No description available."),\par 
                "is_primary": str(rec.get("technique_id", "")) == primary_id,\par 
            \}\par 
        )\par 
        used_techniques.add(tid)\par 
        used_tactics.add(tactic)\par 
\par 
    # Keep output concise and useful: 5-7 logical steps.\par 
    if len(chain) < 5:\par 
        # Allow repeated tactics only when needed to reach minimum depth.\par 
        fallback = [c for c in remaining_repeat_tactics if str(c.get("technique_id", "")) not in used_techniques]\par 
        for rec in fallback:\par 
            tactic = (rec.get("tactics", ["unknown"]) or ["unknown"])[0]\par 
            chain.append(\par 
                \{\par 
                    "step": len(chain) + 1,\par 
                    "technique_id": rec.get("technique_id", "N/A"),\par 
                    "technique_name": rec.get("technique_name", "Unknown Technique"),\par 
                    "tactic": tactic,\par 
                    "tools": (_select_context_tools(rec.get("tools", []), strict_context_text, max_tools=3) or _fallback_web_tools(vuln, tactic)),\par 
                    "description": rec.get("description", "No description available."),\par 
                    "is_primary": str(rec.get("technique_id", "")) == primary_id,\par 
                \}\par 
            )\par 
            used_techniques.add(str(rec.get("technique_id", "")))\par 
            if len(chain) >= 5 or len(chain) >= 7:\par 
                break\par 
\par 
    if len(chain) < 5:\par 
        # Last-resort fill: keep flow-compatible, non-duplicate techniques to hit minimum depth.\par 
        final_fill = [\par 
            r\par 
            for r in remaining\par 
            if str(r.get("technique_id", "")) not in used_techniques\par 
            and (r.get("tactics", ["unknown"]) or ["unknown"])[0] in ATTACK_FLOW_TACTICS\par 
        ]\par 
        for rec in final_fill:\par 
            tactic = (rec.get("tactics", ["unknown"]) or ["unknown"])[0]\par 
            chain.append(\par 
                \{\par 
                    "step": len(chain) + 1,\par 
                    "technique_id": rec.get("technique_id", "N/A"),\par 
                    "technique_name": rec.get("technique_name", "Unknown Technique"),\par 
                    "tactic": tactic,\par 
                    "tools": (_select_context_tools(rec.get("tools", []), strict_context_text, max_tools=3) or _fallback_web_tools(vuln, tactic)),\par 
                    "description": rec.get("description", "No description available."),\par 
                    "is_primary": str(rec.get("technique_id", "")) == primary_id,\par 
                \}\par 
            )\par 
            used_techniques.add(str(rec.get("technique_id", "")))\par 
            if len(chain) >= 5:\par 
                break\par 
\par 
    # Ensure primary technique is always included even if it fell outside flow picks.\par 
    if primary_id and all(str(step.get("technique_id", "")) != primary_id for step in chain):\par 
        chain.insert(\par 
            0,\par 
            \{\par 
                "step": 1,\par 
                "technique_id": primary.get("technique_id", "N/A"),\par 
                "technique_name": primary.get("technique_name", "Unknown Technique"),\par 
                "tactic": primary_tactic,\par 
                "tools": (_select_context_tools(primary.get("tools", []), strict_context_text, max_tools=3) or _fallback_web_tools(vuln, primary_tactic)),\par 
                "description": primary.get("description", "No description available."),\par 
                "is_primary": True,\par 
            \},\par 
        )\par 
\par 
    chain = _downsample_chain_preserve_order(chain, max_steps=6)\par 
    for i, step in enumerate(chain, 1):\par 
        step["step"] = i\par 
    return chain\par 
