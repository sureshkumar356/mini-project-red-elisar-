def api_report_download():\par 
    path = (request.args.get("path") or "").strip()\par 
    if not path:\par 
        abort(404)\par 
    report_path = Path(path).expanduser().resolve()\par 
    output_dir = config.OUTPUT_DIR.resolve()\par 
    if output_dir not in report_path.parents and report_path != output_dir:\par 
        abort(403)\par 
    if (not report_path.exists() or not report_path.is_file()) and report_path.suffix.lower() == ".pdf":\par 
        # Auto-heal missing PDF by rendering from sibling markdown when available.\par 
        md_candidate = report_path.with_suffix(".md")\par 
