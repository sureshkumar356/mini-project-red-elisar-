def probe_target(target_url: str, attack_type: str, timeout: float | None = None) -> dict:\par 
    """\par 
    Probe the target URL for the specified attack type.\par 
    Returns a dict with: found, evidence, severity, endpoints_tested, recommendation\par 
    """\par 
    target_url = target_url.rstrip("/")\par 
    probers = \{\par 
        "xss":                 _probe_xss,\par 
        "sql_injection":       _probe_sqli,\par 
        "exposed_files":       _probe_exposed_files,\par 
        "unauthenticated_api": _probe_unauth_api,\par 
        "open_redirect":       _probe_open_redirect,\par 
