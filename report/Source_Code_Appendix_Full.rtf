    # Test GET /search\par 
    for payload, meaning in payloads[:2]:\par 
        url = f"\{base\}/search?q=\{payload\}"\par 
        endpoints_tested.append(url)\par 
        try:\par 
            r = requests.get(url, timeout=timeout_s)\par 
            if r.status_code == 200 and len(r.text) > 500:\par 
                evidence.append(\{\par 
