    def _dedupe_limit_techniques(self, techniques: list[dict], top_k: int) -> list[dict]:\par 
        # Prefer highest relevance per technique_id; avoid base+sub-technique duplicates when possible.\par 
        by_id: dict[str, dict] = \{\}\par 
        for t in techniques:\par 
            tid = self._clean_ws(t.get("technique_id", ""))\par 
            if not tid:\par 
                continue\par 
            prev = by_id.get(tid)\par 
            if prev is None or float(t.get("relevance_score", 0.0) or 0.0) > float(prev.get("relevance_score", 0.0) or 0.0):\par 
                by_id[tid] = t\par 
\par 
        # Drop sub-techniques if the base technique is already present.\par 
        selected: list[dict] = []\par 
        seen_bases: set[str] = set()\par 
        for tid, t in sorted(by_id.items(), key=lambda kv: float(kv[1].get("relevance_score", 0.0) or 0.0), reverse=True):\par 
            base = tid.split(".")[0]\par 
            if "." in tid and base in by_id:\par 
                continue\par 
            if base in seen_bases and base != tid:\par 
                continue\par 
            selected.append(t)\par 
            seen_bases.add(base)\par 
            if len(selected) >= top_k:\par 
