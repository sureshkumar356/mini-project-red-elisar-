"""\par 
mitre_mapper.py ├втВмтАЭ MITRE ATT&CK Vulnerability Mapper for Red ELISAR\par 
===================================================================\par 
Maps scanner findings to real MITRE ATT&CK techniques using:\par 
  1. Direct technique ID lookup (from mitre_hint field)\par 
  2. RAG semantic search (your existing FAISS vector store)\par 
  3. Attack chain ordering by tactic kill-chain sequence\par 
\par 
Integration: Fully compatible with your existing RAGEngine and FAISSVectorStore.\par 
"""\par 
\par 
import logging\par 
from typing import Optional\par 
\par 
logger = logging.getLogger("red_elisar.mitre_mapper")\par 
\par 
# Standard MITRE ATT&CK tactic kill-chain order\par 
TACTIC_KILL_CHAIN_ORDER = [\par 
    "reconnaissance",\par 
    "resource-development",\par 
    "initial-access",\par 
    "execution",\par 
    "persistence",\par 
    "privilege-escalation",\par 
    "defense-evasion",\par 
    "credential-access",\par 
    "discovery",\par 
    "lateral-movement",\par 
    "collection",\par 
    "exfiltration",\par 
    "impact",\par 
]\par 
\par 
# Direct map: MITRE technique ID ├втАатАЩ search query for RAG\par 
TECHNIQUE_SEARCH_QUERIES = \{\par 
    "T1592":    "gathering victim host information server fingerprinting reconnaissance",\par 
    "T1190":    "exploit public-facing application web server vulnerability",\par 
    "T1059.007":"JavaScript execution browser scripting cross-site scripting XSS",\par 
    "T1557":    "adversary in the middle man-in-the-middle MITM network interception",\par 
    "T1185":    "browser session hijacking clickjacking iframe",\par 
    "T1204":    "user execution malicious link phishing redirect",\par 
    "T1552":    "unsecured credentials exposed configuration files secrets",\par 
    "T1562":    "impair defenses disable security controls bypass",\par 
    "T1078":    "valid accounts credential access unauthorized admin access",\par 
    "T1213":    "data from information repositories exposed source code",\par 
    "T1499":    "endpoint denial of service web server resource exhaustion",\par 
    "T1110":    "brute force password spraying credential stuffing",\par 
\}\par 
\par 
\par 
class MITREMapper:\par 
    """\par 
    Maps vulnerability scanner findings to MITRE ATT&CK techniques\par 
    and orders them into a realistic attack chain.\par 
    """\par 
\par 
    def __init__(self, rag_engine):\par 
        """\par 
        Args:\par 
            rag_engine: Your existing RAGEngine instance.\par 
        """\par 
        self.rag = rag_engine\par 
\par 
    # ├втАЭтВм├втАЭтВм├втАЭтВм Main Entry Points ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм\par 
\par 
    def map_vulnerabilities(self, vulnerabilities: list) -> list:\par 
        """\par 
        For each vulnerability, retrieve matching MITRE ATT&CK techniques\par 
        from the FAISS vector store via the RAG engine.\par 
\par 
        Returns a list of dicts: \{vulnerability, mitre_techniques\}\par 
        """\par 
        mapped = []\par 
        retrieval_cache: dict[str, list] = \{\}\par 
        logger.info(f"[MITREMapper] Mapping \{len(vulnerabilities)\} vulnerabilities to MITRE ATT&CK...")\par 
\par 
        for vuln in vulnerabilities:\par 
            mitre_hint = vuln.get("mitre_hint", "")\par 
            vuln_type  = vuln.get("type", "")\par 
            detail     = vuln.get("detail", "")\par 
            evidence   = vuln.get("evidence", "")\par 
            recommendation = vuln.get("recommendation", "")\par 
\par 
            # Build a semantic search query from the vulnerability\par 
            # Prefer the direct technique query if available\par 
            if mitre_hint in TECHNIQUE_SEARCH_QUERIES:\par 
                query = TECHNIQUE_SEARCH_QUERIES[mitre_hint]\par 
            else:\par 
                query = f"\{vuln_type\} \{detail\} \{evidence\} \{recommendation\} web application attack behavior"\par 
\par 
            query_key = " ".join(str(query or "").split()).strip().lower()\par 
\par 
            try:\par 
                if query_key in retrieval_cache:\par 
                    techniques = retrieval_cache[query_key]\par 
                else:\par 
                    # Fast mapping mode: one query variant is usually enough for per-step mapping.\par 
                    techniques = self.rag.retrieve(\par 
                        query,\par 
                        top_k=8,\par 
                        max_query_variants=1,\par 
                        use_cache=True,\par 
                    )\par 
                    retrieval_cache[query_key] = techniques\par 
            except Exception as e:\par 
                logger.warning(f"[MITREMapper] RAG retrieval failed for '\{query[:50]\}': \{e\}")\par 
                techniques = []\par 
\par 
            # Drop weak matches to reduce irrelevant tactics.\par 
            filtered = []\par 
            for t in techniques:\par 
                score = float(t.get("relevance_score", 0.0) or 0.0)\par 
                if score >= 0.2:\par 
                    filtered.append(t)\par 
            techniques = filtered[:8]\par 
\par 
            # Add direct hint technique if it's not already retrieved\par 
            retrieved_ids = \{t.get("technique_id") for t in techniques\}\par 
            if mitre_hint and mitre_hint not in retrieved_ids:\par 
                direct = None\par 
                try:\par 
                    if hasattr(self.rag, "vector_store") and hasattr(self.rag.vector_store, "query_by_technique_id"):\par 
                        direct = self.rag.vector_store.query_by_technique_id(mitre_hint)\par 
                except Exception:\par 
                    direct = None\par 
\par 
                if direct:\par 
                    techniques.insert(0, \{\par 
                        "technique_id": mitre_hint,\par 
                        "name": direct.get("name", f"Technique \{mitre_hint\}"),\par 
                        "tactics": direct.get("tactics", []) or ["unknown"],\par 
                        "relevance_score": 1.0,\par 
                        "description_preview": direct.get("description_preview", f"Technique \{mitre_hint\} from ATT&CK dataset."),\par 
                    \})\par 
\par 
            mapped.append(\{\par 
                "vulnerability":     vuln,\par 
                "mitre_techniques":  techniques,\par 
                "primary_technique": techniques[0] if techniques else None,\par 
            \})\par 
            logger.info(\par 
                f"[MITREMapper] '\{vuln_type\}' ├втАатАЩ "\par 
                f"\{[t.get('technique_id') for t in techniques[:2]]\}"\par 
            )\par 
\par 
        return mapped\par 
\par 
    def build_attack_chain(self, mapped_vulns: list, target_url: str = "") -> list:\par 
        """\par 
        Orders mapped techniques into a realistic kill-chain attack sequence.\par 
\par 
        Logic:\par 
          1. Group all retrieved techniques by tactic\par 
          2. Walk the kill-chain tactic order\par 
          3. At each tactic position, pick the best matching technique\par 
          4. Attach the source vulnerability for context\par 
\par 
        Returns an ordered list of attack steps.\par 
        """\par 
        # Collect all technique├втАатАЩvulnerability pairs, grouped by tactic\par 
        tactic_bucket: dict[str, list] = \{t: [] for t in TACTIC_KILL_CHAIN_ORDER\}\par 
\par 
        for mv in mapped_vulns:\par 
            vuln = mv["vulnerability"]\par 
            techniques = mv.get("mitre_techniques") or []\par 
            if not techniques:\par 
                continue\par 
\par 
            # Include multiple mapped techniques per vulnerability so the chain\par 
            # reflects broader attack behavior instead of only one primary pick.\par 
            for rank, tech in enumerate(techniques[:5]):\par 
                tactics = tech.get("tactics", [])\par 
                if isinstance(tactics, str):\par 
                    tactics = [tactics]\par 
\par 
                for tactic in tactics:\par 
                    tactic_clean = tactic.lower().replace(" ", "-")\par 
                    if tactic_clean in tactic_bucket:\par 
                        tactic_bucket[tactic_clean].append(\{\par 
                            "technique": tech,\par 
                            "vulnerability": vuln,\par 
                            "rank": rank,\par 
                        \})\par 
\par 
        # Build the ordered chain (one step per tactic where possible)\par 
        chain = []\par 
        step_num = 1\par 
        used_techniques = set()\par 
        for tactic in TACTIC_KILL_CHAIN_ORDER:\par 
            entries = tactic_bucket.get(tactic, [])\par 
            if not entries:\par 
                # Pull a direct tactic-focused candidate when this stage is missing.\par 
                try:\par 
                    extra = self.rag.retrieve(\par 
                        f"\{target_url\} attack behavior for tactic \{tactic.replace('-', ' ')\}",\par 
                        top_k=6,\par 
                        tactic_filter=tactic,\par 
                    )\par 
                except Exception:\par 
                    extra = []\par 
\par 
                if extra:\par 
                    entries = [\par 
                        \{\par 
                            "technique": extra[0],\par 
                            "vulnerability": \{"type": "Lifecycle Coverage", "detail": f"Coverage-added tactic step: \{tactic\}", "severity": "INFO"\},\par 
                        \}\par 
                    ]\par 
                else:\par 
                    continue\par 
\par 
            # Prefer highest cosine similarity score; avoid reusing the same technique across steps.\par 
            available = [\par 
                e for e in entries\par 
                if e["technique"].get("technique_id") not in used_techniques\par 
            ]\par 
            pool = available if available else entries\par 
            best = max(\par 
                pool,\par 
                key=lambda e: (\par 
                    float(e["technique"].get("relevance_score", -1.0) or -1.0),\par 
                    -int(e.get("rank", 99)),\par 
                ),\par 
            )\par 
            tech = best["technique"]\par 
            vuln = best["vulnerability"]\par 
            used_techniques.add(tech.get("technique_id"))\par 
\par 
            chain.append(\{\par 
                "step":            step_num,\par 
                "tactic":          tactic,\par 
                "technique_id":    tech.get("technique_id", "Unknown"),\par 
                "technique_name":  tech.get("name", "Unknown"),\par 
                "relevance_score": tech.get("relevance_score"),\par 
                "description":     tech.get("description_preview", tech.get("document", ""))[:300],\par 
                "source_vulnerability": \{\par 
                    "type":     vuln.get("type"),\par 
                    "detail":   vuln.get("detail"),\par 
                    "severity": vuln.get("severity"),\par 
                \},\par 
                "recommendation": vuln.get("recommendation"),\par 
            \})\par 
            step_num += 1\par 
\par 
        # Second pass: guarantee broader per-vulnerability representation.\par 
        # This ensures each vulnerability contributes multiple mapped techniques\par 
        # (when available), not just a single extracted one.\par 
        seen_vuln_multi: set[str] = set()\par 
        for mv in mapped_vulns:\par 
            vuln = mv.get("vulnerability", \{\}) or \{\}\par 
            techniques = mv.get("mitre_techniques") or []\par 
            if not techniques:\par 
                continue\par 
            vuln_key = (\par 
                f"\{vuln.get('type', '')\}|\{vuln.get('detail', '')\}|"\par 
                f"\{vuln.get('endpoint', vuln.get('url', ''))\}"\par 
            ).strip().lower()\par 
            if vuln_key in seen_vuln_multi:\par 
                continue\par 
            seen_vuln_multi.add(vuln_key)\par 
\par 
            added_for_vuln = 0\par 
            for tech in techniques:\par 
                if len(chain) >= 12 or added_for_vuln >= 3:\par 
                    break\par 
                tid = tech.get("technique_id")\par 
                if not tid or tid in used_techniques:\par 
                    continue\par 
                tactics = tech.get("tactics", [])\par 
                if isinstance(tactics, str):\par 
                    tactics = [tactics]\par 
                tactic_clean = "unknown"\par 
                for t in tactics:\par 
                    tc = str(t).lower().replace(" ", "-")\par 
                    if tc in tactic_bucket:\par 
                        tactic_clean = tc\par 
                        break\par 
\par 
                used_techniques.add(tid)\par 
                chain.append(\{\par 
                    "step":            step_num,\par 
                    "tactic":          tactic_clean,\par 
                    "technique_id":    tech.get("technique_id", "Unknown"),\par 
                    "technique_name":  tech.get("name", "Unknown"),\par 
                    "relevance_score": tech.get("relevance_score"),\par 
                    "description":     tech.get("description_preview", tech.get("document", ""))[:300],\par 
                    "source_vulnerability": \{\par 
                        "type":     vuln.get("type"),\par 
                        "detail":   vuln.get("detail"),\par 
                        "severity": vuln.get("severity"),\par 
                    \},\par 
                    "recommendation": vuln.get("recommendation"),\par 
                \})\par 
                step_num += 1\par 
                added_for_vuln += 1\par 
\par 
        # Third pass: include additional high-confidence techniques even if\par 
        # they share tactics, so users can see fuller attack-chain coverage.\par 
        extra_candidates = []\par 
        for tactic, entries in tactic_bucket.items():\par 
            for entry in entries:\par 
                tid = entry["technique"].get("technique_id")\par 
                if not tid or tid in used_techniques:\par 
                    continue\par 
                extra_candidates.append((tactic, entry))\par 
\par 
        extra_candidates.sort(\par 
            key=lambda x: (\par 
                float(x[1]["technique"].get("relevance_score", 0.0) or 0.0),\par 
                -int(x[1].get("rank", 99)),\par 
            ),\par 
            reverse=True,\par 
        )\par 
\par 
        for tactic, best in extra_candidates:\par 
            if len(chain) >= 12:\par 
                break\par 
            tech = best["technique"]\par 
            vuln = best["vulnerability"]\par 
            tid = tech.get("technique_id")\par 
            if not tid or tid in used_techniques:\par 
                continue\par 
            used_techniques.add(tid)\par 
            chain.append(\{\par 
                "step":            step_num,\par 
                "tactic":          tactic,\par 
                "technique_id":    tech.get("technique_id", "Unknown"),\par 
                "technique_name":  tech.get("name", "Unknown"),\par 
                "relevance_score": tech.get("relevance_score"),\par 
                "description":     tech.get("description_preview", tech.get("document", ""))[:300],\par 
                "source_vulnerability": \{\par 
                    "type":     vuln.get("type"),\par 
                    "detail":   vuln.get("detail"),\par 
                    "severity": vuln.get("severity"),\par 
                \},\par 
                "recommendation": vuln.get("recommendation"),\par 
            \})\par 
            step_num += 1\par 
\par 
        # Normalize step numbering after multi-pass appends.\par 
        for idx, step in enumerate(chain, 1):\par 
            step["step"] = idx\par 
\par 
        logger.info(f"[MITREMapper] Built attack chain with \{len(chain)\} steps "\par 
                    f"across \{len(set(s['tactic'] for s in chain))\} tactics")\par 
        return chain\par 
\par 
    def build_scenario_description(self, target_url: str, scan_result: dict,\par 
                                   mapped_vulns: list) -> str:\par 
        """\par 
        Builds a natural-language scenario description for the RAG engine\par 
        to generate the final LLM-powered attack narrative.\par 
        """\par 
        risk    = scan_result.get("overall_risk", "UNKNOWN")\par 
        counts  = scan_result.get("severity_counts", \{\})\par 
        total   = scan_result.get("total_vulns", 0)\par 
        tech    = scan_result.get("tech_stack", \{\})\par 
\par 
        server   = tech.get("server", "Unknown web server")\par 
        language = tech.get("language", "Unknown backend")\par 
\par 
        vuln_types = list(\{mv["vulnerability"]["type"] for mv in mapped_vulns\})\par 
        vuln_str   = ", ".join(vuln_types[:5])\par 
\par 
        scenario = (\par 
            f"Web application attack targeting \{target_url\} "\par 
            f"(\{server\}, \{language\}). "\par 
            f"Discovered vulnerabilities: \{vuln_str\}. "\par 
            f"Overall risk: \{risk\}. "\par 
            f"Critical:\{counts.get('CRITICAL',0)\}, "\par 
            f"High:\{counts.get('HIGH',0)\}, "\par 
            f"Medium:\{counts.get('MEDIUM',0)\} findings. "\par 
            f"Attacker can exploit SQL injection, exposed credentials, "\par 
            f"missing security controls, and debug mode to achieve full compromise."\par 
        )\par 
        return scenario\par 
\par 
