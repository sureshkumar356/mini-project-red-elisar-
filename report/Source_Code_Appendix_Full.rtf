def _build_readable_scenario_text(scenario: str, target_env: str | None, chain_steps: list) -> dict:\par 
    """Create readable, user-focused narrative paragraphs from LLM-generated chain steps."""\par 
    steps = chain_steps or []\par 
    top_steps = steps[:8]\par 
    names = [str(s.get("technique_name") or s.get("name") or s.get("technique_id") or "attack step").strip() for s in top_steps]\par 
    tactics = [str(s.get("tactic") or s.get("phase") or "unknown").strip().replace("-", " ") for s in top_steps]\par 
    env = (target_env or "enterprise environment").strip()\par 
\par 
    if names:\par 
        attack_flow = ", then ".join(names[:5])\par 
        if len(names) > 5:\par 
            attack_flow += ", followed by additional chained stages"\par 
    else:\par 
        attack_flow = "multi-stage behavior mapped from your scenario"\par 
\par 
    intent_para = (\par 
        f"This scenario models a realistic multi-step security pathway in the \{env\}, "\par 
        f"aligned to your stated objective and likely progression points."\par 
    )\par 
    flow_para = (\par 
        f"The generated chain indicates a practical progression: \{attack_flow\}. "\par 
        f"This sequence is modeled from your scenario context and ATT&CK-grounded LLM reasoning."\par 
    )\par 
    workflow_para = (\par 
        "Use this chain as a structured execution and validation workflow: confirm prerequisites, verify each transition, "\par 
        "capture evidence at each stage, and record outcome quality before moving to the next step."\par 
    )\par 
    actions = []\par 
    detailed_flow = []\par 
    proceed_guidance = []\par 
    for idx, step in enumerate(top_steps[:8], start=1):\par 
        name = str(step.get("technique_name") or step.get("name") or step.get("technique_id") or f"Step \{idx\}")\par 
        tactic = str(step.get("tactic") or step.get("phase") or "unknown").replace("-", " ")\par 
        desc = str(step.get("description") or "No detailed description provided by the chain.").strip()\par 
        rationale = str(step.get("rationale") or "Mapped from scenario context and ATT&CK behavior.").strip()\par 
        mitigation = str(step.get("mitigation") or "Apply layered controls, detection, and hardening for this step.").strip()\par 
        actions.append(f"Step \{idx\}: Focus on \{name\} under \{tactic\} with clear success criteria.")\par 
        detailed_flow.append(\par 
            f"Step \{idx\} (\{tactic\}) - \{name\}. "\par 
            f"Process detail: \{desc\} "\par 
            f"Chain role: \{rationale\}"\par 
        )\par 
        proceed_guidance.append(\par 
            f"Step \{idx\} execution guidance: Prepare required conditions for \{name\}, run controlled validation for this stage, "\par 
            f"collect concrete evidence artifacts, and confirm that outputs satisfy step-specific success criteria. "\par 
            f"Quality note: \{mitigation\}"\par 
        )\par 
\par 
    return \{\par 
        "summary": " ".join([intent_para, flow_para]),\par 
        "paragraphs": [intent_para, flow_para, workflow_para],\par 
        "operator_actions": actions,\par 
        "detailed_attack_flow": detailed_flow,\par 
        "how_to_proceed": proceed_guidance,\par 
        "tactic_sequence": tactics,\par 
    \}\par 
\par 
