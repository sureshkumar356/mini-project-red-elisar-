@contextlib.contextmanager\par 
def _silent_execution() -> Any:\par 
    """Suppress stdout/stderr and non-critical logs during option execution."""\par 
    buf_out = io.StringIO()\par 
    buf_err = io.StringIO()\par 
    previous_disable = logging.root.manager.disable\par 
    try:\par 
        logging.disable(logging.CRITICAL)\par 
        with contextlib.redirect_stdout(buf_out), contextlib.redirect_stderr(buf_err):\par 
            yield\par 
    finally:\par 
        logging.disable(previous_disable)\par 
\par 
