class VulnerabilityScanner:\par 
    """\par 
    Analyzes recon data to identify vulnerabilities and\par 
    map them to MITRE ATT&CK technique hints.\par 
    """\par 
\par 
    def __init__(self, recon_data: dict):\par 
        self.data           = recon_data\par 
        self.vulnerabilities = []\par 
        self.scan_time       = datetime.now(timezone.utc).isoformat()\par 
\par 
    # ├втАЭтВм├втАЭтВм├втАЭтВм Main Entry Point ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм\par 
    def scan(self) -> dict:\par 
        """Run all checks and return a structured vulnerability report."""\par 
        logger.info(f"[Scanner] Starting vulnerability scan for: \{self.data.get('target_url')\}")\par 
\par 
        if not self.data.get("reachable"):\par 
            return \{"error": "Target not reachable", "vulnerabilities": []\}\par 
\par 
        self._check_missing_headers()\par 
        self._check_leaky_headers()\par 
        self._check_exposed_paths()\par 
        self._check_cors()\par 
        self._check_open_redirect()\par 
        self._check_ssl()\par 
        self._check_debug_mode()\par 
        self._check_http_only()\par 
\par 
        # Sort by severity\par 
        self.vulnerabilities.sort(key=lambda v: SEVERITY_ORDER.get(v["severity"], 99))\par 
\par 
        stats = \{\par 
            "CRITICAL": sum(1 for v in self.vulnerabilities if v["severity"] == "CRITICAL"),\par 
            "HIGH":     sum(1 for v in self.vulnerabilities if v["severity"] == "HIGH"),\par 
            "MEDIUM":   sum(1 for v in self.vulnerabilities if v["severity"] == "MEDIUM"),\par 
            "LOW":      sum(1 for v in self.vulnerabilities if v["severity"] == "LOW"),\par 
            "INFO":     sum(1 for v in self.vulnerabilities if v["severity"] == "INFO"),\par 
        \}\par 
\par 
        logger.info(\par 
            f"[Scanner] Found \{len(self.vulnerabilities)\} vulnerabilities ├втВмтАЭ "\par 
            f"CRITICAL:\{stats['CRITICAL']\} HIGH:\{stats['HIGH']\} "\par 
            f"MEDIUM:\{stats['MEDIUM']\} LOW:\{stats['LOW']\}"\par 
        )\par 
\par 
        return \{\par 
            "target_url":      self.data.get("target_url"),\par 
            "scan_timestamp":  self.scan_time,\par 
            "total_vulns":     len(self.vulnerabilities),\par 
            "severity_counts": stats,\par 
            "overall_risk":    self._calculate_overall_risk(stats),\par 
