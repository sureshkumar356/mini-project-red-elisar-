        overall_risk = "INFO"\par 
        if stats["CRITICAL"] > 0:\par 
            overall_risk = "CRITICAL"\par 
        elif stats["HIGH"] >= 2:\par 
            overall_risk = "HIGH"\par 
        elif stats["HIGH"] >= 1 or stats["MEDIUM"] >= 3:\par 
            overall_risk = "MEDIUM"\par 
        elif stats["MEDIUM"] > 0:\par 
