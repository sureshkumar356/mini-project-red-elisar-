def _save_enriched_report(prefix: str, payload: dict[str, Any]) -> tuple[Path, Path]:\par 
    """Keep enriched JSON/Markdown generation for interactive scan outputs."""\par 
    config.ensure_directories()\par 
    ts = datetime.now(timezone.utc).strftime("%Y%m%d_%H%M%S")\par 
    json_path = config.OUTPUT_DIR / f"\{prefix\}_\{ts\}.json"\par 
    md_path = config.OUTPUT_DIR / f"\{prefix\}_\{ts\}.md"\par 
\par 
    with open(json_path, "w", encoding="utf-8") as f:\par 
        json.dump(payload, f, indent=2, ensure_ascii=False, default=str)\par 
\par 
    lines = [\par 
        f"# \{prefix.replace('_', ' ').title()\}",\par 
        "",\par 
        f"- Generated: \{datetime.now(timezone.utc).strftime('%Y-%m-%d %H:%M UTC')\}",\par 
        f"- Target URL: \{payload.get('target_url', 'N/A')\}",\par 
        f"- Total vulnerabilities: \{len(payload.get('vulnerabilities', []))\}",\par 
        "",\par 
        "## MITRE Mapping Per Vulnerability",\par 
        "",\par 
    ]\par 
\par 
    for i, item in enumerate(payload.get("vuln_mappings", []), 1):\par 
        vuln = item.get("vulnerability", \{\})\par 
        lines.append(f"### \{i\}. \{vuln.get('type', 'Unknown')\} [\{vuln.get('severity', 'N/A')\}]")\par 
        lines.append(f"- Detail: \{vuln.get('detail', 'N/A')\}")\par 
        techniques = item.get("top_techniques", [])\par 
        if techniques:\par 
            lines.append("- Techniques:")\par 
            for t in techniques:\par 
                lines.append(f"  - [\{t.get('technique_id', 'N/A')\}] \{t.get('name', 'Unknown')\}")\par 
        else:\par 
            lines.append("- Techniques: None")\par 
        lines.append("")\par 
\par 
    lines += ["## Attack Chain", ""]\par 
    for step in payload.get("attack_chain", []):\par 
        lines.append(\par 
            f"- Step \{step.get('step', '?')\}: "\par 
            f"[\{step.get('technique_id', 'N/A')\}] \{step.get('technique_name', 'Unknown')\} "\par 
            f"(\{step.get('tactic', 'N/A')\})"\par 
        )\par 
\par 
    with open(md_path, "w", encoding="utf-8") as f:\par 
        f.write("\\n".join(lines) + "\\n")\par 
\par 
    return json_path, md_path\par 
