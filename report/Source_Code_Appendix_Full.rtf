def _store_latest(mode: str, payload: dict) -> None:\par 
    timestamp = datetime.now(timezone.utc).isoformat()\par 
    with _latest_lock:\par 
        _latest_results[mode] = payload\par 
        _latest_results["last"] = payload\par 
        _latest_meta["mode"] = mode\par 
        _latest_meta["timestamp"] = timestamp\par 
