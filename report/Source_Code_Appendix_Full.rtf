    # ├втАЭтВм├втАЭтВм 6. Reflected XSS ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм\par 
    def _check_xss(self):\par 
        """\par 
        Sends XSS payloads to endpoints and confirms reflection in the live\par 
        HTTP response body.\par 
        """\par 
        probe_targets = [\par 
            (f"\{self.target\}/greet",  "name"),\par 
            (f"\{self.target\}/search", "q"),\par 
        ]\par 
        for endpoint, param in probe_targets:\par 
            for payload, marker in XSS_PAYLOADS:\par 
                try:\par 
                    params = \{param: payload\}\par 
                    resp   = self.session.get(endpoint, params=params,\par 
                                              timeout=self.timeout)\par 
                    # Check if the raw payload (or a significant part) appears\par 
                    # verbatim in the response ├втВмтАЭ confirming reflection\par 
                    if marker in resp.text or payload[:20] in resp.text:\par 
                        self._add(\par 
                            vuln_type  = "Reflected Cross-Site Scripting (XSS)",\par 
                            detail     = (\par 
                                f"XSS payload reflected unescaped on "\par 
                                f"\{endpoint\}?\{param\}=<payload>"\par 
                            ),\par 
                            severity   = "HIGH",\par 
                            cwe        = "CWE-79",\par 
                            mitre      = "T1059.007",\par 
                            evidence   = (\par 
                                f"Sent: \{payload[:60]\} | "\par 
                                f"Marker '\{marker\}' found verbatim in live HTTP response"\par 
                            ),\par 
                            check      = "_check_xss",\par 
                            confirmed  = True,\par 
                            recommendation = (\par 
                                "HTML-escape all user input before rendering. "\par 
                                "Use template engines with auto-escaping (e.g., Jinja2 with |e)."\par 
                            ),\par 
                        )\par 
                        break  # One XSS per endpoint is enough\par 
                except Exception:\par 
                    continue\par 
