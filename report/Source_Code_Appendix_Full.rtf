    def validate_response(\par 
        self,\par 
        raw_response: str,\par 
        retrieved_techniques: list[dict],\par 
    ) -> tuple[dict, list[str]]:\par 
        warnings = []\par 
\par 
        # Layer 1: JSON parsing\par 
        parsed = self._extract_json(raw_response)\par 
        if parsed is None:\par 
            raise ValueError(\par 
                f"LLM response is not valid JSON. Raw response:\\n\{raw_response[:500]\}"\par 
            )\par 
\par 
        # Layer 2: Normalize output to \{steps: [...]\}\par 
        if "steps" not in parsed and "attack_chain" in parsed:\par 
            parsed = \{"steps": parsed.get("attack_chain", []), "metadata": parsed.get("metadata", \{\})\}\par 
\par 
        # Mandatory: steps must exist for downstream evaluation.\par 
        if not isinstance(parsed, dict) or "steps" not in parsed or not isinstance(parsed.get("steps"), list):\par 
            raise ValueError("Missing or invalid 'steps' in model output")\par 
\par 
        # Normalize: allow model to emit \{technique: "Txxxx"\} and convert to technique_id.\par 
        normalized_steps: list[dict] = []\par 
        for step in parsed.get("steps", []):\par 
            if not isinstance(step, dict):\par 
                continue\par 
            out = dict(step)\par 
            tid = str(out.get("technique_id") or out.get("technique") or "").strip().upper()\par 
            if tid:\par 
                out["technique_id"] = tid\par 
            normalized_steps.append(out)\par 
        parsed["steps"] = normalized_steps\par 
\par 
        # Mandatory: every step must have a valid technique id.\par 
        bad = 0\par 
        for s in parsed.get("steps", []):\par 
            tid = str(s.get("technique_id", "")).strip().upper()\par 
            if not re.match(r"^T\\d\{4\}(\\.\\d\{3\})?$", tid):\par 
                bad += 1\par 
        if bad:\par 
            raise ValueError(f"Invalid or missing technique IDs in steps: \{bad\}")\par 
\par 
        # Layer 3: Schema validation (non-fatal warning)\par 
        try:\par 
            jsonschema.validate(instance=parsed, schema=ATTACK_CHAIN_SCHEMA)\par 
        except jsonschema.ValidationError as e:\par 
            warnings.append(f"Schema validation warning: \{e.message\}")\par 
            logger.warning(f"Schema validation issue: \{e.message\}")\par 
\par 
        # Layer 4: Grounding signal (informational, not a hard fail)\par 
        retrieved_ids = \{t.get("technique_id", "") for t in retrieved_techniques\}\par 
        steps = parsed.get("steps", []) if isinstance(parsed, dict) else []\par 
        grounded = 0\par 
        total = 0\par 
        for step in steps if isinstance(steps, list) else []:\par 
            cited_id = str(step.get("technique_id") or step.get("technique") or "").strip().upper()\par 
            if not cited_id:\par 
                continue\par 
            total += 1\par 
            if cited_id in retrieved_ids or cited_id.split(".")[0] in \{x.split(".")[0] for x in retrieved_ids if x\}:\par 
                grounded += 1\par 
        if total:\par 
            grounded_ratio = grounded / total\par 
            logger.info("Grounded steps: %d/%d (%.0f%%)", grounded, total, grounded_ratio * 100)\par 
\par 
        # Convert to legacy-compatible shape for downstream consumers.\par 
        legacy_chain = []\par 
        for s in steps if isinstance(steps, list) else []:\par 
            legacy_chain.append(\par 
                \{\par 
                    "step": int(s.get("step", len(legacy_chain) + 1) or (len(legacy_chain) + 1)),\par 
                    "technique_id": str(s.get("technique_id") or s.get("technique") or "").strip().upper(),\par 
                    "technique_name": str(s.get("technique_name", "")).strip(),\par 
                    "tactic": str(s.get("tactic", "")).strip(),\par 
                    "description": str(s.get("description", "")).strip(),\par 
                    "rationale": str(s.get("rationale", "")).strip() if isinstance(s, dict) else "",\par 
                    "prerequisites": s.get("prerequisites", []) if isinstance(s, dict) else [],\par 
                    "detection_considerations": str(s.get("detection_considerations", "")).strip() if isinstance(s, dict) else "",\par 
                    "mitigation": str(s.get("mitigation", "")).strip() if isinstance(s, dict) else "",\par 
                    "tool_commands": s.get("tool_commands", []) if isinstance(s, dict) else [],\par 
                \}\par 
            )\par 
        legacy_chain.sort(key=lambda x: x.get("step", 0) or 0)\par 
        for i, step in enumerate(legacy_chain, 1):\par 
            step["step"] = i\par 
\par 
        metadata = parsed.get("metadata", \{\}) if isinstance(parsed, dict) else \{\}\par 
        return \{"attack_chain": legacy_chain, "metadata": metadata\}, warnings\par 
\par 
    def _extract_json(self, text: str) -> Optional[dict]:\par 
        # Try direct parse\par 
        try:\par 
            return json.loads(text)\par 
        except json.JSONDecodeError:\par 
            pass\par 
\par 
        # Try markdown code block\par 
        json_match = re.search(r'```(?:json)?\\s*\\n?(.*?)\\n?```', text, re.DOTALL)\par 
        if json_match:\par 
            try:\par 
                return json.loads(json_match.group(1))\par 
            except json.JSONDecodeError:\par 
                pass\par 
\par 
        # Try first \{ to last \}\par 
        first_brace = text.find('\{')\par 
        last_brace = text.rfind('\}')\par 
        if first_brace != -1 and last_brace != -1 and last_brace > first_brace:\par 
            try:\par 
                return json.loads(text[first_brace:last_brace + 1])\par 
            except json.JSONDecodeError:\par 
                pass\par 
\par 
        # Strip <think>...</think> blocks (DeepSeek-R1 reasoning traces)\par 
        cleaned = re.sub(r'<think>.*?</think>', '', text, flags=re.DOTALL).strip()\par 
        if cleaned != text:\par 
            return self._extract_json(cleaned)\par 
\par 
        logger.error(f"Failed to extract JSON from response: \{text[:300]\}...")\par 
        return None\par 
\par 
    @staticmethod\par 
    def _normalize_tactic(tactic: str) -> str:\par 
        return str(tactic or "").lower().strip().replace(" ", "-")\par 
\par 
    def _rebalance_tactic_coverage(\par 
        self,\par 
        parsed_chain: dict,\par 
        retrieved_techniques: list[dict],\par 
        chain_length: int,\par 
    ) -> tuple[dict, list[str]]:\par 
        warnings = []\par 
        if chain_length < len(self.MITRE_TACTICS):\par 
            return parsed_chain, warnings\par 
\par 
        chain = parsed_chain.get("attack_chain", [])\par 
        if not isinstance(chain, list) or not chain:\par 
            return parsed_chain, warnings\par 
\par 
        tactic_counts: dict[str, int] = \{\}\par 
        for step in chain:\par 
            t = self._normalize_tactic(step.get("tactic", ""))\par 
            if t:\par 
                tactic_counts[t] = tactic_counts.get(t, 0) + 1\par 
\par 
        missing_tactics = [\par 
            t for t in self.MITRE_TACTICS\par 
            if t not in tactic_counts\par 
        ]\par 
        if not missing_tactics:\par 
            return parsed_chain, warnings\par 
\par 
        by_tactic: dict[str, dict] = \{\}\par 
        for tech in retrieved_techniques:\par 
            tactics = tech.get("tactics", [])\par 
            if isinstance(tactics, str):\par 
                tactics = [x.strip() for x in tactics.split(",") if x.strip()]\par 
            for tactic in tactics:\par 
                t = self._normalize_tactic(tactic)\par 
                if t in self.MITRE_TACTICS and t not in by_tactic:\par 
                    by_tactic[t] = tech\par 
\par 
        # Pull additional candidates for missing tactics if not present.\par 
        for missing in missing_tactics:\par 
            if missing in by_tactic:\par 
                continue\par 
            try:\par 
                extra = self.retrieve(\par 
                    scenario=f"MITRE ATT&CK techniques for tactic \{missing.replace('-', ' ')\}",\par 
                    top_k=8,\par 
                    tactic_filter=missing,\par 
                )\par 
                if extra:\par 
                    by_tactic[missing] = extra[0]\par 
            except Exception:\par 
                continue\par 
\par 
        duplicate_indices = []\par 
        seen: dict[str, int] = \{\}\par 
        for idx, step in enumerate(chain):\par 
            t = self._normalize_tactic(step.get("tactic", ""))\par 
            seen[t] = seen.get(t, 0) + 1\par 
            if not t or t not in self.MITRE_TACTICS or seen[t] > 1:\par 
                duplicate_indices.append(idx)\par 
\par 
        used_ids = \{step.get("technique_id", "") for step in chain\}\par 
\par 
        for missing in missing_tactics:\par 
            candidate = by_tactic.get(missing)\par 
            if not candidate:\par 
                continue\par 
            if duplicate_indices:\par 
                idx = duplicate_indices.pop(0)\par 
                step = chain[idx]\par 
                step["technique_id"] = candidate.get("technique_id", step.get("technique_id", ""))\par 
                step["technique_name"] = candidate.get("name", step.get("technique_name", ""))\par 
                step["tactic"] = missing\par 
                step["description"] = candidate.get("description_preview", step.get("description", ""))\par 
                step["rationale"] = step.get("rationale") or f"Adjusted to ensure full tactic coverage for \{missing\}."\par 
                used_ids.add(step.get("technique_id", ""))\par 
            elif len(chain) < chain_length:\par 
                chain.append(\par 
                    \{\par 
                        "step": len(chain) + 1,\par 
                        "technique_id": candidate.get("technique_id", ""),\par 
                        "technique_name": candidate.get("name", "Unknown"),\par 
                        "tactic": missing,\par 
                        "description": candidate.get("description_preview", "Coverage-added tactic step."),\par 
                        "rationale": f"Added to maintain complete ATT&CK lifecycle coverage for \{missing\}.",\par 
                        "prerequisites": [],\par 
                        "detection_considerations": "",\par 
                        "mitigation": "",\par 
                        "tool_commands": [],\par 
                    \}\par 
                )\par 
                used_ids.add(candidate.get("technique_id", ""))\par 
\par 
        # Re-number steps after any replacements/appends.\par 
        for i, step in enumerate(chain, 1):\par 
            step["step"] = i\par 
\par 
        final_tactics = \{\par 
            self._normalize_tactic(step.get("tactic", ""))\par 
            for step in chain\par 
            if step.get("tactic")\par 
        \}\par 
        final_covered = len(final_tactics & set(self.MITRE_TACTICS))\par 
        if final_covered < len(self.MITRE_TACTICS):\par 
            warnings.append(\par 
                f"Tactic coverage after balancing is \{final_covered\}/\{len(self.MITRE_TACTICS)\}. "\par 
                "Scenario relevance may naturally omit some tactics."\par 
            )\par 
\par 
        return parsed_chain, warnings\par 
\par 
    def generate_attack_chain(\par 
        self,\par 
        scenario: str,\par 
        target_environment: str = "Enterprise Windows Active Directory network",\par 
        chain_length: int = None,\par 
        top_k: int = None,\par 
        tactic_filter: Optional[str] = None,\par 
        platform_filter: Optional[str] = None,\par 
    ) -> dict:\par 
        if chain_length is None:\par 
            chain_length = config.DEFAULT_CHAIN_LENGTH\par 
\par 
        # Required bounds for multi-step prompts.\par 
        if int(chain_length or 1) <= 1:\par 
            chain_length = 1\par 
        else:\par 
            chain_length = max(8, min(int(getattr(config, "MAX_CHAIN_LENGTH", 14)), int(chain_length)))\par 
\par 
        pipeline_start = time.perf_counter()\par 
        latency_metrics = \{"pipeline_start": pipeline_start\}\par 
\par 
        # Sanitize user input\par 
        try:\par 
            scenario = sanitize_scenario(scenario)\par 
        except ValueError as e:\par 
            raise ValueError(f"Input sanitization failed: \{e\}")\par 
\par 
        # Phase 1: Retrieve\par 
        logger.info(f"\{'='*60\}")\par 
        logger.info(f"PHASE 1: RETRIEVAL")\par 
        logger.info(f"\{'='*60\}")\par 
\par 
        retrieve_start = time.perf_counter()\par 
        use_diverse = bool(getattr(config, "RAG_USE_DIVERSE_RETRIEVAL", False))\par 
        if use_diverse and not tactic_filter and not platform_filter:\par 
            retrieved = self.vector_store.query_diverse(query_text=scenario, top_k=top_k)\par 
        else:\par 
            wide_k = top_k\par 
            if wide_k is None:\par 
                wide_k = int(getattr(config, "RAG_RETRIEVAL_TOP_K_WIDE", getattr(config, "DIVERSITY_TOP_K_WIDE", 30)))\par 
            retrieved = self.retrieve(\par 
                scenario=scenario,\par 
                top_k=wide_k,\par 
                tactic_filter=tactic_filter,\par 
                platform_filter=platform_filter,\par 
                max_query_variants=int(getattr(config, "RAG_MAX_QUERY_VARIANTS", 0)) or None,\par 
            )\par 
        latency_metrics["retrieval_time_s"] = time.perf_counter() - retrieve_start\par 
\par 
        if not retrieved:\par 
            raise ValueError(\par 
                "No techniques retrieved. Check that the vector store is indexed "\par 
                "and the query is relevant."\par 
            )\par 
\par 
        # Phase 2: Augment prompt\par 
        logger.info(f"\{'='*60\}")\par 
        logger.info(f"PHASE 2: PROMPT AUGMENTATION")\par 
        logger.info(f"\{'='*60\}")\par 
\par 
        augment_start = time.perf_counter()\par 
        system_prompt, user_prompt = self.build_prompt(\par 
            scenario=scenario,\par 
            target_environment=target_environment,\par 
            retrieved_techniques=retrieved,\par 
            chain_length=chain_length,\par 
        )\par 
        latency_metrics["augmentation_time_s"] = time.perf_counter() - augment_start\par 
\par 
        # Phase 3: Generate\par 
        logger.info(f"\{'='*60\}")\par 
        logger.info(f"PHASE 3: LLM GENERATION")\par 
        logger.info(f"\{'='*60\}")\par 
\par 
        # Phase 4: Validate + mandatory retries (max 2 retries)\par 
        logger.info(f"\{'='*60\}")\par 
        logger.info(f"PHASE 4: VALIDATION & FAITHFULNESS CHECK")\par 
        logger.info(f"\{'='*60\}")\par 
\par 
        validate_start = time.perf_counter()\par 
        max_attempts = 3\par 
        last_error: Optional[BaseException] = None\par 
        parsed_chain: Optional[dict] = None\par 
        warnings: list[str] = []\par 
        gen_latency: dict = \{\}\par 
\par 
        for attempt in range(1, max_attempts + 1):\par 
            try:\par 
                retry_note = ""\par 
                if attempt > 1:\par 
                    retry_note = (\par 
                        "\\n\\nRETRY: Your previous output was invalid or too short. "\par 
                        f"Return STRICT JSON only and include \{max(8, min(chain_length, 14))\} to \{min(chain_length, 14)\} steps."\par 
                    )\par 
\par 
                raw_response, gen_latency = self.generate(\par 
                    system_prompt,\par 
                    user_prompt + retry_note,\par 
                    temperature_override=(0.0 if attempt > 1 else None),\par 
                    max_tokens_override=int(getattr(config, "LLM_MAX_TOKENS", 512)),\par 
                )\par 
\par 
                if raw_response is None or not str(raw_response).strip():\par 
                    raise ValueError("Empty model output")\par 
\par 
                parsed_chain, warnings = self.validate_response(raw_response, retrieved)\par 
\par 
                chain = parsed_chain.get("attack_chain", []) if isinstance(parsed_chain, dict) else []\par 
                if not isinstance(chain, list):\par 
                    raise ValueError("Invalid attack_chain shape")\par 
\par 
                min_steps_required = 1 if chain_length <= 1 else max(8, min(chain_length, 14))\par 
                if len(chain) < min_steps_required:\par 
                    raise ValueError(f"Generated chain too short: \{len(chain)\} < \{min_steps_required\}")\par 
\par 
                if chain_length > 1:\par 
                    grounded_steps = self._count_grounded_steps(chain, retrieved)\par 
                    if grounded_steps < 3:\par 
                        raise ValueError(f"Not enough context-grounded steps: \{grounded_steps\} < 3")\par 
\par 
                break\par 
            except Exception as e:  # noqa: BLE001\par 
                last_error = e\par 
                parsed_chain = None\par 
                warnings = []\par 
                if attempt >= max_attempts:\par 
                    raise\par 
                logger.warning("Validation failed (attempt %d/%d): %s", attempt, max_attempts, str(e)[:300])\par 
\par 
        latency_metrics.update(gen_latency)\par 
\par 
        # Enforce step count constraints (stability + multi-step quality).\par 
        chain = parsed_chain.get("attack_chain", [])\par 
        if isinstance(chain, list) and chain_length:\par 
            if len(chain) > chain_length:\par 
                parsed_chain["attack_chain"] = chain[:chain_length]\par 
            min_steps = 1 if chain_length <= 1 else max(8, min(chain_length, 14))\par 
            if len(parsed_chain.get("attack_chain", [])) < min_steps:\par 
                raise ValueError(\par 
                    f"Generated chain too short: \{len(parsed_chain.get('attack_chain', []))\} < \{min_steps\}"\par 
                )\par 
        parsed_chain, coverage_warnings = self._rebalance_tactic_coverage(\par 
            parsed_chain=parsed_chain,\par 
            retrieved_techniques=retrieved,\par 
            chain_length=chain_length,\par 
        )\par 
        warnings.extend(coverage_warnings)\par 
        latency_metrics["validation_time_s"] = time.perf_counter() - validate_start\par 
\par 
        # Calculate faithfulness score\par 
        retrieved_ids = \{t.get("technique_id", "") for t in retrieved\}\par 
        retrieved_bases = \{tid.split(".")[0] for tid in retrieved_ids if tid\}\par 
        chain_steps = parsed_chain.get("attack_chain", [])\par 
        total_steps = len(chain_steps)\par 
        grounded_steps = 0\par 
        for step in chain_steps:\par 
            tid = str(step.get("technique_id", "")).strip()\par 
            if not tid:\par 
                continue\par 
            if tid in retrieved_ids or tid.split(".")[0] in retrieved_bases:\par 
                grounded_steps += 1\par 
        faithfulness_score = grounded_steps / total_steps if total_steps else 0.0\par 
\par 
        # Enrich each step with mitigations and tool commands\par 
        for step in parsed_chain.get("attack_chain", []):\par 
            tid = step.get("technique_id", "")\par 
            if not step.get("mitigation"):\par 
                mit = get_mitigation(tid)\par 
                step["mitigation"] = f"\{mit['name']\}: \{mit['description']\}"\par 
            if not step.get("tool_commands"):\par 
                tools_info = get_tools(tid)\par 
                step["tool_commands"] = tools_info.get("commands", [])[:3]\par 
\par 
        latency_metrics["pipeline_total_s"] = time.perf_counter() - pipeline_start\par 
\par 
        logger.info(f"\{'='*60\}")\par 
        logger.info(f"PIPELINE COMPLETE")\par 
        logger.info(\par 
            f"Total: \{latency_metrics['pipeline_total_s']:.2f\}s | "\par 
            f"Retrieval: \{latency_metrics['retrieval_time_s']*1000:.0f\}ms | "\par 
            f"Generation: \{latency_metrics.get('llm_latency_s', 0):.2f\}s | "\par 
            f"Faithfulness: \{faithfulness_score:.0%\}"\par 
        )\par 
        logger.info(f"\{'='*60\}")\par 
\par 
        return \{\par 
            "attack_chain": parsed_chain,\par 
            "retrieval_results": [\par 
                \{\par 
                    "technique_id": r["technique_id"],\par 
                    "name": r["name"],\par 
                    "relevance_score": r.get("relevance_score"),\par 
                    "tactics": r.get("tactics"),\par 
                    "description": r.get("description_preview", ""),\par 
                \}\par 
                for r in retrieved\par 
            ],\par 
            "latency": latency_metrics,\par 
            "warnings": warnings,\par 
            "faithfulness_score": faithfulness_score,\par 
            "scenario": scenario,\par 
            "target_environment": target_environment,\par 
            "timestamp": datetime.now(timezone.utc).isoformat(),\par 
        \}\par 
\par 
    def generate_attack_chain_fast(\par 
        self,\par 
        scenario: str,\par 
        target_environment: str = "Enterprise Windows Active Directory network",\par 
        chain_length: int = None,\par 
        top_k: int = None,\par 
        tactic_filter: Optional[str] = None,\par 
        platform_filter: Optional[str] = None,\par 
    ) -> dict:\par 
        pipeline_start = time.perf_counter()\par 
        latency_metrics = \{"pipeline_start": pipeline_start\}\par 
\par 
        try:\par 
            scenario = sanitize_scenario(scenario)\par 
        except ValueError as e:\par 
            raise ValueError(f"Input sanitization failed: \{e\}")\par 
\par 
        retrieve_start = time.perf_counter()\par 
        normalized_len = None\par 
        if chain_length is not None:\par 
            try:\par 
                normalized_len = int(chain_length)\par 
            except Exception:\par 
                normalized_len = None\par 
\par 
        if normalized_len is not None:\par 
            normalized_len = max(1, min(int(getattr(config, "MAX_CHAIN_LENGTH", 14)), normalized_len))\par 
\par 
        wide_k = top_k\par 
        if wide_k is None:\par 
            base = normalized_len or int(getattr(config, "DEFAULT_CHAIN_LENGTH", 10))\par 
            wide_k = max(int(getattr(config, "RAG_RETRIEVAL_TOP_K_WIDE", 18)), base * 2)\par 
\par 
        use_diverse = bool(getattr(config, "RAG_USE_DIVERSE_RETRIEVAL", False))\par 
        if use_diverse and not tactic_filter and not platform_filter:\par 
            retrieved = self.vector_store.query_diverse(query_text=scenario, top_k=wide_k)\par 
        else:\par 
            retrieved = self.retrieve(\par 
                scenario=scenario,\par 
                top_k=wide_k,\par 
                tactic_filter=tactic_filter,\par 
                platform_filter=platform_filter,\par 
                max_query_variants=int(getattr(config, "RAG_MAX_QUERY_VARIANTS", 0)) or None,\par 
            )\par 
\par 
        latency_metrics["retrieval_time_s"] = time.perf_counter() - retrieve_start\par 
        if not retrieved:\par 
            raise ValueError("No techniques retrieved. Check that the vector store is indexed.")\par 
\par 
        if normalized_len is None:\par 
            normalized_len = min(8, len(retrieved))\par 
            normalized_len = max(1, normalized_len)\par 
\par 
        candidates = self._select_context_techniques(\par 
            scenario=scenario,\par 
            techniques=retrieved,\par 
            desired_count=min(len(retrieved), max(normalized_len * 2, 12)),\par 
            chain_length=normalized_len,\par 
        )\par 
\par 
        def _tactics_for(tech: dict) -> list[str]:\par 
            tactics = tech.get("tactics", [])\par 
            if isinstance(tactics, str):\par 
                tactics = [x.strip() for x in tactics.split(",") if x.strip()]\par 
            return [self._normalize_tactic(t) for t in (tactics or []) if t]\par 
\par 
        def _score(tech: dict) -> float:\par 
            return float(tech.get("_combined_score", tech.get("relevance_score", 0.0)) or 0.0)\par 
\par 
        ranked = sorted(candidates, key=_score, reverse=True)\par 
        selected: list[dict] = []\par 
        used_ids: set[str] = set()\par 
\par 
        # Favor kill-chain ordering where possible.\par 
        for tactic in self.MITRE_TACTICS:\par 
            for tech in ranked:\par 
                tid = str(tech.get("technique_id") or "").strip().upper()\par 
                if not tid or tid in used_ids:\par 
                    continue\par 
                if tactic in _tactics_for(tech):\par 
                    selected.append(\{"tech": tech, "tactic": tactic\})\par 
                    used_ids.add(tid)\par 
                    break\par 
            if len(selected) >= normalized_len:\par 
                break\par 
\par 
        # Fill remaining slots by relevance.\par 
        for tech in ranked:\par 
            if len(selected) >= normalized_len:\par 
                break\par 
            tid = str(tech.get("technique_id") or "").strip().upper()\par 
            if not tid or tid in used_ids:\par 
                continue\par 
            tactics = _tactics_for(tech)\par 
            selected.append(\{"tech": tech, "tactic": tactics[0] if tactics else "unknown"\})\par 
            used_ids.add(tid)\par 
\par 
        chain_steps = []\par 
        for i, item in enumerate(selected, 1):\par 
            tech = item["tech"]\par 
            tid = str(tech.get("technique_id") or "").strip().upper()\par 
            tactic = item.get("tactic") or "unknown"\par 
            description = tech.get("description_preview") or tech.get("document") or "Retrieved ATT&CK technique aligned to scenario."\par 
            step = \{\par 
                "step": i,\par 
                "technique_id": tid,\par 
                "technique_name": tech.get("name", "Unknown"),\par 
                "tactic": tactic,\par 
                "description": description,\par 
                "rationale": "Derived from RAG retrieval for the provided scenario.",\par 
                "prerequisites": [],\par 
                "detection_considerations": "",\par 
                "mitigation": "",\par 
                "tool_commands": [],\par 
            \}\par 
            mit = get_mitigation(tid)\par 
            if mit.get("name"):\par 
                step["mitigation"] = f"\{mit['name']\}: \{mit.get('description', '')\}".strip()\par 
            tools_info = get_tools(tid)\par 
            step["tool_commands"] = (tools_info.get("commands", []) or [])[:3]\par 
            chain_steps.append(step)\par 
\par 
        warnings: list[str] = []\par 
        if len(chain_steps) < normalized_len:\par 
            warnings.append(\par 
                f"Only \{len(chain_steps)\} techniques available for fast mode; requested \{normalized_len\}."\par 
            )\par 
\par 
        latency_metrics["pipeline_total_s"] = time.perf_counter() - pipeline_start\par 
        latency_metrics["llm_latency_s"] = 0.0\par 
\par 
        parsed_chain = \{\par 
            "attack_chain": chain_steps,\par 
            "metadata": \{\par 
                "scenario": scenario,\par 
                "target_environment": target_environment,\par 
                "chain_length": normalized_len,\par 
                "techniques_used": len(chain_steps),\par 
                "generation_mode": "fast",\par 
            \},\par 
        \}\par 
\par 
        return \{\par 
            "attack_chain": parsed_chain,\par 
            "retrieval_results": [\par 
                \{\par 
                    "technique_id": r["technique_id"],\par 
                    "name": r["name"],\par 
                    "relevance_score": r.get("relevance_score"),\par 
                    "tactics": r.get("tactics"),\par 
                    "description": r.get("description_preview", ""),\par 
                \}\par 
                for r in retrieved\par 
            ],\par 
            "latency": latency_metrics,\par 
            "warnings": warnings,\par 
            "faithfulness_score": 1.0,\par 
            "scenario": scenario,\par 
            "target_environment": target_environment,\par 
            "timestamp": datetime.now(timezone.utc).isoformat(),\par 
        \}\par 
\par 
