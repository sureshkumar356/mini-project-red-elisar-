def _probe_sqli(base: str, timeout_s: float) -> dict:\par 
    payloads = [\par 
        ("' OR '1'='1", "shows all results ├втВмтАЭ authentication bypass"),\par 
        ("' OR '1'='1'--", "comments out password check"),\par 
