            "hnsw_efConstruction": config.FAISS_HNSW_EF_CONSTRUCTION,\par 
            "index_path": str(self._index_path),\par 
            "index_exists": self._index_path.exists(),\par 
        \}\par 
\par 
    def is_ready(self) -> bool:\par 
        """Compatibility helper for callers expecting a readiness check."""\par 
        if not self._index_path.exists() or not self._metadata_path.exists():\par 
            return False\par 
        try:\par 
            self._load_index()\par 
            return self._index is not None and self._index.ntotal > 0\par 
        except Exception:\par 
            return False\par 
\par 
    def load(self):\par 
        """Compatibility helper for callers expecting an explicit load method."""\par 
        self._load_index()\par 
        return self\par 
\par 
    def reset(self):\par 
