class MitreAttackDatabase:\par 
    """Minimal MITRE ATT&CK STIX reader for technique/tactic/tools enrichment."""\par 
\par 
    def __init__(self, stix_path: Path):\par 
        self.stix_path = stix_path\par 
        self.technique_index: dict[str, dict[str, Any]] = \{\}\par 
        self.technique_stix_to_external: dict[str, str] = \{\}\par 
        self.software_index: dict[str, dict[str, str]] = \{\}\par 
        self.tools_by_technique: dict[str, list[dict[str, str]]] = \{\}\par 
        self.tactic_id_to_name: dict[str, str] = \{\}\par 
        self.tactic_order: list[str] = []\par 
        self._loaded = False\par 
        self._load()\par 
\par 
    def _load(self) -> None:\par 
        self._loaded = True\par 
        if not self.stix_path.exists():\par 
            return\par 
        try:\par 
            bundle = json.loads(self.stix_path.read_text(encoding="utf-8"))\par 
        except Exception:\par 
            return\par 
\par 
        objects = bundle.get("objects", []) if isinstance(bundle, dict) else []\par 
        software_types = \{"tool", "malware"\}\par 
\par 
        for obj in objects:\par 
            if obj.get("type") == "x-mitre-tactic":\par 
                self.tactic_id_to_name[obj.get("id", "")] = str(obj.get("name", "")).strip().lower()\par 
\par 
        # Build tactic sequence from ATT&CK matrix ordering in STIX (no hardcoded stage order).\par 
        for obj in objects:\par 
            if obj.get("type") != "x-mitre-matrix":\par 
                continue\par 
            refs = obj.get("tactic_refs", [])\par 
            ordered = []\par 
            for ref in refs:\par 
                nm = self.tactic_id_to_name.get(ref)\par 
                if nm:\par 
                    ordered.append(nm)\par 
            if ordered:\par 
                self.tactic_order = ordered\par 
                break\par 
\par 
        for obj in objects:\par 
            otype = obj.get("type")\par 
            if otype in software_types:\par 
                self.software_index[obj.get("id", "")] = \{\par 
                    "name": obj.get("name", "Unknown Tool"),\par 
                    "description": (obj.get("description", "") or "").strip(),\par 
                \}\par 
\par 
        for obj in objects:\par 
            if obj.get("type") != "attack-pattern":\par 
                continue\par 
            ext_id = ""\par 
            for ref in obj.get("external_references", []):\par 
                eid = str(ref.get("external_id", "")).strip()\par 
                if eid.startswith("T"):\par 
                    ext_id = eid\par 
                    break\par 
            if not ext_id:\par 
                continue\par 
\par 
            tactics = []\par 
            for phase in obj.get("kill_chain_phases", []):\par 
                if phase.get("kill_chain_name") == "mitre-attack":\par 
                    pname = str(phase.get("phase_name", "")).strip()\par 
                    if pname:\par 
                        tactics.append(pname)\par 
\par 
            self.technique_index[ext_id] = \{\par 
                "technique_id": ext_id,\par 
                "technique_name": obj.get("name", "Unknown Technique"),\par 
                "description": (obj.get("description", "") or "").strip(),\par 
                "tactics": sorted(set(tactics)),\par 
                "stix_id": obj.get("id", ""),\par 
            \}\par 
            self.technique_stix_to_external[obj.get("id", "")] = ext_id\par 
\par 
        temp_tools: dict[str, dict[str, dict[str, str]]] = \{\}\par 
        for obj in objects:\par 
            if obj.get("type") != "relationship":\par 
                continue\par 
            if obj.get("relationship_type") != "uses":\par 
                continue\par 
            target_ref = obj.get("target_ref", "")\par 
            source_ref = obj.get("source_ref", "")\par 
            technique_id = self.technique_stix_to_external.get(target_ref)\par 
            software = self.software_index.get(source_ref)\par 
            if not technique_id or not software:\par 
                continue\par 
            bucket = temp_tools.setdefault(technique_id, \{\})\par 
            bucket[software.get("name", "Unknown Tool")] = software\par 
\par 
        self.tools_by_technique = \{\par 
            tid: list(name_map.values()) for tid, name_map in temp_tools.items()\par 
        \}\par 
\par 
    def get_technique(self, technique_id: str) -> dict[str, Any]:\par 
        return self.technique_index.get(technique_id, \{\})\par 
\par 
    def get_tools_for_technique(self, technique_id: str) -> list[dict[str, str]]:\par 
        return list(self.tools_by_technique.get(technique_id, []))\par 
\par 
    def tactic_rank(self, tactic: str) -> int:\par 
        key = str(tactic or "").strip().lower()\par 
        if key in self.tactic_order:\par 
            return self.tactic_order.index(key)\par 
        return 10_000\par 
\par 
\par 
def normalize_url(url: str) -> str:\par 
    raw = (url or "").strip()\par 
    if not raw:\par 
        raise ValueError("URL cannot be empty.")\par 
    if not raw.startswith(("http://", "https://")):\par 
        raw = f"http://\{raw\}"\par 
    parsed = urlparse(raw)\par 
    if not parsed.netloc:\par 
        raise ValueError(f"Invalid URL: \{url\}")\par 
    return raw.rstrip("/")\par 
\par 
\par 
def same_host(a: str, b: str) -> bool:\par 
    return urlparse(a).netloc == urlparse(b).netloc\par 
\par 
\par 
def canonicalize(url: str) -> str:\par 
    p = urlparse(url)\par 
    query = urlencode(sorted(parse_qsl(p.query, keep_blank_values=True)))\par 
    return urlunparse((p.scheme, p.netloc, p.path.rstrip("/") or "/", "", query, ""))\par 
\par 
\par 
def parse_html_links_and_forms(base_url: str, html: str) -> tuple[set[str], list[dict[str, Any]]]:\par 
    links: set[str] = set()\par 
    forms: list[dict[str, Any]] = []\par 
\par 
    if BeautifulSoup is not None:\par 
        soup = BeautifulSoup(html, "html.parser")\par 
        for anchor in soup.find_all("a", href=True):\par 
            href = str(anchor.get("href", "")).strip()\par 
            if not href or href.startswith(("javascript:", "mailto:", "#")):\par 
                continue\par 
            links.add(urljoin(base_url + "/", href))\par 
\par 
        for form in soup.find_all("form"):\par 
            action = str(form.get("action") or "").strip() or base_url\par 
            method = str(form.get("method") or "GET").upper()\par 
            inputs = []\par 
            for inp in form.find_all(["input", "textarea", "select"]):\par 
                name = inp.get("name")\par 
                if name:\par 
                    inputs.append(str(name))\par 
            forms.append(\par 
                \{\par 
                    "action": urljoin(base_url + "/", action),\par 
                    "method": method,\par 
                    "params": sorted(set(inputs)),\par 
                \}\par 
            )\par 
        return links, forms\par 
\par 
    # Regex fallback for environments without bs4.\par 
    for match in re.findall(r"href=[\\"']([^\\"']+)[\\"']", html, flags=re.IGNORECASE):\par 
        href = match.strip()\par 
        if href and not href.startswith(("javascript:", "mailto:", "#")):\par 
            links.add(urljoin(base_url + "/", href))\par 
\par 
    for match in re.finditer(r"<form\\b([^>]*)>(.*?)</form>", html, flags=re.IGNORECASE | re.DOTALL):\par 
        form_attrs = match.group(1) or ""\par 
        form_body = match.group(2) or ""\par 
\par 
        method_m = re.search(r"\\bmethod\\s*=\\s*[\\"']?([^\\"' >]+)", form_attrs, flags=re.IGNORECASE)\par 
        action_m = re.search(r"\\baction\\s*=\\s*[\\"']?([^\\"' >]+)", form_attrs, flags=re.IGNORECASE)\par 
\par 
        method = (method_m.group(1) if method_m else "GET").upper()\par 
        action = (action_m.group(1) if action_m else "").strip() or base_url\par 
\par 
        params = sorted(\par 
            \{\par 
                p.strip()\par 
                for p in re.findall(\par 
                    r"<(?:input|textarea|select)[^>]*\\bname\\s*=\\s*[\\"']?([^\\"' >]+)",\par 
                    form_body,\par 
                    flags=re.IGNORECASE,\par 
                )\par 
                if p.strip()\par 
            \}\par 
        )\par 
\par 
        forms.append(\par 
            \{\par 
                "action": urljoin(base_url + "/", action),\par 
                "method": method,\par 
                "params": params,\par 
            \}\par 
        )\par 
\par 
    return links, forms\par 
\par 
\par 
def discover_attack_surface(base_url: str, max_pages: int = 30, timeout: int = 8) -> dict[str, Any]:\par 
    """Discover routes dynamically via crawl + form detection + common-path probing."""\par 
    session = requests.Session()\par 
    visited: set[str] = set()\par 
    discovered_routes: set[str] = set()\par 
    discovered_forms: list[dict[str, Any]] = []\par 
    params_by_route: dict[str, set[str]] = \{\}\par 
    queue = deque([base_url])\par 
\par 
    while queue and len(visited) < max_pages:\par 
        current = canonicalize(queue.popleft())\par 
        if current in visited:\par 
            continue\par 
        visited.add(current)\par 
\par 
        try:\par 
            resp = session.get(current, timeout=timeout, allow_redirects=True)\par 
        except Exception:\par 
            continue\par 
\par 
        if resp.status_code >= 500:\par 
            continue\par 
\par 
        discovered_routes.add(canonicalize(resp.url))\par 
\par 
        parsed = urlparse(resp.url)\par 
        if parsed.query:\par 
            params_by_route.setdefault(canonicalize(resp.url.split("?")[0]), set()).update(\par 
                [k for k, _ in parse_qsl(parsed.query, keep_blank_values=True)]\par 
            )\par 
\par 
        content_type = (resp.headers.get("Content-Type") or "").lower()\par 
        if "text/html" not in content_type:\par 
            continue\par 
\par 
        links, forms = parse_html_links_and_forms(resp.url, resp.text)\par 
        for form in forms:\par 
            form_action = canonicalize(form["action"])\par 
            discovered_routes.add(form_action)\par 
            discovered_forms.append(form)\par 
            params_by_route.setdefault(form_action, set()).update(form.get("params", []))\par 
\par 
        for candidate in links:\par 
            if not candidate.startswith(("http://", "https://")):\par 
                continue\par 
            if same_host(base_url, candidate):\par 
                c = canonicalize(candidate)\par 
                discovered_routes.add(c)\par 
                if c not in visited:\par 
                    queue.append(c)\par 
\par 
    # Common path probing for additional reachable endpoints.\par 
    for path in COMMON_PATHS:\par 
        test_url = canonicalize(urljoin(base_url + "/", path.lstrip("/")))\par 
        if test_url in discovered_routes:\par 
            continue\par 
        try:\par 
            r = session.get(test_url, timeout=timeout, allow_redirects=False)\par 
            if r.status_code < 400:\par 
                discovered_routes.add(test_url)\par 
        except Exception:\par 
            continue\par 
\par 
    route_params: dict[str, list[str]] = \{\par 
        route: sorted(v) for route, v in params_by_route.items() if v\par 
    \}\par 
\par 
    return \{\par 
        "base_url": base_url,\par 
        "visited_pages": sorted(visited),\par 
        "routes": sorted(discovered_routes),\par 
        "forms": discovered_forms,\par 
        "params_by_route": route_params,\par 
    \}\par 
\par 
\par 
def _merge_vulnerabilities(*groups: list[dict[str, Any]]) -> list[dict[str, Any]]:\par 
    merged_by_key: dict[str, dict[str, Any]] = \{\}\par 
    severity_rank = \{"CRITICAL": 5, "HIGH": 4, "MEDIUM": 3, "LOW": 2, "INFO": 1\}\par 
\par 
    def endpoint_key(v: dict[str, Any]) -> str:\par 
        def normalize_endpoint(u: str) -> str:\par 
            p = urlparse(u)\par 
            if p.scheme and p.netloc:\par 
                return urlunparse((p.scheme, p.netloc, p.path.rstrip("/") or "/", "", "", ""))\par 
            return u\par 
\par 
        direct = str(v.get("endpoint", "")).strip()\par 
        if direct:\par 
            try:\par 
                return normalize_endpoint(direct)\par 
            except Exception:\par 
                return direct\par 
        inferred = _infer_affected_url(v, "")\par 
        if inferred:\par 
            try:\par 
                return normalize_endpoint(inferred)\par 
            except Exception:\par 
                return inferred\par 
        return "unknown-endpoint"\par 
\par 
    def split_evidence(text: str) -> list[str]:\par 
        if not text:\par 
            return []\par 
        return [p.strip() for p in re.split(r"\\n|\\s+\\|\\s+|\\s*;\\s*", text) if p.strip()]\par 
\par 
    def normalize_type(vtype: str) -> str:\par 
        t = (vtype or "Unknown").strip()\par 
        t = re.sub(r"\\s*\\([^)]*\\)", "", t).strip()\par 
        low = t.lower()\par 
        if "sql injection" in low:\par 
            return "SQL Injection"\par 
        if "cross-site scripting" in low or "xss" in low:\par 
            return "Reflected Cross-Site Scripting (XSS)"\par 
        if "sensitive file" in low or "exposed sensitive resource" in low:\par 
            return "Exposed Sensitive Resource"\par 
        return t\par 
\par 
    for group in groups:\par 
        for v in group:\par 
            vtype = normalize_type(str(v.get("type", "Unknown")))\par 
            endpoint = endpoint_key(v)\par 
            key = f"\{endpoint\}::\{vtype.lower()\}"\par 
\par 
            if key not in merged_by_key:\par 
                base = dict(v)\par 
                base["type"] = vtype\par 
                base["endpoint"] = endpoint\par 
                base["_evidence_items"] = split_evidence(str(v.get("evidence", "")))\par 
                merged_by_key[key] = base\par 
                continue\par 
\par 
            curr = merged_by_key[key]\par 
            evidence_items = curr.get("_evidence_items", [])\par 
            for piece in split_evidence(str(v.get("evidence", ""))):\par 
                if piece not in evidence_items:\par 
                    evidence_items.append(piece)\par 
            curr["_evidence_items"] = evidence_items\par 
\par 
            curr_sev = severity_rank.get(str(curr.get("severity", "INFO")).upper(), 0)\par 
            new_sev = severity_rank.get(str(v.get("severity", "INFO")).upper(), 0)\par 
            if new_sev > curr_sev:\par 
                curr["severity"] = v.get("severity", curr.get("severity"))\par 
\par 
            if len(str(v.get("detail", ""))) > len(str(curr.get("detail", ""))):\par 
                curr["detail"] = v.get("detail", curr.get("detail"))\par 
            if not curr.get("mitre_hint") and v.get("mitre_hint"):\par 
                curr["mitre_hint"] = v.get("mitre_hint")\par 
            if len(str(v.get("recommendation", ""))) > len(str(curr.get("recommendation", ""))):\par 
                curr["recommendation"] = v.get("recommendation", curr.get("recommendation"))\par 
\par 
    merged: list[dict[str, Any]] = []\par 
    for item in merged_by_key.values():\par 
        evidence_items = item.pop("_evidence_items", [])\par 
        if evidence_items:\par 
            item["evidence"] = " | ".join(evidence_items)\par 
        merged.append(item)\par 
    return merged\par 
\par 
\par 
def _probe_discovered_forms(base_url: str, forms: list[dict[str, Any]], timeout: int = 8) -> list[dict[str, Any]]:\par 
    findings: list[dict[str, Any]] = []\par 
    seen: set[str] = set()\par 
    session = requests.Session()\par 
\par 
    for form in forms:\par 
        action = str(form.get("action", "")).strip()\par 
        method = str(form.get("method", "GET")).upper().strip()\par 
        params = [str(p).strip() for p in (form.get("params", []) or []) if str(p).strip()]\par 
        if not action or not params:\par 
            continue\par 
\par 
        url = action if action.startswith(("http://", "https://")) else urljoin(base_url + "/", action)\par 
\par 
        for param in params[:6]:\par 
            for payload in FORM_SQLI_PAYLOADS:\par 
                try:\par 
                    data = \{param: payload\}\par 
                    if method == "POST":\par 
                        resp = session.post(url, data=data, timeout=timeout, allow_redirects=True)\par 
                    else:\par 
                        resp = session.get(url, params=data, timeout=timeout, allow_redirects=True)\par 
                    body = (resp.text or "")[:8000].lower()\par 
                    matched = next((pat for pat in SQL_ERROR_PATTERNS if re.search(pat, body, re.IGNORECASE)), None)\par 
                    if matched:\par 
                        key = f"sqli::\{url\}::\{param\}"\par 
                        if key in seen:\par 
                            continue\par 
                        seen.add(key)\par 
                        findings.append(\par 
                            \{\par 
                                "type": "SQL Injection",\par 
                                "detail": f"Form parameter '\{param\}' at \{url\} appears SQL injectable.",\par 
                                "severity": "CRITICAL",\par 
                                "cwe_id": "CWE-89",\par 
                                "mitre_hint": "T1190",\par 
                                "recommendation": "Use parameterized queries for all database access and validate input.",\par 
                                "evidence": f"\{method\} \{url\} param=\{param\} payload=\{payload\} pattern=\{matched\}",\par 
                                "endpoint": url,\par 
                                "confirmed_live": True,\par 
                            \}\par 
                        )\par 
                except Exception:\par 
                    continue\par 
\par 
            for payload in FORM_XSS_PAYLOADS:\par 
                try:\par 
                    data = \{param: payload\}\par 
                    if method == "POST":\par 
                        resp = session.post(url, data=data, timeout=timeout, allow_redirects=True)\par 
                    else:\par 
                        resp = session.get(url, params=data, timeout=timeout, allow_redirects=True)\par 
                    body = resp.text or ""\par 
                    if payload[:20] in body or "alert('x')" in body.lower():\par 
                        key = f"xss::\{url\}::\{param\}"\par 
                        if key in seen:\par 
                            continue\par 
                        seen.add(key)\par 
                        findings.append(\par 
                            \{\par 
                                "type": "Reflected Cross-Site Scripting (XSS)",\par 
                                "detail": f"Form parameter '\{param\}' at \{url\} reflects unescaped input.",\par 
                                "severity": "HIGH",\par 
                                "cwe_id": "CWE-79",\par 
                                "mitre_hint": "T1059.007",\par 
                                "recommendation": "Apply output encoding and input validation for form parameters.",\par 
                                "evidence": f"\{method\} \{url\} param=\{param\} payload=\{payload\}",\par 
                                "endpoint": url,\par 
                                "confirmed_live": True,\par 
                            \}\par 
                        )\par 
                except Exception:\par 
                    continue\par 
\par 
    return findings\par 
\par 
