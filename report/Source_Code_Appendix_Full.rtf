@app.route("/api/cancel", methods=["POST"])\par 
def api_cancel():\par 
    data = request.get_json(force=True) or \{\}\par 
    request_id = str(data.get("request_id") or "").strip()\par 
    if not request_id:\par 
        return jsonify(\{"error": "request_id is required"\}), 400\par 
    with _cancel_lock:\par 
        ev = _cancel_events.get(request_id)\par 
        if ev is None:\par 
            return jsonify(\{"status": "not_found", "request_id": request_id\}), 404\par 
        ev.set()\par 
    return jsonify(\{"status": "cancelled", "request_id": request_id\})\par 
