\par 
    def run_full_check(self) -> dict:\par 
        """\par 
        Execute all real-time vulnerability checks and return a structured\par 
        report. Nothing is assumed ├втВмтАЭ every finding is confirmed live.\par 
        """\par 
        t_start = time.perf_counter()\par 
        print(f"\\n\{'='*65\}")\par 
        print(f"  RED ELISAR ├втВмтАЭ LIVE VULNERABILITY CHECKER")\par 
        print(f"  Target : \{self.target\}")\par 
        print(f"  Time   : \{self.scan_start\}")\par 
        print(f"\{'='*65\}\\n")\par 
\par 
        # Verify reachability first\par 
        if not self._verify_reachable():\par 
            return self._build_report(elapsed=time.perf_counter() - t_start,\par 
                                       error="Target not reachable")\par 
\par 
        # Run all checks in sequence\par 
        checks = [\par 
            ("[1/12] Security Headers",          self._check_security_headers),\par 
            ("[2/12] Server Banner Leakage",      self._check_server_banners),\par 
            ("[3/12] CORS Misconfiguration",      self._check_cors),\par 
            ("[4/12] Sensitive File Disclosure",  self._check_sensitive_paths),\par 
            ("[5/12] SQL Injection",              self._check_sql_injection),\par 
            ("[6/12] Reflected XSS",             self._check_xss),\par 
            ("[7/12] Open Redirect",             self._check_open_redirect),\par 
            ("[8/12] Auth Bypass (SQLi Login)",  self._check_auth_bypass),\par 
            ("[9/12] Unauthenticated Admin",     self._check_unauth_admin),\par 
            ("[10/12] Error Information Leakage", self._check_error_leakage),\par 
            ("[11/12] Cookie Security Flags",    self._check_cookie_flags),\par 
            ("[12/12] HTTP vs HTTPS",            self._check_http_scheme),\par 
        ]\par 
\par 
        for label, fn in checks:\par 
            print(f"  \{label\} ...", end="", flush=True)\par 
            try:\par 
                fn()\par 
                count_for_step = sum(\par 
                    1 for f in self.findings\par 
                    if f.get("_check") == fn.__name__\par 
                )\par 
                print(f" \{'FOUND ' + str(count_for_step) if count_for_step else 'clean'\}")\par 
            except Exception as e:\par 
                logger.warning(f"Check failed (\{label\}): \{e\}")\par 
                print(f" ERROR: \{e\}")\par 
\par 
        elapsed = time.perf_counter() - t_start\par 
        report  = self._build_report(elapsed=elapsed)\par 
        self._print_summary(report)\par 
        return report\par 
\par 
