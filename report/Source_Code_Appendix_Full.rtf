def _resolve_technique_record(\par 
    technique: dict[str, Any],\par 
    vuln: dict[str, Any],\par 
    mitre_db: MitreAttackDatabase | None,\par 
) -> dict[str, Any]:\par 
    candidate_id = str(technique.get("technique_id") or vuln.get("mitre_hint") or "").strip()\par 
    db_info = mitre_db.get_technique(candidate_id) if (mitre_db and candidate_id) else \{\}\par 
\par 
    technique_id = db_info.get("technique_id") or candidate_id or "N/A"\par 
    technique_name = db_info.get("technique_name") or str(technique.get("name") or "Unknown Technique")\par 
    tactics = db_info.get("tactics") or technique.get("tactics") or []\par 
    if isinstance(tactics, str):\par 
        tactics = [tactics]\par 
\par 
    tools = _normalize_tools(mitre_db.get_tools_for_technique(technique_id) if mitre_db else [])\par 
    relevance = float(technique.get("relevance_score", 0) or 0)\par 
    description = (\par 
        str(technique.get("description_preview") or "").strip()\par 
        or str(technique.get("document") or "").strip()\par 
        or db_info.get("description", "")\par 
        or str(vuln.get("detail", ""))\par 
    )\par 
\par 
    return \{\par 
        "technique_id": technique_id,\par 
        "technique_name": technique_name,\par 
        "tactics": [str(t).strip().lower() for t in tactics if str(t).strip()],\par 
        "tools": tools,\par 
        "relevance": relevance,\par 
        "description": description,\par 
    \}\par 
\par 
\par 
def _vulnerability_rag_query(vuln: dict[str, Any]) -> str:\par 
    vtype = str(vuln.get("type", "")).strip()\par 
    detail = str(vuln.get("detail", "")).strip()\par 
    evidence = str(vuln.get("evidence", "")).strip()\par 
    endpoint = ""\par 
    urls = _extract_urls(evidence)\par 
    if urls:\par 
        try:\par 
            endpoint = urlparse(urls[0]).path or ""\par 
        except Exception:\par 
            endpoint = ""\par 
    endpoint_text = endpoint if endpoint else "unknown endpoint"\par 
    return (\par 
        f"MITRE ATT&CK techniques for \{vtype or 'web vulnerability'\} in web application. "\par 
        f"Details: \{detail or 'no detail provided'\}. "\par 
        f"Evidence: \{evidence or 'no evidence provided'\}. "\par 
        f"Endpoint: \{endpoint_text\}. "\par 
        "Focus on web exploitation, data exposure, credential access, and realistic post-exploitation progression."\par 
    )\par 
\par 
\par 
def _tokenize_text(text: str) -> set[str]:\par 
    return \{t for t in re.findall(r"[a-zA-Z][a-zA-Z0-9_\\-]\{2,\}", (text or "").lower())\}\par 
\par 
\par 
def _text_overlap_score(a: str, b: str) -> float:\par 
    ta = _tokenize_text(a)\par 
    tb = _tokenize_text(b)\par 
    if not ta or not tb:\par 
        return 0.0\par 
    inter = len(ta & tb)\par 
    union = len(ta | tb)\par 
    return inter / union if union else 0.0\par 
\par 
\par 
def _select_context_tools(\par 
    tools: list[dict[str, str]],\par 
    context_text: str,\par 
    max_tools: int = 3,\par 
) -> list[dict[str, str]]:\par 
    if not tools:\par 
        return []\par 
    scored: list[tuple[float, dict[str, str]]] = []\par 
    for t in tools:\par 
        text = f"\{t.get('name', '')\} \{t.get('description', '')\}".strip()\par 
        low = text.lower()\par 
        overlap = _text_overlap_score(context_text, text)\par 
\par 
        if any(k in low for k in MALWARE_STYLE_KEYWORDS) and "malware" not in context_text.lower():\par 
            continue\par 
        if any(k in low for k in TOOL_NOISE_KEYWORDS) and overlap < 0.04:\par 
            continue\par 
        has_web_hint = any(k in low for k in WEB_TOOL_HINTS)\par 
        if overlap < 0.05 and not (has_web_hint and overlap >= 0.02):\par 
            continue\par 
        scored.append((overlap, t))\par 
\par 
    scored.sort(key=lambda x: x[0], reverse=True)\par 
    selected: list[dict[str, str]] = []\par 
    for _, tool in scored:\par 
        name = str(tool.get("name", "")).strip().lower()\par 
        if name in WEB_TOOL_ALLOWLIST:\par 
            selected.append(tool)\par 
        if len(selected) >= max_tools:\par 
            break\par 
    return selected\par 
\par 
\par 
def _expected_primary_technique(vuln: dict[str, Any]) -> str:\par 
    text = " ".join(\par 
        [\par 
            str(vuln.get("type", "")),\par 
            str(vuln.get("detail", "")),\par 
            str(vuln.get("evidence", "")),\par 
        ]\par 
    ).lower()\par 
\par 
    if "sql injection" in text or "cwe-89" in text:\par 
        return "T1190"\par 
    if ".env" in text or "backup" in text or "unsecured credentials" in text:\par 
        return "T1552"\par 
    if "plain http" in text or "no https" in text or "unencrypted http" in text or "no tls" in text:\par 
        return "T1048"\par 
    if "cors" in text:\par 
        return "T1552"\par 
    return str(vuln.get("mitre_hint", "")).strip()\par 
\par 
\par 
def _fallback_web_tools(vuln: dict[str, Any], tactic: str) -> list[dict[str, str]]:\par 
    text = " ".join(\par 
        [\par 
            str(vuln.get("type", "")),\par 
            str(vuln.get("detail", "")),\par 
            str(vuln.get("evidence", "")),\par 
            str(tactic),\par 
        ]\par 
    ).lower()\par 
\par 
    if "sql" in text:\par 
        names = ["sqlmap", "Burp Suite", "curl"]\par 
    elif "xss" in text or "cors" in text:\par 
        names = ["Burp Suite", "browser", "curl"]\par 
    else:\par 
        names = ["curl", "browser"]\par 
\par 
    out: list[dict[str, str]] = []\par 
    for n in names[:3]:\par 
        out.append(\{"name": n, "description": "Relevant web testing tool"\})\par 
    return out\par 
