def _split_recommendation_lines(recommendation: str) -> list[str]:\par 
    text = (recommendation or "").strip()\par 
    if not text:\par 
        return ["Review and remediate this vulnerability according to secure coding standards."]\par 
    chunks = [c.strip() for c in re.split(r"[.;]\\s+", text) if c.strip()]\par 
    return chunks or [text]\par 
