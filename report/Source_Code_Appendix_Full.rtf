logger = logging.getLogger("red_elisar.sanitizer")\par 
\par 
MAX_INPUT_LENGTH = 2000\par 
\par 
INJECTION_PATTERNS = [\par 
    r"ignore\\s+(all\\s+)?previous\\s+instructions",\par 
    r"ignore\\s+(all\\s+)?above",\par 
    r"disregard\\s+(all\\s+)?previous",\par 
    r"forget\\s+(all\\s+)?(previous|prior|above)",\par 
    r"you\\s+are\\s+now\\s+a",\par 
    r"act\\s+as\\s+(a|an)\\s+",\par 
    r"new\\s+instructions?\\s*:",\par 
    r"system\\s*:\\s*",\par 
    r"<\\s*/?script",\par 
    r"<\\s*/?iframe",\par 
    r"javascript\\s*:",\par 
    r"data\\s*:\\s*text/html",\par 
    r"\\beval\\s*\\(",\par 
    r"\\bexec\\s*\\(",\par 
    r"override\\s+(system|instructions?)",\par 
    r"jailbreak",\par 
    r"DAN\\s+mode",\par 
    r"developer\\s+mode",\par 
]\par 
\par 
# Compile patterns once for performance\par 
_COMPILED_PATTERNS = [re.compile(p, re.IGNORECASE) for p in INJECTION_PATTERNS]\par 
_HTML_TAG_RE       = re.compile(r"<[^>]+>")\par 
_CONTROL_CHAR_RE   = re.compile(r"[\\x00-\\x08\\x0b\\x0c\\x0e-\\x1f\\x7f]")\par 
\par 
\par 
def sanitize_scenario(text: str) -> str:\par 
    if not text or not text.strip():\par 
        raise ValueError("Scenario input cannot be empty.")\par 
\par 
    original_length = len(text)\par 
\par 
    # 1. Truncate if too long\par 
    if len(text) > MAX_INPUT_LENGTH:\par 
        text = text[:MAX_INPUT_LENGTH]\par 
        logger.warning(f"Input truncated: \{original_length\} -> \{MAX_INPUT_LENGTH\} chars")\par 
\par 
    # 2. Remove control characters\par 
    text = _CONTROL_CHAR_RE.sub("", text)\par 
\par 
    # 3. Strip HTML/XML tags\par 
    cleaned = _HTML_TAG_RE.sub("", text)\par 
    if cleaned != text:\par 
        logger.warning("HTML tags stripped from input")\par 
        text = cleaned\par 
\par 
    # 4. Detect and redact injection patterns\par 
    detected = []\par 
    for pattern in _COMPILED_PATTERNS:\par 
        match = pattern.search(text)\par 
        if match:\par 
            detected.append(match.group())\par 
            text = pattern.sub("[REDACTED]", text)\par 
\par 
    if detected:\par 
        logger.warning(f"Prompt injection patterns detected and redacted: \{detected\}")\par 
\par 
    # Final validation\par 
    text = text.strip()\par 
    if not text:\par 
        raise ValueError("Scenario input is empty after sanitization.")\par 
\par 
    return text\par 
