    # ├втАЭтВм├втАЭтВм 11. Cookie Security Flags ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм\par 
    def _check_cookie_flags(self):\par 
        try:\par 
            resp = self.session.get(f"\{self.target\}/login",\par 
                                     timeout=self.timeout)\par 
            # Make a POST to get a Set-Cookie header\par 
            post_resp = self.session.post(\par 
                f"\{self.target\}/login",\par 
                data=\{"username": "admin", "password": "admin123"\},\par 
                timeout=self.timeout,\par 
            )\par 
            for r in [resp, post_resp]:\par 
                set_cookie = r.headers.get("Set-Cookie", "")\par 
                if set_cookie:\par 
                    issues = []\par 
                    if "HttpOnly" not in set_cookie:\par 
                        issues.append("Missing HttpOnly flag ├втВмтАЭ cookie accessible via JS")\par 
                    if "Secure" not in set_cookie:\par 
                        issues.append("Missing Secure flag ├втВмтАЭ cookie sent over HTTP")\par 
                    if "SameSite" not in set_cookie:\par 
                        issues.append("Missing SameSite flag ├втВмтАЭ CSRF risk")\par 
                    for issue in issues:\par 
                        self._add(\par 
                            vuln_type  = "Insecure Cookie Configuration",\par 
                            detail     = issue,\par 
                            severity   = "MEDIUM",\par 
                            cwe        = "CWE-614",\par 
                            mitre      = "T1185",\par 
                            evidence   = f"Live Set-Cookie header: \{set_cookie[:120]\}",\par 
                            check      = "_check_cookie_flags",\par 
                            confirmed  = True,\par 
                            recommendation = (\par 
                                "Set cookies with: HttpOnly; Secure; SameSite=Strict "\par 
                                "(or Lax for SSO)."\par 
                            ),\par 
                        )\par 
                    if issues:\par 
                        break\par 
        except Exception as e:\par 
            logger.debug(f"Cookie flag check error: \{e\}")\par 
