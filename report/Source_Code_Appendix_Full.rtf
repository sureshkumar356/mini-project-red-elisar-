## F. Tool Mapper\par 
\par 
File: $(System.Collections.Hashtable.Path)\par 
\par 
```python\par 
import json\par 
import logging\par 
from typing import Optional\par 
import config\par 
\par 
logger = logging.getLogger("red_elisar.exploit_tools")\par 
\par 
_TOOLS_PATH = config.DATA_DIR / "exploit_tools.json"\par 
_CACHE: Optional[dict] = None\par 
\par 
\par 
def _load_tools() -> dict:\par 
    global _CACHE\par 
    if _CACHE is not None:\par 
        return _CACHE\par 
    if not _TOOLS_PATH.exists():\par 
        logger.warning(f"Exploit tools file not found: \{_TOOLS_PATH\}")\par 
        _CACHE = \{\}\par 
        return _CACHE\par 
    with open(_TOOLS_PATH, "r", encoding="utf-8") as f:\par 
        _CACHE = json.load(f)\par 
    logger.info(f"Loaded \{len(_CACHE)\} exploit tool entries")\par 
    return _CACHE\par 
\par 
\par 
def get_tools(technique_id: str) -> dict:\par 
    data = _load_tools()\par 
\par 
    # 1. Exact match\par 
    if technique_id in data:\par 
        return data[technique_id]\par 
\par 
    # 2. Parent technique fallback\par 
    if "." in technique_id:\par 
        parent_id = technique_id.split(".")[0]\par 
        if parent_id in data:\par 
            entry = data[parent_id].copy()\par 
            entry["_fallback"] = f"Parent technique \{parent_id\}"\par 
            return entry\par 
\par 
    # 3. Empty default\par 
    return \{\par 
        "tools": [],\par 
        "commands": [],\par 
        "platforms": [],\par 
        "_fallback": "No specific tools mapped",\par 
    \}\par 
\par 
\par 
def get_tools_for_chain(attack_chain: list[dict]) -> list[dict]:\par 
    results = []\par 
    for step in attack_chain:\par 
        tid = step.get("technique_id", "")\par 
        tools = get_tools(tid)\par 
        results.append(\{\par 
            "step": step.get("step", 0),\par 
            "technique_id": tid,\par 
            "technique_name": step.get("technique_name", ""),\par 
            "tools": tools,\par 
        \})\par 
    return results\par 
