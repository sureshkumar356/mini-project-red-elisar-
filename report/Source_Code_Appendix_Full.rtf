class StreamQueue:\par 
    """Thread-safe queue used to stream log lines back to the browser via SSE."""\par 
\par 
    def __init__(self):\par 
        self.q: queue.Queue[str | None] = queue.Queue()\par 
\par 
    def put(self, line: str):\par 
        self.q.put(line)\par 
\par 
    def done(self):\par 
        self.q.put(None)  # sentinel\par 
\par 
    def get(self, timeout: float | None = None):\par 
        return self.q.get(timeout=timeout)\par 
\par 
    def __iter__(self):\par 
        while True:\par 
            item = self.q.get()\par 
            if item is None:\par 
                break\par 
            yield item\par 
\par 
\par 
class QueueHandler(logging.Handler):\par 
    """Redirect log records into the SSE stream queue."""\par 
\par 
    def __init__(self, sq: StreamQueue):\par 
        super().__init__()\par 
        self.sq = sq\par 
\par 
    def emit(self, record: logging.LogRecord):\par 
        try:\par 
            msg = self.format(record)\par 
            self.sq.put(msg)\par 
        except Exception:\par 
            pass\par 
\par 
\par 
def _stream_gen(sq: StreamQueue, heartbeat_s: float | None = None):\par 
    """Generator that yields SSE-formatted events from the queue with keepalive."""\par 
    heartbeat = heartbeat_s or float(getattr(config, "WEB_UI_STREAM_HEARTBEAT_S", 12.0))\par 
    while True:\par 
        try:\par 
            line = sq.get(timeout=heartbeat)\par 
        except queue.Empty:\par 
            yield ": keepalive\\n\\n"\par 
            continue\par 
        if line is None:\par 
            break\par 
        safe = str(line).replace("\\n", "\\\\n")\par 
        yield f"data: \{safe\}\\n\\n"\par 
    yield "data: __DONE__\\n\\n"\par 
