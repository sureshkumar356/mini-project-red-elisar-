def _severity_counts(vulns: list[dict[str, Any]]) -> dict[str, int]:\par 
    counts = \{"CRITICAL": 0, "HIGH": 0, "MEDIUM": 0, "LOW": 0, "INFO": 0\}\par 
    for v in vulns:\par 
        sev = str(v.get("severity", "INFO")).upper()\par 
        counts[sev] = counts.get(sev, 0) + 1\par 
    return counts\par 
\par 
\par 
def _overall_risk(counts: dict[str, int]) -> str:\par 
    if counts.get("CRITICAL", 0) > 0:\par 
        return "CRITICAL"\par 
    if counts.get("HIGH", 0) >= 2:\par 
        return "HIGH"\par 
    if counts.get("HIGH", 0) >= 1 or counts.get("MEDIUM", 0) >= 3:\par 
        return "MEDIUM"\par 
    if counts.get("MEDIUM", 0) > 0:\par 
        return "LOW"\par 
    return "INFO"\par 
\par 
\par 
def _extract_urls(text: str) -> list[str]:\par 
    return re.findall(r"https?://[^\\s|`]+", text or "")\par 
\par 
\par 
def _infer_affected_url(vuln: dict[str, Any], target_url: str) -> str:\par 
    urls = _extract_urls(str(vuln.get("evidence", "")))\par 
    if urls:\par 
        return urls[0]\par 
    return target_url\par 
\par 
