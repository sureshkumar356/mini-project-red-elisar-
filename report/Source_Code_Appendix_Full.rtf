def _build_step_attribution(chain_steps: list, retrieval_results: list | None = None) -> list:\par 
    """Build explainable retrieval attribution for each generated chain step."""\par 
    retrieval_results = retrieval_results or []\par 
    by_tid = \{\}\par 
    for rank, r in enumerate(retrieval_results, start=1):\par 
        tid = str(r.get("technique_id") or "").strip().upper()\par 
        if not tid or tid in by_tid:\par 
            continue\par 
        by_tid[tid] = (rank, r)\par 
\par 
    attributions = []\par 
    for i, step in enumerate(chain_steps, start=1):\par 
        tid = str(step.get("technique_id") or "").strip().upper()\par 
        tname = str(step.get("technique_name") or step.get("name") or tid or f"Step \{i\}")\par 
        rationale = str(step.get("rationale") or "").strip()\par 
        rank, source = by_tid.get(tid, (None, None))\par 
\par 
        similarity = 0.0\par 
        evidence = []\par 
        flags = []\par 
\par 
        if source:\par 
            similarity = _coerce_float(source.get("relevance_score"), 0.0)\par 
            snippet = str(source.get("description") or "").strip()\par 
            evidence.append(\par 
                \{\par 
                    "source_type": "faiss_hit",\par 
                    "source_id": str(source.get("technique_id") or tid),\par 
                    "rank": rank,\par 
                    "similarity_score": round(similarity, 4),\par 
                    "snippet": snippet[:280],\par 
                    "matched_terms": [],\par 
                \}\par 
            )\par 
            if similarity < 0.35:\par 
                flags.append("low_similarity")\par 
        else:\par 
            evidence.append(\par 
                \{\par 
                    "source_type": "fallback",\par 
                    "source_id": tid or f"step-\{i\}",\par 
                    "rank": None,\par 
                    "similarity_score": 0.0,\par 
                    "snippet": "No direct retrieval evidence found; used generated step context.",\par 
                    "matched_terms": [],\par 
                \}\par 
            )\par 
            flags.append("fallback_used")\par 
\par 
        confidence = max(0.15, min(0.98, 0.4 + (similarity * 0.6)))\par 
        if not rationale:\par 
            flags.append("sparse_evidence")\par 
\par 
        attributions.append(\par 
            \{\par 
                "step_id": i,\par 
                "technique_id": tid,\par 
                "technique_name": tname,\par 
                "confidence_score": round(confidence, 4),\par 
                "evidence": evidence,\par 
                "rationale_summary": (rationale[:240] if rationale else "Generated from scenario context and mapped ATT&CK behavior."),\par 
                "attribution_flags": sorted(set(flags)),\par 
            \}\par 
        )\par 
\par 
    return attributions\par 
\par 
