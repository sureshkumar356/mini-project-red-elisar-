def _simulate_defense_what_if(graph: dict, controls: list[dict] | None = None) -> dict:\par 
    """Run a lightweight what-if simulation over attack graph nodes."""\par 
    controls = controls or [\par 
        \{\par 
            "control_id": "waf_strict_mode",\par 
            "name": "Strict WAF Rules",\par 
            "target_tactics": ["initial-access", "execution"],\par 
            "effect": "weaken",\par 
            "probability_multiplier": 0.65,\par 
            "cost_multiplier": 1.2,\par 
            "enabled": True,\par 
        \},\par 
        \{\par 
            "control_id": "mfa_everywhere",\par 
            "name": "MFA Everywhere",\par 
            "target_tactics": ["credential-access", "lateral-movement"],\par 
            "effect": "block",\par 
            "probability_multiplier": 0.4,\par 
            "cost_multiplier": 1.35,\par 
            "enabled": True,\par 
        \},\par 
        \{\par 
            "control_id": "edr_behavioral",\par 
            "name": "EDR Behavioral Detection",\par 
            "target_tactics": ["execution", "persistence", "impact"],\par 
            "effect": "detect",\par 
            "probability_multiplier": 0.75,\par 
            "cost_multiplier": 1.5,\par 
            "enabled": True,\par 
        \},\par 
    ]\par 
\par 
    technique_nodes = [n for n in graph.get("nodes", []) if n.get("type") == "technique"]\par 
    if not technique_nodes:\par 
        return \{\par 
            "active_controls": controls,\par 
            "path_results": [],\par 
            "global_metrics": \{\par 
                "best_attack_path_probability": 0.0,\par 
                "mean_time_to_objective": 0.0,\par 
                "residual_risk_score": 0.0,\par 
                "control_effectiveness_delta": 0.0,\par 
            \},\par 
        \}\par 
\par 
    baseline_prob = 1.0\par 
    baseline_cost = 0.0\par 
    adjusted_prob = 1.0\par 
    adjusted_cost = 0.0\par 
\par 
    per_step = []\par 
    for n in technique_nodes:\par 
        p = _coerce_float(n.get("base_probability"), 0.5)\par 
        c = _coerce_float(n.get("base_cost"), 1.0)\par 
        baseline_prob *= p\par 
        baseline_cost += c\par 
\par 
        p_adj = p\par 
        c_adj = c\par 
        tactic = str(n.get("tactic") or "")\par 
        blockers = []\par 
        for ctrl in controls:\par 
            if not ctrl.get("enabled"):\par 
                continue\par 
            if tactic not in (ctrl.get("target_tactics") or []):\par 
                continue\par 
            p_adj *= _coerce_float(ctrl.get("probability_multiplier"), 1.0)\par 
            c_adj *= _coerce_float(ctrl.get("cost_multiplier"), 1.0)\par 
            blockers.append(ctrl.get("name", "Control"))\par 
\par 
        adjusted_prob *= max(0.01, p_adj)\par 
        adjusted_cost += c_adj\par 
        per_step.append(\par 
            \{\par 
                "node_id": n.get("id"),\par 
                "technique_id": n.get("technique_id", ""),\par 
                "tactic": tactic,\par 
                "base_probability": round(p, 4),\par 
                "adjusted_probability": round(max(0.01, p_adj), 4),\par 
                "base_cost": round(c, 2),\par 
                "adjusted_cost": round(c_adj, 2),\par 
                "affected_by": blockers,\par 
            \}\par 
        )\par 
\par 
    delta = 0.0\par 
    if baseline_prob > 0:\par 
        delta = max(0.0, min(1.0, 1.0 - (adjusted_prob / baseline_prob)))\par 
\par 
    return \{\par 
        "active_controls": controls,\par 
        "path_results": [\par 
            \{\par 
                "path_id": "primary_path",\par 
                "success_probability": round(adjusted_prob, 6),\par 
                "expected_cost": round(adjusted_cost, 2),\par 
                "expected_time": round(adjusted_cost * 0.85, 2),\par 
                "blocked_by_controls": sorted(\{b for s in per_step for b in s.get("affected_by", [])\}),\par 
            \}\par 
        ],\par 
        "per_step_effects": per_step,\par 
        "global_metrics": \{\par 
            "baseline_path_probability": round(baseline_prob, 6),\par 
            "best_attack_path_probability": round(adjusted_prob, 6),\par 
            "mean_time_to_objective": round(adjusted_cost * 0.85, 2),\par 
            "residual_risk_score": round(min(1.0, adjusted_prob * 2.0), 4),\par 
            "control_effectiveness_delta": round(delta, 4),\par 
        \},\par 
    \}\par 
\par 
