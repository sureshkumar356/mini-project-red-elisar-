def _normalize_tools(raw_tools: list[dict[str, str]], max_items: int = 6) -> list[dict[str, str]]:\par 
    normalized: list[dict[str, str]] = []\par 
    seen: set[str] = set()\par 
    for t in raw_tools:\par 
        name = str(t.get("name", "Unknown Tool")).strip()\par 
        if not name or name in seen:\par 
            continue\par 
        seen.add(name)\par 
        desc = str(t.get("description", "")).strip()\par 
        if len(desc) > 220:\par 
            desc = desc[:217] + "..."\par 
        normalized.append(\{"name": name, "description": desc\})\par 
        if len(normalized) >= max_items:\par 
            break\par 
    return normalized\par 
