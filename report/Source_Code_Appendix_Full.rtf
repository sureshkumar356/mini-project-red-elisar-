def _make_session(timeout: int = 10) -> requests.Session:\par 
    """Create a resilient requests session with retry logic."""\par 
    session = requests.Session()\par 
    retry = Retry(total=2, backoff_factor=0.3, status_forcelist=[500, 502, 503])\par 
    adapter = HTTPAdapter(max_retries=retry)\par 
    session.mount("http://", adapter)\par 
    session.mount("https://", adapter)\par 
    session.headers.update(\{"User-Agent": "RedELISAR-LiveVulnChecker/2.0"\})\par 
    session.timeout = timeout\par 
    return session\par 
