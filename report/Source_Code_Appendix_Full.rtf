def _probe_missing_headers(base: str, timeout_s: float) -> dict:\par 
    required = \{\par 
        "Content-Security-Policy":    "Prevents XSS attacks",\par 
        "X-Frame-Options":            "Prevents clickjacking",\par 
        "Strict-Transport-Security":  "Enforces HTTPS",\par 
        "X-Content-Type-Options":     "Prevents MIME sniffing",\par 
        "Referrer-Policy":            "Controls referrer leakage",\par 
        "Permissions-Policy":         "Controls browser features",\par 
